Graph Memory (Neo4j)

from neo4j import GraphDatabase

driver = GraphDatabase.driver("bolt://neo4j:7687")

def add_relationship(a, b, rel):
    with driver.session() as session:
        session.run(
            "MERGE (a:Entity {name:$a}) "
            "MERGE (b:Entity {name:$b}) "
            "MERGE (a)-[r:REL {type:$rel}]->(b)",
            a=a, b=b, rel=rel
        )


