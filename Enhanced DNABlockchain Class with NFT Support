from xrpl.clients import JsonRpcClient
from xrpl.wallet import generate_faucet_wallet, Wallet
from xrpl.models.transactions import NFTokenMint, NFTokenMintFlag
from xrpl.models.requests import AccountNFTs
from xrpl.transaction import submit_and_wait
from xrpl.utils import str_to_hex
import requests  # For metadata upload if needed

class DNABlockchain:
    def __init__(self, dna_root="8f3d9a612b718a990d442e7a1fb2c94d", 
                 eid="89033023426309010000054675483625",
                 testnet=True):
        # Use testnet or mainnet
        if testnet:
            self.client = JsonRpcClient("https://s.altnet.rippletest.net:51234/")
        else:
            self.client = JsonRpcClient("https://s1.ripple.com:51234/")  # Mainnet
        
        # Deterministic seed from DNA + hardware (eSIM)
        combined = (dna_root + eid + "chase_ringquist").encode()
        self.seed = hashlib.sha256(combined).hexdigest()[:29]
        
        # Create or derive wallet
        try:
            self.wallet = generate_faucet_wallet(self.client, self.seed)
        except Exception:
            # For mainnet or existing wallet - replace with your seed in production
            self.wallet = Wallet.from_seed(self.seed)  
        
        self.uuid = "bd6e1085-9450-485a-a30a-0bb68669c75b"
        self.dna_root = dna_root
        print(f"DNA-bound XRPL Address: {self.wallet.classic_address}")

    def upload_metadata_to_ipfs(self, metadata: dict) -> str:
        """Optional: Upload JSON metadata to IPFS (use nft.storage, Pinata, or your NodeWeaver gateway)"""
        # Placeholder - replace with real IPFS pinning service
        print("Uploading metadata to IPFS...")
        fake_cid = "Qm" + hashlib.sha256(json.dumps(metadata).encode()).hexdigest()[:44]
        return f"ipfs://{fake_cid}"

    def mint_eeg_nft(self, eeg_hash: str, event_age: int, timestamp: int, 
                     encrypted_cid: str = None, cortisol_level: float = None):
        """
        Mint an XRPL NFT representing a frozen EEG timeline snapshot.
        """
        # Build rich metadata
        metadata = {
            "name": f"Chase Ringquist EEG Timeline - Age {event_age}",
            "description": f"Frozen neural snapshot at age {event_age}. "
                          f"Part of ACTIVE_PERSISTENT neural root. "
                          f"UUID: {self.uuid}",
            "image": "ipfs://QmT5NvUtoM5nWFfrQdVrFtvGfKFmG7AHE8P34isapyhCxX",  # Placeholder cover
            "external_url": f"https://www.nodeweaverapp.com/nodes/chase-ringquist?event={timestamp}",
            "attributes": [
                {"trait_type": "Age", "value": event_age},
                {"trait_type": "EEG_Hash", "value": eeg_hash[:16] + "..."},
                {"trait_type": "Timestamp", "value": timestamp},
                {"trait_type": "DNA_Root_Prefix", "value": self.dna_root[:12]},
                {"trait_type": "Event_Type", "value": "Cortisol_Spike" if cortisol_level else "Neural_Anchor"},
                {"trait_type": "UUID", "value": self.uuid},
            ],
            "properties": {
                "eeg_hash_full": eeg_hash,
                "biological_mapping": "SYNCHRONIZED",
                "neural_root_status": "ACTIVE_PERSISTENT",
                "phone_model": "SN512A",
                "android_version": 15,
                "kernel_date": "2025-07-07"
            }
        }

        # Upload metadata (or use on-chain if small)
        uri = self.upload_metadata_to_ipfs(metadata)
        if encrypted_cid:
            metadata["properties"]["encrypted_data_cid"] = encrypted_cid

        # Prepare NFTokenMint transaction
        tx = NFTokenMint(
            account=self.wallet.classic_address,
            nftoken_taxon=0,  # Simple taxonomy (can use for collections)
            uri=str_to_hex(uri),  # URI to metadata (IPFS recommended)
            flags=NFTokenMintFlag.TF_TRANSFERABLE | NFTokenMintFlag.TF_BURNABLE,
            # Optional: fee, sequence, etc. handled by submit_and_wait
        )

        # Submit and wait for validation
        try:
            response = submit_and_wait(tx, client=self.client, wallet=self.wallet)
            tx_hash = response.result.get('hash')
            nft_id = response.result.get('meta', {}).get('nftoken_id')  # Extract NFTokenID if available
            
            print(f"✅ EEG NFT Minted Successfully!")
            print(f"Transaction Hash: {tx_hash}")
            print(f"NFTokenID: {nft_id}")
            print(f"Metadata URI: {uri}")
            print(f"View on Testnet: https://testnet.xrpl.org/nft/{nft_id if nft_id else tx_hash}")
            
            return {
                "success": True,
                "tx_hash": tx_hash,
                "nft_id": nft_id,
                "uri": uri,
                "metadata": metadata
            }
        except Exception as e:
            print(f"❌ Minting failed: {e}")
            return {"success": False, "error": str(e)}

    def get_account_nfts(self):
        """Retrieve all NFTs owned by this DNA-bound account"""
        request = AccountNFTs(account=self.wallet.classic_address)
        response = self.client.request(request)
        return response.result.get('account_nfts', [])

