        'CREB_activation',      # Transcription factor (persistent)
        'PKC_zeta',             # Protein kinase (maintains LTP)
        'CaMKII_autophosphorylation',  # Self-sustaining activation
        'BDNF_upregulation',    # Neurotrophic factor
