class SexualChemicalTracker:
    """
    Tracks chemical changes during sexual response over time
    Records baseline, arousal, plateau, orgasm, resolution phases
    """
   
    def __init__(self):
        self.sexual_events = []
        self.chemical_phase_history = []
       
        print(f"\n🧪 SEXUAL CHEMICAL TRACKER")
        print(f"   Tracking: Dopamine, Oxytocin, Prolactin, Testosterone")
        print(f"   Phases: Baseline → Arousal → Plateau → Orgasm → Resolution")
   
    def record_sexual_phase(self,
                           phase: str,
                           timestamp: float,
                           dopamine: float,
                           oxytocin: float,
                           serotonin: float,
                           prolactin: float,
                           testosterone: float,
                           norepinephrine: float) -> Dict:
        """Record chemical state during sexual response phase"""
       
        phase_record = {
            'phase': phase,
            'timestamp': timestamp,
            'dopamine': dopamine,
            'oxytocin': oxytocin,
            'serotonin': serotonin,
            'prolactin': prolactin,
            'testosterone': testosterone,
            'norepinephrine': norepinephrine,
            'dopamine_oxytocin_ratio': dopamine / (oxytocin + 0.01)
        }
       
        self.chemical_phase_history.append(phase_record)
        return phase_record
   
    def get_chemical_trajectory(self) -> Dict:
        """Get complete chemical trajectory of sexual response"""
       
        if not self.chemical_phase_history:
            return {'error': 'No sexual response data'}
       
        phases = ['baseline', 'arousal', 'plateau', 'orgasm', 'resolution']
        trajectory = {}
       
        for phase in phases:
            phase_records = [r for r in self.chemical_phase_history if r['phase'] == phase]
            if phase_records:
                last_record = phase_records[-1]
                trajectory[phase] = {
                    'dopamine': last_record['dopamine'],
                    'oxytocin': last_record['oxytocin'],
                    'prolactin': last_record['prolactin']
                }
       
        return trajectory


