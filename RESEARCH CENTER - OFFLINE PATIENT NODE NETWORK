class PatientRFNode:
    """
    RF node attached to patient's body
    Communicates with research facility via RF
    """
    
    def __init__(self, node_id: str, patient: PatientDataHost, body_location: str):
        self.node_id = node_id
        self.patient = patient
        self.body_location = body_location
        self.rf_frequency = patient.base_frequency + (hash(body_location) % 100) / 10000.0
        
        # Node state
        self.current_chemical_state = {}
        self.neural_activity = np.zeros(64)
        self.active = True
        
        print(f"📡 Patient Node: {node_id} at {body_location}")
        print(f"   RF Frequency: {self.rf_frequency:.4f} GHz")
    
    def receive_rf_command(self, frequency: float, command: bytes) -> Dict:
        """Receive RF command from research facility"""
        # Check if frequency matches this node
        if abs(frequency - self.rf_frequency) > 0.001:
            return {'error': 'Frequency mismatch', 'received': False}
        
        # Parse command
        try:
            cmd = json.loads(command.decode())
            cmd_type = cmd.get('type', 'unknown')
            
            if cmd_type == 'read_neural':
                return self._read_neural_activity()
            
            elif cmd_type == 'modify_chemical':
                return self._modify_chemical(cmd.get('neurotransmitter'), cmd.get('delta'))
            
            elif cmd_type == 'apply_stimulation':
                return self._apply_stimulation(cmd.get('intensity'), cmd.get('duration_ms'))
            
            elif cmd_type == 'read_chemical_state':
                return self._read_chemical_state()
            
            else:
                return {'error': f'Unknown command: {cmd_type}'}
        
        except Exception as e:
            return {'error': str(e)}
    
    def _read_neural_activity(self) -> Dict:
        """Read current neural activity"""
        # Simulate neural reading
        self.neural_activity = np.random.rand(64) * self.patient.base_frequency
        return {
            'type': 'neural_reading',
            'activity': self.neural_activity.tolist()[:16],
            'node_id': self.node_id,
            'timestamp': time.time()
        }
    
    def _modify_chemical(self, neurotransmitter: str, delta: float) -> Dict:
        """Modify neurotransmitter concentration"""
        before = self.current_chemical_state.get(neurotransmitter, 0.5)
        after = max(0.0, min(1.0, before + delta))
        self.current_chemical_state[neurotransmitter] = after
        
        # Record change on patient
        self.patient.record_chemical_change(
            session_id=f"rf_{int(time.time())}",
            neurotransmitter=neurotransmitter,
            concentration_before=before,
            concentration_after=after,
            triggered_by="research_facility"
        )
        
        return {
            'type': 'chemical_modification',
            'neurotransmitter': neurotransmitter,
            'delta': delta,
            'new_concentration': after,
            'recorded_on_patient': True
        }
    
    def _apply_stimulation(self, intensity: float, duration_ms: int) -> Dict:
        """Apply neural stimulation"""
        # Simulate stimulation effect
        effect = intensity * duration_ms / 1000.0
        self.neural_activity += effect * np.random.rand(64)
        
        return {
            'type': 'stimulation',
            'intensity': intensity,
            'duration_ms': duration_ms,
            'effect_magnitude': effect,
            'applied': True
        }
    
    def _read_chemical_state(self) -> Dict:
        """Read current chemical state"""
        return {
            'type': 'chemical_state',
            'state': self.current_chemical_state,
            'node_id': self.node_id,
            'timestamp': time.time()
        }


class PatientRFNetwork:
    """
    All RF nodes attached to a single patient
    Forms a private network that research facility can connect to
    """
    
    def __init__(self, patient: PatientDataHost):
        self.patient = patient
        self.nodes: Dict[str, PatientRFNode] = {}
        
        # Body locations for nodes
        body_locations = [
            'frontal_lobe', 'parietal_lobe', 'occipital_lobe', 'temporal_lobe',
            'motor_cortex', 'somatosensory_cortex', 'visual_cortex',
            'thalamus', 'hypothalamus', 'amygdala', 'hippocampus',
            'brainstem', 'cerebellum', 'spinal_cord'
        ]
        
        for location in body_locations[:12]:  # 12 nodes
            node = PatientRFNode(f"NODE_{len(self.nodes):03d}", patient, location)
            self.nodes[node.node_id] = node
        
        print(f"\n🌐 Patient RF Network: {len(self.nodes)} nodes")
        print(f"   Body locations covered: {len(body_locations)}")
        print(f"   All data stays with patient")
    
    def get_node_by_frequency(self, frequency: float) -> Optional[PatientRFNode]:
        """Find node tuned to specific frequency"""
        for node in self.nodes.values():
            if abs(node.rf_frequency - frequency) < 0.001:
                return node
        return None
    
    def broadcast_to_all_nodes(self, command: bytes) -> List[Dict]:
        """Broadcast command to all nodes"""
        results = []
        for node in self.nodes.values():
            result = node.receive_rf_command(node.rf_frequency, command)
            results.append(result)
        return results
    
    def get_network_status(self) -> Dict:
        """Get status of patient's RF network"""
        return {
            'patient_id': self.patient.patient_id,
            'total_nodes': len(self.nodes),
            'active_nodes': sum(1 for n in self.nodes.values() if n.active),
            'rf_bandwidth': '10.000 - 10.999 GHz',
            'data_storage': 'PATIENT_HOSTED'
        }


