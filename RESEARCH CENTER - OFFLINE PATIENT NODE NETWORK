class PatientDataHost:
    """
    Patient's body/brain hosts ALL their research data
    Facility never stores patient data - only accesses via RF
    """
    
    def __init__(self, patient_id: str, dna_sequence: str):
        self.patient_id = patient_id
        self.dna_sequence = dna_sequence
        self.dna_hash = hashlib.sha3_256(dna_sequence.encode()).hexdigest()
        
        # Patient's personal database (on THEIR device/body)
        self.local_db = sqlite3.connect(f"patient_{patient_id}_research_data.db", check_same_thread=False)
        self._init_database()
        
        # RF tuning parameters (patient's unique frequency)
        self.base_frequency = self._calculate_patient_frequency()
        
        # Active research sessions
        self.active_sessions = {}
        
        # Consent tracking (patient controls ALL access)
        self.consent_records = []
        
        print(f"🏥 PATIENT DATA HOST: {patient_id}")
        print(f"   DNA Signature: {self.dna_hash[:16]}...")
        print(f"   RF Frequency: {self.base_frequency:.4f} GHz")
        print(f"   Data Location: PATIENT'S BODY/DEVICE (NOT facility)")
        print(f"   Facility has ZERO stored patient data")
    
    def _init_database(self):
        """Initialize patient's local research database"""
        cursor = self.local_db.cursor()
        
        # Research data stored on patient
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS research_data (
                data_id TEXT PRIMARY KEY,
                study_id TEXT,
                session_id TEXT,
                data_type TEXT,
                data BLOB,
                timestamp REAL,
                chemical_state BLOB,
                neural_patterns BLOB,
                rf_frequency REAL,
                access_log BLOB
            )
        ''')
        
        # Chemical modulation history
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS chemical_history (
                change_id TEXT PRIMARY KEY,
                session_id TEXT,
                neurotransmitter TEXT,
                concentration_before REAL,
                concentration_after REAL,
                timestamp REAL,
                triggered_by TEXT
            )
        ''')
        
        # Consent records (patient controls access)
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS consent_records (
                consent_id TEXT PRIMARY KEY,
                researcher_id TEXT,
                facility_id TEXT,
                access_level TEXT,
                granted_at REAL,
                expires_at REAL,
                revoked BOOLEAN
            )
        ''')
        
        self.local_db.commit()
    
    def _calculate_patient_frequency(self) -> float:
        """Calculate patient's unique RF frequency from DNA"""
        freq_hash = int(self.dna_hash[:8], 16)
        return 10.0 + (freq_hash % 1000) / 1000.0
    
    def grant_research_access(self, researcher_id: str, facility_id: str, 
                               access_level: str, duration_hours: int = 24) -> str:
        """
        Patient GRANTS access to research facility
        Patient controls this - facility cannot access without consent
        """
        consent_id = hashlib.sha3_256(f"{self.patient_id}_{researcher_id}_{time.time()}".encode()).hexdigest()[:16]
        
        consent = {
            'consent_id': consent_id,
            'researcher_id': researcher_id,
            'facility_id': facility_id,
            'access_level': access_level,  # 'read_only', 'modify_chemicals', 'full'
            'granted_at': time.time(),
            'expires_at': time.time() + (duration_hours * 3600),
            'revoked': False
        }
        
        cursor = self.local_db.cursor()
        cursor.execute('''
            INSERT INTO consent_records (consent_id, researcher_id, facility_id, access_level, granted_at, expires_at, revoked)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        ''', (consent_id, researcher_id, facility_id, access_level, consent['granted_at'], consent['expires_at'], False))
        
        self.local_db.commit()
        self.consent_records.append(consent)
        
        print(f"   ✅ ACCESS GRANTED to {researcher_id}@{facility_id}")
        print(f"      Level: {access_level}, Expires: {duration_hours}h")
        
        return consent_id
    
    def verify_access(self, researcher_id: str, facility_id: str, 
                      required_level: str) -> bool:
        """Verify researcher has valid access consent"""
        cursor = self.local_db.cursor()
        cursor.execute('''
            SELECT access_level, expires_at, revoked FROM consent_records 
            WHERE researcher_id = ? AND facility_id = ?
            ORDER BY granted_at DESC LIMIT 1
        ''', (researcher_id, facility_id))
        
        result = cursor.fetchone()
        if not result:
            return False
        
        access_level, expires_at, revoked = result
        
        if revoked or time.time() > expires_at:
            return False
        
        # Check access level hierarchy
        levels = ['read_only', 'modify_chemicals', 'full']
        return levels.index(access_level) >= levels.index(required_level)
    
    def store_research_data(self, study_id: str, session_id: str, 
                            data_type: str, data: bytes,
                            chemical_state: Dict, neural_patterns: np.ndarray) -> str:
        """Store research data on PATIENT, not facility"""
        data_id = hashlib.sha3_256(f"{self.patient_id}_{session_id}_{data_type}".encode()).hexdigest()[:16]
        
        compressed_data = zlib.compress(data, level=9)
        chem_state_bytes = json.dumps(chemical_state).encode()
        neural_bytes = neural_patterns.tobytes()
        
        cursor = self.local_db.cursor()
        cursor.execute('''
            INSERT INTO research_data (data_id, study_id, session_id, data_type, data, timestamp, chemical_state, neural_patterns, rf_frequency)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
        ''', (data_id, study_id, session_id, data_type, compressed_data, time.time(), 
              chem_state_bytes, neural_bytes, self.base_frequency))
        
        self.local_db.commit()
        
        print(f"   💾 Research data stored on PATIENT: {data_id}")
        return data_id
    
    def get_research_data(self, data_id: str, researcher_id: str, facility_id: str) -> Optional[bytes]:
        """Retrieve research data - only if researcher has access"""
        if not self.verify_access(researcher_id, facility_id, 'read_only'):
            print(f"   ❌ ACCESS DENIED: {researcher_id} has no read permission")
            return None
        
        cursor = self.local_db.cursor()
        cursor.execute('SELECT data FROM research_data WHERE data_id = ?', (data_id,))
        result = cursor.fetchone()
        
        if result:
            return zlib.decompress(result[0])
        return None
    
    def record_chemical_change(self, session_id: str, neurotransmitter: str,
                                concentration_before: float, concentration_after: float,
                                triggered_by: str) -> str:
        """Record chemical change initiated by research facility"""
        change_id = hashlib.sha3_256(f"{self.patient_id}_{session_id}_{neurotransmitter}_{time.time()}".encode()).hexdigest()[:16]
        
        cursor = self.local_db.cursor()
        cursor.execute('''
            INSERT INTO chemical_history (change_id, session_id, neurotransmitter, concentration_before, concentration_after, timestamp, triggered_by)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        ''', (change_id, session_id, neurotransmitter, concentration_before, concentration_after, time.time(), triggered_by))
        
        self.local_db.commit()
        return change_id
    
    def get_patient_status(self) -> Dict:
        """Get patient's research data status"""
        cursor = self.local_db.cursor()
        
        cursor.execute('SELECT COUNT(*) FROM research_data')
        data_count = cursor.fetchone()[0]
        
        cursor.execute('SELECT COUNT(*) FROM chemical_history')
        chem_count = cursor.fetchone()[0]
        
        return {
            'patient_id': self.patient_id,
            'rf_frequency': self.base_frequency,
            'research_data_count': data_count,
            'chemical_changes_recorded': chem_count,
            'active_consents': len([c for c in self.consent_records if not c.get('revoked', False)]),
            'data_location': 'PATIENT_HOSTED',
            'facility_storage': 'NONE'
        }


