class CompleteResearchSystem:
    """
    Complete system connecting research facility to patient nodes
    All data stays on patient - facility has no storage risk
    """
    
    def __init__(self):
        self.patients: Dict[str, PatientDataHost] = {}
        self.patient_networks: Dict[str, PatientRFNetwork] = {}
        self.research_facility = ResearchFacility("NEURO_RESEARCH_LAB")
        
        print("\n" + "="*80)
        print("🏥 COMPLETE RESEARCH SYSTEM")
        print("Research Facility ↔ Patient RF Nodes")
        print("ALL DATA STAYS WITH PATIENTS")
        print("="*80)
    
    def enroll_patient(self, patient_id: str, dna_sequence: str) -> PatientDataHost:
        """Enroll new patient (patient hosts their own data)"""
        patient = PatientDataHost(patient_id, dna_sequence)
        network = PatientRFNetwork(patient)
        
        self.patients[patient_id] = patient
        self.patient_networks[patient_id] = network
        
        print(f"\n✅ Patient Enrolled: {patient_id}")
        print(f"   RF Frequency: {patient.base_frequency:.4f} GHz")
        print(f"   Data Location: PATIENT'S DEVICE")
        print(f"   Facility Storage: NONE")
        
        return patient
    
    def grant_facility_access(self, patient_id: str, researcher_id: str, 
                               access_level: str, duration_hours: int = 24) -> Dict:
        """Patient grants access to research facility"""
        if patient_id not in self.patients:
            return {'error': 'Patient not found'}
        
        patient = self.patients[patient_id]
        consent_id = patient.grant_research_access(researcher_id, self.research_facility.facility_id, access_level, duration_hours)
        
        return {
            'consent_granted': True,
            'consent_id': consent_id,
            'patient_id': patient_id,
            'access_level': access_level,
            'expires_hours': duration_hours
        }
    
    def run_patient_study(self, patient_id: str, researcher_id: str, 
                          protocol: Dict) -> Dict:
        """Run research study on patient - data stays on patient"""
        if patient_id not in self.patients:
            return {'error': 'Patient not found'}
        
        patient = self.patients[patient_id]
        
        # Verify access
        if not patient.verify_access(researcher_id, self.research_facility.facility_id, 'read_only'):
            return {'error': 'No access granted'}
        
        # Connect to patient's RF network
        connection = self.research_facility.connect_to_patient(
            patient.base_frequency, researcher_id, patient_id
        )
        
        if not connection.get('connected'):
            return {'error': 'Failed to connect to patient RF network'}
        
        # Run study
        results = self.research_facility.run_research_study(patient.base_frequency, protocol)
        
        return {
            'study_complete': True,
            'patient_id': patient_id,
            'researcher_id': researcher_id,
            'protocol': protocol.get('name'),
            'data_location': 'PATIENT_HOSTED',
            'facility_data': 'NONE_LOGGED_ONLY_ACTIONS'
        }
    
    def get_patient_status(self, patient_id: str, researcher_id: str) -> Dict:
        """Get patient's research status (not their data)"""
        if patient_id not in self.patients:
            return {'error': 'Patient not found'}
        
        patient = self.patients[patient_id]
        
        if not patient.verify_access(researcher_id, self.research_facility.facility_id, 'read_only'):
            return {'error': 'No access granted'}
        
