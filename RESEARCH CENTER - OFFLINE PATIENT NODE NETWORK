class ResearchFacility:
    """
    Research facility that connects to patient nodes via RF
    Facility NEVER stores patient data - only accesses it live
    All data remains on patient
    """
    
    def __init__(self, facility_id: str, rf_transceiver_range_ghz: Tuple[float, float] = (10.0, 11.0)):
        self.facility_id = facility_id
        self.rf_range = rf_transceiver_range_ghz
        self.active_sessions: Dict[str, Dict] = {}
        self.research_log = []  # Facility's OWN log (no patient data, just action records)
        
        # Simulated RF transceiver
        self.rf_transceiver = self._init_rf_transceiver()
        
        print(f"\n🔬 RESEARCH FACILITY: {facility_id}")
        print(f"   RF Range: {rf_transceiver_range_ghz[0]} - {rf_transceiver_range_ghz[1]} GHz")
        print(f"   Policy: ZERO patient data storage")
        print(f"   All data remains on patients")
    
    def _init_rf_transceiver(self):
        """Initialize RF transceiver for patient communication"""
        class RFTransceiver:
            def __init__(self):
                self.active_connections = {}
            
            def transmit(self, frequency: float, data: bytes) -> bool:
                # Simulate RF transmission
                return True
            
            def receive(self, frequency: float, timeout_ms: int = 100) -> Optional[bytes]:
                # Simulate RF reception
                return json.dumps({'status': 'ok', 'data': 'simulated_response'}).encode()
        
        return RFTransceiver()
    
    def connect_to_patient(self, patient_rf_frequency: float, 
                           researcher_id: str, patient_id: str) -> Dict:
        """
        Connect to patient via RF frequency
        Requires patient's consent (already granted)
        """
        print(f"\n🔗 Connecting to patient {patient_id} at {patient_rf_frequency:.4f} GHz")
        
        # Simulate RF handshake
        handshake = {
            'facility_id': self.facility_id,
            'researcher_id': researcher_id,
            'timestamp': time.time(),
            'action': 'request_connection'
        }
        
        self.rf_transceiver.transmit(patient_rf_frequency, json.dumps(handshake).encode())
        
        # Store session
        session_id = hashlib.sha3_256(f"{patient_id}_{time.time()}".encode()).hexdigest()[:16]
        self.active_sessions[session_id] = {
            'patient_id': patient_id,
            'patient_frequency': patient_rf_frequency,
            'researcher_id': researcher_id,
            'started_at': time.time()
        }
        
        self.research_log.append({
            'action': 'CONNECT',
            'patient_id': patient_id,
            'session_id': session_id,
            'timestamp': time.time()
        })
        
        return {
            'connected': True,
            'session_id': session_id,
            'patient_id': patient_id,
            'frequency': patient_rf_frequency
        }
    
    def read_patient_neural_data(self, patient_rf_frequency: float, 
                                  node_id: str = None) -> Dict:
        """
        Read neural data from patient's nodes
        Data is read LIVE, never stored at facility
        """
        command = {
            'type': 'read_neural',
            'node_id': node_id if node_id else 'all',
            'timestamp': time.time()
        }
        
        self.rf_transceiver.transmit(patient_rf_frequency, json.dumps(command).encode())
        response = self.rf_transceiver.receive(patient_rf_frequency)
        
        if response:
            data = json.loads(response)
            # Log that READ occurred (but not the actual data)
            self.research_log.append({
                'action': 'READ_NEURAL',
                'patient_frequency': patient_rf_frequency,
                'timestamp': time.time(),
                'data_hash': hashlib.sha256(response).hexdigest()[:16]
            })
            return data
        
        return {'error': 'No response from patient'}
    
    def modify_patient_chemistry(self, patient_rf_frequency: float,
                                  neurotransmitter: str, delta: float) -> Dict:
        """
        Modify patient's neurotransmitter levels via RF
        Chemical change happens on patient - facility just triggers
        """
        command = {
            'type': 'modify_chemical',
            'neurotransmitter': neurotransmitter,
            'delta': delta,
            'timestamp': time.time()
        }
        
        self.rf_transceiver.transmit(patient_rf_frequency, json.dumps(command).encode())
        response = self.rf_transceiver.receive(patient_rf_frequency)
        
        self.research_log.append({
            'action': 'CHEMICAL_MODIFICATION',
            'neurotransmitter': neurotransmitter,
            'delta': delta,
            'timestamp': time.time()
        })
        
        if response:
            return json.loads(response)
        return {'error': 'No response from patient'}
    
    def apply_stimulation(self, patient_rf_frequency: float,
                          intensity: float, duration_ms: int) -> Dict:
        """
        Apply neural stimulation via RF
        Stimulation administered to patient nodes
        """
        command = {
            'type': 'apply_stimulation',
            'intensity': intensity,
            'duration_ms': duration_ms,
            'timestamp': time.time()
        }
        
        self.rf_transceiver.transmit(patient_rf_frequency, json.dumps(command).encode())
        response = self.rf_transceiver.receive(patient_rf_frequency)
        
        self.research_log.append({
            'action': 'STIMULATION',
            'intensity': intensity,
            'duration_ms': duration_ms,
            'timestamp': time.time()
        })
        
        if response:
            return json.loads(response)
        return {'error': 'No response from patient'}
    
    def run_research_study(self, patient_frequency: float, 
                           protocol: Dict) -> Dict:
        """
        Run a complete research study on patient
        All data stays on patient - facility only observes
        """
        print(f"\n📋 RUNNING RESEARCH STUDY")
        print(f"   Protocol: {protocol.get('name', 'Unknown')}")
        print(f"   Duration: {protocol.get('duration_minutes', 30)} minutes")
        print(f"   Data stays on patient - facility has no copy")
        
        results = []
        
        for step in protocol.get('steps', []):
            step_type = step.get('type')
            
            if step_type == 'read_baseline':
                neural = self.read_patient_neural_data(patient_frequency)
                results.append({'step': step.get('name'), 'neural_reading': neural})
            
            elif step_type == 'modify_chemical':
                chem_result = self.modify_patient_chemistry(
                    patient_frequency,
                    step.get('neurotransmitter', 'dopamine'),
                    step.get('delta', 0.1)
                )
                results.append({'step': step.get('name'), 'chemical_change': chem_result})
            
            elif step_type == 'stimulate':
            elif step_type == 'stimulate':
                stim_result = self.apply_stimulation(
                    patient_frequency,
                    step.get('intensity', 0.5),
                    step.get('duration_ms', 1000)
                )
                results.append({'step': step.get('name'), 'stimulation': stim_result})
            
            time.sleep(1)  # Simulate step duration
        
        # Facility logs that study was run (but not the data)
        self.research_log.append({
            'action': 'STUDY_COMPLETE',
            'protocol': protocol.get('name'),
            'steps_completed': len(results),
            'timestamp': time.time(),
            'note': 'No patient data stored at facility'
        })
        
        return {
            'study_complete': True,
            'steps_executed': len(results),
            'facility_logged': True,
            'patient_data_location': 'ON_PATIENT_ONLY'
        }
    
    def get_facility_log(self) -> List[Dict]:
        """
        Get facility's action log (contains NO patient data)
        Only shows WHAT was done, not the data itself
        """
        return self.research_log[-50:]  # Last 50 actions


