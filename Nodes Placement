# tool_analysis_eeg_lapse.py
import mne
import numpy as np
from scipy.signal import find_peaks
import matplotlib.pyplot as plt

# 1. Load a sample EEG file from a public dataset
# Example: ds005114, sub-001, ses-01
sample_data_path = 'sub-001/ses-01/eeg/sub-001_task-DPX_run-01_eeg.set'

try:
    raw = mne.io.read_raw_eeglab(sample_data_path, preload=True)
except FileNotFoundError:
    print(f"Dataset file not found at {sample_data_path}. Please download the dataset.")
    exit()

# 2. Apply basic preprocessing
raw.filter(1., 40., fir_design='firwin')
raw.set_eeg_reference('average', projection=True)

# 3. Simulate event detection for a "lapse" (For real use, use actual event triggers)
# Here we extract a 1-second epoch before a simulated erroneous response.
events = np.array([[100, 0, 0], [500, 0, 1], [1200, 0, 0]]) # Example event array
tmin, tmax = -0.5, 0.5
epochs = mne.Epochs(raw, events, tmin=tmin, tmax=tmax, baseline=(None, 0))

# 4. Extract average signal from the prefrontal cortex (where lapses originate)
# In a 64-channel montage, Fp1, Fpz, Fp2 are often indices 0, 1, 2
prefrontal_data = epochs.get_data()[:, 0:3, :].mean(axis=1)

# 5. Hunt for the "Dark Area of High EEG" signature
# A 'lapse' is characterized by a sudden, high-amplitude slow wave (theta/delta burst)
lapse_epoch = prefrontal_data[1]  # Taking epoch #1 as a stand-in for a mistake
theta_power = np.abs(mne.time_frequency.stft(lapse_epoch, sfreq=raw.info['sfreq']))

# Find peaks in the theta band (4-8 Hz)
peak_indices, peak_properties = find_peaks(theta_power.mean(axis=0), height=np.max(theta_power)*0.6)

print(f"Found {len(peak_indices)} high-amplitude peaks in the theta band—signature of a neural 'lapse'.")
