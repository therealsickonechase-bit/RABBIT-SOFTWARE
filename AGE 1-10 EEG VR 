# =============================================================================
# SECTION 1: EEG RECORDING TYPES
# =============================================================================

class EEGRecordingType(Enum):
    CLINICAL_BASELINE = "clinical_baseline"
    RESEARCH_STUDY = "research_study"
    VR_VIEWING = "vr_viewing"
    SLEEP_STUDY = "sleep_study"
    STRESS_RESPONSE = "stress_response"
    COGNITIVE_TASK = "cognitive_task"
    HOME_MONITORING = "home_monitoring"
    MEDICAL_EVALUATION = "medical_evaluation"


class RecordingState(Enum):
    LIVE = "live"      # Active real-time recording
    PAUSED = "paused"   # Frozen/saved recording
    ARCHIVED = "archived"  # Stored for research


@dataclass
class EEGRecording:
    """Complete EEG recording session with all metadata"""
    recording_id: str
    recording_type: EEGRecordingType
    state: RecordingState
    age_years: float
    age_months: int
    date: str
    location: str
    duration_minutes: float
   
    # EEG Band Powers
    delta_power: float
    theta_power: float
    alpha_power: float
    beta_power: float
    gamma_power: float
   
    # Chemical/Hormone Levels at time of recording
    dopamine: float
    serotonin: float
    cortisol: float
    oxytocin: float
    melatonin: float
    growth_hormone: float
   
    # RF Frequency Data
    rf_frequency_ghz: float
    rf_signal_strength_dbm: float
   
    # VR/Viewing Data (if applicable)
    vr_exposure: bool
    vr_content_type: Optional[str]
    viewing_duration_min: Optional[float]
   
    # Research/Medical Context
    research_study_id: Optional[str]
    medical_reason: Optional[str]
    consent_obtained: bool
   
    # Network State
    network_status: str  # online, offline, mesh
    data_synced: bool
   
    # Notes
    notes: str


