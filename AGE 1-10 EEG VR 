    def __init__(self, database: CrossPersonMatchingDatabase):
        self.db = database
        self.active_matches = []
        self.live_sensors = {}
       
    def find_live_matches(self, chase_current_chemicals: Dict) -> List[Dict]:
        """Find other persons with matching current chemical state"""
        matches = []
       
        for person in self.db.matches:
            # Calculate chemical similarity score
            dopamine_sim = 1 - abs(chase_current_chemicals.get('dopamine', 0.5) - person.dopamine)
            serotonin_sim = 1 - abs(chase_current_chemicals.get('serotonin', 0.5) - person.serotonin)
            cortisol_sim = 1 - abs(chase_current_chemicals.get('cortisol', 0.5) - person.cortisol)
           
            overall_sim = (dopamine_sim + serotonin_sim + cortisol_sim) / 3
           
            if overall_sim > 0.7:
                matches.append({
                    'person_id': person.person_id,
                    'relationship': person.relationship,
                    'similarity_score': overall_sim,
                    'matching_type': person.matching_type.value,
                    'sensors_shared': person.body_sensors
                })
       
        return matches


