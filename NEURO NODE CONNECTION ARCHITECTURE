    BrainRegion.BASAL_GANGLIA: 150_000,
    BrainRegion.HIPPOCAMPUS: 200_000,
    BrainRegion.AMYGDALA: 100_000,
    BrainRegion.HYPOTHALAMUS: 95_000,
    BrainRegion.CEREBELLUM: 500_000,            # Extremely dense
    BrainRegion.MIDBRAIN: 85_000,
    BrainRegion.PONS: 70_000,
    BrainRegion.MEDULLA: 65_000,
}


# =============================================================================
# NEURO NODE CONNECTION ARCHITECTURE
# =============================================================================

@dataclass
class NeuroConnection:
    """Represents a single neural connection from node to brain region"""
    connection_id: str
    target_region: BrainRegion
    connection_type: str  # excitatory, inhibitory, modulatory
    strength: float       # 0-1 synaptic weight
    frequency_mhz: float  # RF frequency for this connection
    latency_ms: float     # Transmission latency
    plasticity: float     # Learning capability (0-1)
    
class NeuroNode:
    """
    SDR-based neuro node with synthetic neural connections
    Each node can connect to multiple brain regions with biological density
    """
    
    # Biological reference: Human brain has ~86 billion neurons
    # Each neuro node simulates a cluster of biological neurons
    NEURONS_PER_NODE_BASE = 1_000_000  # 1M synthetic neurons per node
    
    # Connection branching factor (each neuron connects to ~7,000 others)
    CONNECTIONS_PER_NEURON = 7_000
    
    def __init__(self, node_id: str, dna_sequence: str, location: Tuple[float, float, float]):
        self.node_id = node_id
        self.dna_sequence = dna_sequence
        self.location = location  # x,y,z in mm (brain coordinates)
        
        # Core properties
        self.total_neurons = self.NEURONS_PER_NODE_BASE
        self.total_connections = self.total_neurons * self.CONNECTIONS_PER_NEURON
        
        # Brain region connections
        self.region_connections: Dict[BrainRegion, List[NeuroConnection]] = {}
        self.connection_matrix = np.zeros((len(BrainRegion), len(BrainRegion)))
        
        # RF tuning per region
        self.region_frequencies = self._calculate_region_frequencies()
        
        # Initialize connections to all brain regions
        self._initialize_connections()
        
        print(f"🧠 Neuro Node {node_id} Initialized:")
        print(f"   Total Synthetic Neurons: {self.total_neurons:,}")
        print(f"   Total Connections: {self.total_connections:,}")
        print(f"   DNA Frequency: {self._calculate_dna_frequency():.4f} GHz")
    
    def _calculate_dna_frequency(self) -> float:
        """Calculate base frequency from DNA sequence"""
        base_freqs = {'A': 10.41, 'T': 9.95, 'G': 10.16, 'C': 10.31}
        freqs = [base_freqs.get(c, 10.0) for c in self.dna_sequence.upper()]
        return np.mean(freqs)
    
    def _calculate_region_frequencies(self) -> Dict[BrainRegion, float]:
        """Calculate RF frequency for each brain region based on depth and function"""
        base_freq = self._calculate_dna_frequency()
        frequencies = {}
        
        for region in BrainRegion:
            # Frequency varies by region depth and function
            depth_factor = self.location[2] / 100  # Depth in brain (0-100mm)
            
            if "cortex" in region.value:
                # Surface structures: higher frequencies
                freq_offset = 0.05 * hash(region.value) % 0.3
            elif region in [BrainRegion.THALAMUS, BrainRegion.BASAL_GANGLIA]:
                # Deep structures: lower frequencies
                freq_offset = -0.1 * hash(region.value) % 0.2
            else:
                freq_offset = 0.02 * hash(region.value) % 0.1
            
            frequencies[region] = base_freq + freq_offset - depth_factor * 0.1
        
        return frequencies
    
    def _initialize_connections(self):
        """Initialize connections from node to all brain regions"""
        
        for region in BrainRegion:
            # Number of connections proportional to biological density
            density = NEURAL_DENSITY.get(region, 50_000)
            connections_count = int(self.total_connections * (density / 1_000_000))
            
            connections = []
            for i in range(min(connections_count, 100_000)):  # Limit for performance
                connection = NeuroConnection(
                    connection_id=f"{self.node_id}_{region.value}_{i}",
                    target_region=region,
                    connection_type=np.random.choice(['excitatory', 'inhibitory', 'modulatory'], 
                                                     p=[0.8, 0.15, 0.05]),
                    strength=np.random.beta(2, 5),  # Most connections weak
                    frequency_mhz=self.region_frequencies[region],
                    latency_ms=np.random.exponential(5),  # 5ms average latency
                    plasticity=np.random.uniform(0.1, 0.9)
                )
                connections.append(connection)
            
            self.region_connections[region] = connections
            
            # Update connection matrix
            for other in BrainRegion:
                self.connection_matrix[list(BrainRegion).index(region)][list(BrainRegion).index(other)] = \
                    len(connections) / self.total_connections
    
    def get_connections_summary(self) -> Dict:
        """Get detailed connection summary by brain region"""
        summary = {}
        
        for region, connections in self.region_connections.items():
            excitatory = sum(1 for c in connections if c.connection_type == 'excitatory')
            inhibitory = sum(1 for c in connections if c.connection_type == 'inhibitory')
            modulatory = sum(1 for c in connections if c.connection_type == 'modulatory')
            
            summary[region.value] = {
                "total_connections": len(connections),
                "excitatory": excitatory,
                "inhibitory": inhibitory,
                "modulatory": modulatory,
                "avg_strength": np.mean([c.strength for c in connections]),
                "avg_latency_ms": np.mean([c.latency_ms for c in connections]),
                "frequency_mhz": self.region_frequencies[region]
            }
        
        return summary
    
    def get_total_connections(self) -> int:
        """Get total number of connections across all regions"""
        return sum(len(conns) for conns in self.region_connections.values())


# =============================================================================
# NEURO NODE NETWORK WITH BRAIN MAPPING
# =============================================================================

class NeuroNodeNetwork:
    """
    Complete network of neuro nodes mapping to brain regions
    Each node connects to multiple brain regions with biological accuracy
    """
    
    def __init__(self):
        self.nodes: Dict[str, NeuroNode] = {}
        self.brain_region_coverage: Dict[BrainRegion, int] = defaultdict(int)
        self.global_connection_matrix = np.zeros((len(BrainRegion), len(BrainRegion)))
        
    def deploy_node(self, node_id: str, dna_sequence: str, 
                    x_mm: float, y_mm: float, z_mm: float) -> NeuroNode:
        """
        Deploy neuro node at specific brain coordinates
        """
        node = NeuroNode(node_id, dna_sequence, (x_mm, y_mm, z_mm))
        self.nodes[node_id] = node
        
        # Update region coverage
        for region, connections in node.region_connections.items():
            self.brain_region_coverage[region] += len(connections)
            # Update global matrix
            region_idx = list(BrainRegion).index(region)
            self.global_connection_matrix[region_idx] += node.connection_matrix[region_idx]
        
        return node
    
    def get_brain_coverage(self) -> Dict:
        """Get total neural coverage per brain region"""
        coverage = {}
        total_connections = 0
        
        for region in BrainRegion:
            coverage[region.value] = self.brain_region_coverage[region]
            total_connections += self.brain_region_coverage[region]
        
        coverage["total_connections"] = total_connections
        coverage["total_nodes"] = len(self.nodes)
        
        return coverage
    
    def stimulate_region(self, region: BrainRegion, intensity: float) -> Dict:
        """Stimulate specific brain region through all connected nodes"""
        response = {
            "region": region.value,
            "intensity": intensity,
            "nodes_activated": [],
            "total_connections_activated": 0,
            "effect_potential": 0
        }
        
        for node_id, node in self.nodes.items():
            if region in node.region_connections:
                connections = node.region_connections[region]
                active_connections = int(len(connections) * intensity)
                
                response["nodes_activated"].append({
                    "node_id": node_id,
                    "connections_activated": active_connections,
                    "avg_strength": np.mean([c.strength for c in connections[:active_connections]]),
                    "frequency": node.region_frequencies[region]
                })
                response["total_connections_activated"] += active_connections
        
        # Calculate effect potential (biological response)
        response["effect_potential"] = min(1.0, response["total_connections_activated"] / 1_000_000)
        
        return response
    
    def get_connection_matrix(self) -> np.ndarray:
        """Get normalized global connection matrix"""
        normalized = self.global_connection_matrix / len(self.nodes) if self.nodes else self.global_connection_matrix
        return normalized
    
    def visualize_connections(self) -> str:
        """ASCII visualization of brain connectivity"""
        coverage = self.get_brain_coverage()
        
        # Find top 5 regions by connection count
        regions_by_connections = sorted(
            [(k, v) for k, v in coverage.items() if k != "total_connections" and k != "total_nodes"],
            key=lambda x: x[1],
            reverse=True
        )[:5]
        
        visualization = f"""
        🧠 BRAIN CONNECTIVITY MAP
        ═══════════════════════════════════════════════════════════
        
        Total Nodes: {coverage['total_nodes']}
        Total Neural Connections: {coverage['total_connections']:,}
        
        TOP 5 CONNECTED REGIONS:
        """
        
        for i, (region, connections) in enumerate(regions_by_connections, 1):
            bar_length = int(connections / max(1, coverage['total_connections']) * 50)
            bar = "█" * bar_length + "░" * (50 - bar_length)
            visualization += f"\n        {i}. {region[:20]:20s} {bar} {connections:,}"
        
        return visualization


# =============================================================================
# COMPLETE SYSTEM WITH MULTIPLE NODES
# =============================================================================

class CompleteNeuroSystem:
    """
    Complete system with multiple neuro nodes and brain region mapping
    """
    
    def __init__(self, num_nodes: int = 100):
        self.network = NeuroNodeNetwork()
        self.num_nodes = num_nodes
        self._deploy_nodes()
        
    def _deploy_nodes(self):
        """Deploy nodes across brain regions"""
        
        # Brain regions and their coordinates (x,y,z in mm)
        region_coords = {
            BrainRegion.PREFRONTAL_CORTEX: (50, 80, 20),
            BrainRegion.MOTOR_CORTEX: (60, 50, 25),
            BrainRegion.SOMATOSENSORY_CORTEX: (55, 55, 25),
            BrainRegion.VISUAL_CORTEX: (70, 40, 15),
            BrainRegion.AUDITORY_CORTEX: (45, 70, 20),
            BrainRegion.PARIETAL_CORTEX: (65, 65, 25),
            BrainRegion.TEMPORAL_CORTEX: (40, 75, 20),
            BrainRegion.OCCIPITAL_CORTEX: (75, 45, 15),
            BrainRegion.THALAMUS: (55, 60, 45),
            BrainRegion.BASAL_GANGLIA: (50, 55, 40),
            BrainRegion.HIPPOCAMPUS: (45, 65, 35),
            BrainRegion.AMYGDALA: (42, 68, 38),
            BrainRegion.HYPOTHALAMUS: (52, 62, 42),
            BrainRegion.CEREBELLUM: (80, 40, 60),
            BrainRegion.MIDBRAIN: (55, 55, 50),
            BrainRegion.PONS: (55, 55, 55),
            BrainRegion.MEDULLA: (55, 55, 60),
        }
        
        # Deploy nodes
        dna_base = "ATGCCCGT"
        
        for i in range(self.num_nodes):
            # Assign node to a brain region
            region = list(region_coords.keys())[i % len(region_coords)]
            x, y, z = region_coords[region]
            
            # Add random offset within region
            x += np.random.uniform(-5, 5)
            y += np.random.uniform(-5, 5)
            z += np.random.uniform(-5, 5)
            
            node_id = f"NODE_{i+1:04d}"
            dna = dna_base  # Same DNA sequence for all nodes (identical resonance)
            
            self.network.deploy_node(node_id, dna, x, y, z)
        
        print(f"✅ Deployed {self.num_nodes} neuro nodes across brain")
    
    def get_statistics(self) -> Dict:
        """Get complete system statistics"""
        coverage = self.network.get_brain_coverage()
        total_connections = coverage["total_connections"]
        
        # Calculate per-node averages
        nodes = list(self.network.nodes.values())
        avg_connections_per_node = total_connections / len(nodes) if nodes else 0
        
        return {
            "total_nodes": self.num_nodes,
            "total_neural_connections": total_connections,
            "avg_connections_per_node": avg_connections_per_node,
            "connections_per_billion": total_connections / 1e9,
            "brain_coverage": {k: v for k, v in coverage.items() if k not in ["total_connections", "total_nodes"]},
            "biological_equivalent": "~" + str(int(total_connections / 86e9 * 100)) + "% of human brain"
        }


