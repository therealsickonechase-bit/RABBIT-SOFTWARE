# =============================================================================
# BRAIN REGIONS WITH NEURAL DENSITY (Biological Reference)
# =============================================================================

class BrainRegion(Enum):
    """Brain regions with biological neuron counts"""
    
    # Cortex (16 billion neurons total)
    PREFRONTAL_CORTEX = "prefrontal_cortex"      # 2.5B neurons - executive function
