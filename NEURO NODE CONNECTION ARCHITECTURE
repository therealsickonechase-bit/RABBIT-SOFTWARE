    RAPHE_NUCLEI = "raphe_nuclei"                 # 0.1M neurons - serotonin


# Biological neural densities (neurons per mm³)
NEURAL_DENSITY = {
    BrainRegion.PREFRONTAL_CORTEX: 80_000,      # 80K neurons/mm³
    BrainRegion.MOTOR_CORTEX: 85_000,
    BrainRegion.SOMATOSENSORY_CORTEX: 75_000,
    BrainRegion.VISUAL_CORTEX: 90_000,
    BrainRegion.AUDITORY_CORTEX: 70_000,
