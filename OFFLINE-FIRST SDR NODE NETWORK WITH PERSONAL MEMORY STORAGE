class PersonalSDRNode:
    """
    SDR node tuned to a specific person's frequency
    Attached to the person - moves with them
    Stores patterns locally on the person
    """
    
    def __init__(self, node_id: str, person_host: PersonalMemoryHost, position: str):
        self.node_id = node_id
        self.person = person_host
        self.position = position  # Where on body (head, chest, arm, etc.)
        
        # Person's unique frequency
        self.base_frequency = person_host._get_person_frequency()
        
        # Node tuning parameters (stored on person)
        self._load_tuning()
        
        # Active patterns (currently firing)
        self.active_patterns = []
        self.pattern_history = []
        
        # Applications this node supports
        self.supported_applications = set()
        
        print(f"📡 Personal Node {node_id} attached to {person_host.person_id}")
        print(f"   Position: {position}")
        print(f"   Frequency: {self.base_frequency:.4f} GHz")
        print(f"   Data Storage: PERSONAL (No external server)")
    
    def _load_tuning(self):
        """Load node tuning from person's local storage"""
        cursor = self.person.local_db.cursor()
        cursor.execute('SELECT base_frequency, current_offset, sensitivity FROM node_tuning WHERE node_id = ?', (self.node_id,))
        result = cursor.fetchone()
        
        if result:
            self.base_frequency = result[0] + result[1]
            self.sensitivity = result[2]
        else:
            self.sensitivity = 0.5
            # Store initial tuning
            cursor.execute('''
                INSERT INTO node_tuning (node_id, base_frequency, current_offset, sensitivity, last_calibration)
                VALUES (?, ?, ?, ?, ?)
            ''', (self.node_id, self.base_frequency, 0.0, self.sensitivity, time.time()))
            self.person.local_db.commit()
    
    def detect_pattern(self, rf_signal: np.ndarray) -> Dict:
        """
        Detect pattern from RF signal
        Pattern is stored on the person, not on external server
        """
        # Extract pattern signature
        pattern_hash = hashlib.sha3_256(rf_signal.tobytes()).hexdigest()[:16]
        
        # Check if pattern exists in person's memory
        cursor = self.person.local_db.cursor()
        cursor.execute('SELECT pattern_id, pattern_type, strength FROM memory_patterns WHERE pattern_id LIKE ?', (f'%{pattern_hash[:8]}%',))
        result = cursor.fetchone()
        
        if result:
            return {
                'detected': True,
                'pattern_id': result[0],
                'pattern_type': result[1],
                'strength': result[2],
                'source': 'PERSONAL_MEMORY'
            }
        else:
            # New pattern - store it
            pattern_id = self.person.store_memory(rf_signal.tobytes(), 'rf_pattern', 0.3)
            return {
                'detected': True,
                'pattern_id': pattern_id,
                'pattern_type': 'new',
                'strength': 0.3,
                'source': 'NEW_PATTERN_STORED'
            }
    
    def emit_pattern(self, pattern_id: str) -> np.ndarray:
        """Emit a stored pattern as RF signal"""
        pattern_data = self.person.recall_memory(pattern_id)
        if pattern_data:
            signal = np.frombuffer(pattern_data, dtype=np.float32)
            # Modulate with person's frequency
            t = np.linspace(0, 1, len(signal))
            modulated = signal * np.sin(2 * np.pi * self.base_frequency * t)
            return modulated
        return np.zeros(100)
    
    def tune_to_application(self, application: str):
        """Tune node to support specific application"""
        self.supported_applications.add(application)
        
        # Adjust frequency for application
        app_freq_offset = {
            'gaming': 0.01,
            'experiment': 0.02,
            'intimacy': 0.03,
            'llm_training': 0.04,
            'api_access': 0.05
        }.get(application, 0.0)
        
        cursor = self.person.local_db.cursor()
        cursor.execute('''
            UPDATE node_tuning 
            SET current_offset = ?, last_calibration = ?
            WHERE node_id = ?
        ''', (app_freq_offset, time.time(), self.node_id))
        self.person.local_db.commit()
        
        print(f"   🎯 Node {self.node_id} tuned for: {application}")


