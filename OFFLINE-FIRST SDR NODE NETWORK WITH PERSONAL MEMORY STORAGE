class OfflineSyncEngine:
    """
    Syncs person's data ONLY when they choose
    Person controls ALL data flow
    """
    
    def __init__(self, person: PersonalMemoryHost):
        self.person = person
        self.sync_permission = False  # Person must grant permission
        self.sync_queue = []
    
    def request_sync_permission(self, requester: str, data_types: List[str]) -> Dict:
        """
        Someone requests sync with this person
        Person must explicitly grant permission
        """
        print(f"\n🔐 SYNC REQUEST from {requester}")
        print(f"   Requesting: {data_types}")
        
        # Person decides (simulated - in reality would be user input)
        permission_granted = True  # Assume person allows for demo
        
        if permission_granted:
            return self._execute_sync(requester, data_types)
        else:
            return {
                'status': 'DENIED',
                'message': f'{self.person.person_id} denied sync request'
            }
    
    def _execute_sync(self, requester: str, data_types: List[str]) -> Dict:
        """Execute sync with permission"""
        synced_data = {}
        
        cursor = self.person.local_db.cursor()
        
        if 'memories' in data_types:
            cursor.execute('SELECT pattern_id, pattern_type FROM memory_patterns LIMIT 10')
            synced_data['memories'] = cursor.fetchall()
        
        if 'experiences' in data_types:
            cursor.execute('SELECT exp_id, exp_type FROM experiences LIMIT 10')
            synced_data['experiences'] = cursor.fetchall()
        
        return {
            'status': 'SYNCED',
            'data': synced_data,
            'sync_point': time.time(),
            'data_owner': self.person.person_id
        }
    
    def push_to_external(self, destination: str, data: bytes) -> Dict:
        """
        Person pushes data to external system (API, server, etc.)
        Person controls what and when to push
        """
        print(f"\n📤 PUSHING DATA to {destination}")
        print(f"   Data size: {len(data)} bytes")
        print(f"   Owner: {self.person.person_id} (controls all sharing)")
        
        # Log the push (for person's records)
        push_record = {
            'destination': destination,
            'data_hash': hashlib.sha3_256(data).hexdigest(),
            'timestamp': time.time(),
            'person_consent': True
        }
        
        self.sync_queue.append(push_record)
        
        return {
            'status': 'PUSHED',
            'destination': destination,
            'data_hash': push_record['data_hash'][:16],
            'person_consent': 'EXPLICIT'
        }


