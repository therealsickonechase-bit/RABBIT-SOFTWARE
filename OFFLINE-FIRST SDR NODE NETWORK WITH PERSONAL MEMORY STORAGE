class PersonalMemoryHost:
    """
    The PERSON is the host. Their body/brain stores all patterns.
    No external server needed - data lives in the person.
    Nodes are tuned to this specific person's DNA/EEG signature.
    """
    
    def __init__(self, person_id: str, dna_sequence: str):
        self.person_id = person_id
        self.dna_sequence = dna_sequence
        self.dna_hash = hashlib.sha3_256(dna_sequence.encode()).hexdigest()
        
        # Personal database (stores ALL patterns locally)
        self.local_db = sqlite3.connect(f"person_{person_id}_memory.db", check_same_thread=False)
        self._init_database()
        
        # Personal memory stores
        self.memories = []           # Personal memories
        self.patterns = []           # Neural patterns
        self.experiences = []        # Life experiences
        self.learned_responses = []  # Learned behaviors
        
        # Node tuning cache
        self.node_tuning = {}
        
        # Offline sync queue
        self.sync_queue = queue.Queue()
        
        print(f"🧠 PERSONAL MEMORY HOST: {person_id}")
        print(f"   DNA Signature: {self.dna_hash[:16]}...")
        print(f"   Storage Location: PERSON'S BODY/BRAIN (Local)")
        print(f"   No external server required - PERSON is the server")
    
    def _init_database(self):
        """Initialize local memory database on the person"""
        cursor = self.local_db.cursor()
        
        # Memory patterns stored in the person
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS memory_patterns (
                pattern_id TEXT PRIMARY KEY,
                pattern_type TEXT,
                pattern_data BLOB,
                created_at REAL,
                access_count INTEGER,
                last_accessed REAL,
                rf_frequency REAL,
                strength REAL
            )
        ''')
        
        # Experiences log
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS experiences (
                exp_id TEXT PRIMARY KEY,
                exp_type TEXT,
                data BLOB,
                timestamp REAL,
                emotional_valence REAL,
                node_activations BLOB
            )
        ''')
        
        # Learned responses (like muscle memory)
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS learned_responses (
                response_id TEXT PRIMARY KEY,
                trigger_pattern BLOB,
                response_pattern BLOB,
                success_count INTEGER,
                last_used REAL
            )
        ''')
        
        # Node tuning parameters (unique to this person)
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS node_tuning (
                node_id TEXT PRIMARY KEY,
                base_frequency REAL,
                current_offset REAL,
                sensitivity REAL,
                last_calibration REAL
            )
        ''')
        
        self.local_db.commit()
    
    def store_memory(self, memory_data: bytes, memory_type: str, strength: float = 0.5) -> str:
        """
        Store a memory pattern - lives ON THE PERSON
        This NEVER goes to an external server unless synced
        """
        pattern_id = hashlib.sha3_256(f"{self.person_id}_{time.time()}_{memory_type}".encode()).hexdigest()[:16]
        
        # Compress for efficient personal storage
        compressed = zlib.compress(memory_data, level=9)
        
        cursor = self.local_db.cursor()
        cursor.execute('''
            INSERT INTO memory_patterns (pattern_id, pattern_type, pattern_data, created_at, access_count, last_accessed, rf_frequency, strength)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
        ''', (pattern_id, memory_type, compressed, time.time(), 0, time.time(), self._get_person_frequency(), strength))
        
        self.local_db.commit()
        
        # Keep in active memory cache
        self.memories.append({
            'id': pattern_id,
            'type': memory_type,
            'strength': strength,
            'timestamp': time.time()
        })
        
        print(f"   💾 Memory Stored: {pattern_id} (Type: {memory_type})")
        return pattern_id
    
    def recall_memory(self, pattern_id: str) -> Optional[bytes]:
        """Recall a memory - retrieved from person's local storage"""
        cursor = self.local_db.cursor()
        cursor.execute('SELECT pattern_data FROM memory_patterns WHERE pattern_id = ?', (pattern_id,))
        result = cursor.fetchone()
        
        if result:
            # Update access count
            cursor.execute('''
                UPDATE memory_patterns 
                SET access_count = access_count + 1, last_accessed = ?
                WHERE pattern_id = ?
            ''', (time.time(), pattern_id))
            self.local_db.commit()
            
            return zlib.decompress(result[0])
        
        return None
    
    def _get_person_frequency(self) -> float:
        """Calculate person's unique RF frequency from DNA"""
        # Each person has unique frequency based on their DNA
        freq_hash = int(self.dna_hash[:8], 16)
        return 10.0 + (freq_hash % 1000) / 1000.0  # 10.000 - 10.999 GHz
    
    def record_experience(self, exp_type: str, data: bytes, emotional_valence: float = 0.0):
        """Record a life experience - stored on the person"""
        exp_id = hashlib.sha3_256(f"{self.person_id}_{time.time()}_{exp_type}".encode()).hexdigest()[:16]
        
        compressed = zlib.compress(data, level=9)
        
        cursor = self.local_db.cursor()
        cursor.execute('''
            INSERT INTO experiences (exp_id, exp_type, data, timestamp, emotional_valence)
            VALUES (?, ?, ?, ?, ?)
        ''', (exp_id, exp_type, compressed, time.time(), emotional_valence))
        
        self.local_db.commit()
        self.experiences.append({'id': exp_id, 'type': exp_type, 'valence': emotional_valence})
        
        return exp_id
    
    def learn_response(self, trigger_pattern: bytes, response_pattern: bytes) -> str:
        """Learn a new response pattern (like muscle memory)"""
        response_id = hashlib.sha3_256(f"{self.person_id}_response_{time.time()}".encode()).hexdigest()[:16]
        
        cursor = self.local_db.cursor()
        cursor.execute('''
            INSERT INTO learned_responses (response_id, trigger_pattern, response_pattern, success_count, last_used)
            VALUES (?, ?, ?, ?, ?)
        ''', (response_id, trigger_pattern, response_pattern, 0, time.time()))
        
        self.local_db.commit()
        
        return response_id
    
    def get_personal_stats(self) -> Dict:
        """Get statistics about person's stored data"""
        cursor = self.local_db.cursor()
        
        cursor.execute('SELECT COUNT(*) FROM memory_patterns')
        memory_count = cursor.fetchone()[0]
        
        cursor.execute('SELECT COUNT(*) FROM experiences')
        experience_count = cursor.fetchone()[0]
        
        cursor.execute('SELECT COUNT(*) FROM learned_responses')
        response_count = cursor.fetchone()[0]
        
        return {
            'person_id': self.person_id,
            'memories_stored': memory_count,
            'experiences_recorded': experience_count,
            'learned_responses': response_count,
            'storage_location': 'PERSONAL (Body/Brain)',
            'total_data_gb': (memory_count + experience_count) * 0.001  # Estimate
        }


