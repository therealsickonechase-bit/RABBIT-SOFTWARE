рҹ“Ў 3. EVENT BUS (LIGHTWEIGHT CORE)

# core/event_bus.py
from collections import deque

class EventBus:
    def __init__(self):
        self.queue = deque(maxlen=10000)

    def publish(self, event):
        self.queue.append(event)

    def consume(self):
        if self.queue:
            return self.queue.popleft()
        return None

bus = EventBus()


