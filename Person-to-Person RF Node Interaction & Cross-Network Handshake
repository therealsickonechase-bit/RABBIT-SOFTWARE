class MultiPersonInteractionController:
    """
    Controls interactions between multiple persons' node networks
    Simulates RF communication between individuals
    """
    
    def __init__(self):
        self.persons: Dict[str, PersonNodeNetwork] = {}
        self.interaction_log = []
        
    def add_person(self, person_id: str, dna_sequence: str, name: str) -> PersonNodeNetwork:
        """Add a person to the interaction network"""
        person = PersonNodeNetwork(person_id, dna_sequence, name)
        self.persons[person_id] = person
        return person
    
    def persons_in_range(self, person_a_id: str, person_b_id: str) -> bool:
        """
        Check if two persons are within RF range
        Based on frequency overlap
        """
        if person_a_id not in self.persons or person_b_id not in self.persons:
            return False
        
        person_a = self.persons[person_a_id]
        person_b = self.persons[person_b_id]
        
        # Check frequency overlap
        freq_diff = abs(person_a.rf_frequency - person_b.rf_frequency)
        
        # Within 50 MHz = in range
        return freq_diff < 0.05
    
    def establish_handshake(self, person_a_id: str, person_b_id: str) -> Dict:
        """
        Establish handshake between two persons
        Both must consent
        """
        if not self.persons_in_range(person_a_id, person_b_id):
            return {'success': False, 'reason': 'Out of RF range'}
        
        person_a = self.persons[person_a_id]
        person_b = self.persons[person_b_id]
        
        # Person A broadcasts presence
        presence_a = person_a.broadcast_presence()
        
        # Person B accepts handshake
        handshake = person_b.accept_handshake(presence_a)
        
        if handshake.get('success', True):
            # Reciprocal handshake from A to B
            presence_b = person_b.broadcast_presence()
            handshake_b = person_a.accept_handshake(presence_b)
            
            # Record interaction
            interaction_record = {
                'timestamp': time.time(),
                'handshake_id': handshake['handshake_id'],
                'participants': [person_a_id, person_b_id],
                'names': [person_a.name, person_b.name],
                'frequencies': [person_a.rf_frequency, person_b.rf_frequency],
                'duration': 0
            }
            self.interaction_log.append(interaction_record)
            
            return {
                'success': True,
                'handshake_id': handshake['handshake_id'],
                'participants': [person_a.name, person_b.name],
                'message': f"{person_a.name} ↔ {person_b.name} handshake established"
            }
        
        return handshake
    
    def share_between_persons(self, source_id: str, target_id: str, 
                              data_type: str, data: Dict) -> Dict:
        """
        Share information between two persons
        Information is stored on BOTH persons' local nodes
        """
        if source_id not in self.persons or target_id not in self.persons:
            return {'success': False, 'reason': 'Person not found'}
        
        source = self.persons[source_id]
        target = self.persons[target_id]
        
        # Check if handshake exists
        if target_id not in source.active_peers:
            # Auto-establish handshake
            handshake = self.establish_handshake(source_id, target_id)
            if not handshake.get('success'):
                return {'success': False, 'reason': 'Handshake failed'}
        
        # Source shares information
        share_record = source.share_information(target_id, data, data_type)
        
        if share_record.get('success', True):
            # Target receives and stores information
            target.receive_information(share_record)
            
            # Update interaction log
            for record in self.interaction_log:
                if record['handshake_id'] == share_record.get('handshake_id'):
                    record['duration'] += 1
            
            return {
                'success': True,
                'share_id': share_record['share_id'],
                'source': source.name,
                'target': target.name,
                'data_type': data_type,
                'timestamp': share_record['timestamp']
            }
        
        return share_record
    
    def get_person_history(self, person_id: str) -> Dict:
        """Get complete interaction history for a person"""
        if person_id not in self.persons:
            return {'error': 'Person not found'}
        
        person = self.persons[person_id]
        
        return {
            'person': person.name,
            'connection_summary': person.get_connection_summary(),
            'recent_interactions': person.get_interaction_history()[:10],
            'active_peers': list(person.active_peers.keys())
        }
    
    def simulate_group_interaction(self, participants: List[str], 
                                   topic: str, duration_seconds: int = 30) -> Dict:
        """
        Simulate a group interaction where multiple persons share information
        """
        print(f"\n{'='*60}")
        print(f"👥 GROUP INTERACTION: {topic}")
        print(f"   Participants: {', '.join(participants)}")
        print(f"   Duration: {duration_seconds} seconds")
        print(f"{'='*60}")
        
        results = []
        
        # Establish handshakes between all pairs
        for i, p1 in enumerate(participants):
            for p2 in participants[i+1:]:
                handshake = self.establish_handshake(p1, p2)
                results.append(handshake)
        
        # Share information in a circle
        shared_info = {
            'topic': topic,
            'group_id': hashlib.md5(f"{topic}_{time.time()}".encode()).hexdigest()[:8],
            'timestamp': time.time()
        }
        
        for i, source in enumerate(participants):
            target = participants[(i + 1) % len(participants)]
            
            # Person-specific contribution
            contribution = {
                'participant': self.persons[source].name,
                'thought': f"Sharing my perspective on {topic}",
                'personal_experience': f"Experience #{i+1}",
                'timestamp': time.time()
            }
            
            share_result = self.share_between_persons(
                source, target, 
                f"group_discussion_{topic.replace(' ', '_')}", 
                contribution
            )
            results.append(share_result)
        
        # Store group interaction summary
        group_summary = {
            'topic': topic,
            'participants': participants,
            'duration_seconds': duration_seconds,
            'timestamp': time.time(),
            'interactions_count': len(results)
        }
        
        print(f"\n✅ GROUP INTERACTION COMPLETE")
        print(f"   Handshakes: {len([r for r in results if r.get('success')])}")
        print(f"   Shares: {len([r for r in results if r.get('share_id')])}")
        
        return group_summary


