class PersonNodeNetwork:
    """
    Complete node network for a single person
    Each person has unique RF signature based on DNA
    """
    
    def __init__(self, person_id: str, dna_sequence: str, name: str = ""):
        self.person_id = person_id
        self.dna_sequence = dna_sequence
        self.name = name or person_id
        self.rf_frequency = self._calculate_rf_frequency(dna_sequence)
        
        # Local database (ALL interactions stored here)
        self.local_db = sqlite3.connect(f"person_{person_id}_interactions.db", check_same_thread=False)
        self._init_database()
        
        # Active peer connections
        self.active_peers: Dict[str, Dict] = {}
        self.interaction_history = []
        
        # RF transceiver (simulated)
        self.rf_range_ghz = (self.rf_frequency - 0.1, self.rf_frequency + 0.1)
        
        # Interaction consent settings
        self.auto_accept_peers = False  # Must explicitly accept
        self.allowed_peers: Set[str] = set()
        
        print(f"\n{'='*60}")
        print(f"👤 PERSON NODE NETWORK: {self.name}")
        print(f"   ID: {self.person_id}")
        print(f"   RF Frequency: {self.rf_frequency:.4f} GHz (±100 MHz)")
        print(f"   DNA Signature: {hashlib.md5(dna_sequence.encode()).hexdigest()[:16]}")
        print(f"{'='*60}")
    
    def _calculate_rf_frequency(self, dna: str) -> float:
        """Calculate unique RF frequency from DNA sequence"""
        base_freqs = {'A': 10.23, 'T': 10.24, 'G': 10.25, 'C': 10.26}
        freqs = [base_freqs.get(c, 10.23) for c in dna.upper()[:10]]
        return np.mean(freqs)
    
    def _init_database(self):
        """Initialize local interaction database"""
        cursor = self.local_db.cursor()
        
        # Interactions with other persons
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS interactions (
                interaction_id TEXT PRIMARY KEY,
                peer_id TEXT,
                peer_name TEXT,
                peer_frequency REAL,
                interaction_type TEXT,
                timestamp REAL,
                data_hash TEXT,
                handshake_signature TEXT,
                local_notes BLOB
            )
        ''')
        
        # Shared memories (from interactions)
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS shared_memories (
                memory_id TEXT PRIMARY KEY,
                source_peer_id TEXT,
                memory_type TEXT,
                memory_data BLOB,
                shared_at REAL,
                access_count INTEGER,
                last_accessed REAL
            )
        ''')
        
        # Handshake records
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS handshakes (
                handshake_id TEXT PRIMARY KEY,
                peer_id TEXT,
                handshake_time REAL,
                signal_strength REAL,
                duration_sec REAL,
                successful BOOLEAN
            )
        ''')
        
        self.local_db.commit()
    
    def calculate_proximity_fingerprint(self) -> str:
        """
        Calculate unique fingerprint for proximity detection
        Other persons' nodes can detect this person nearby
        """
        timestamp_hash = hashlib.md5(str(time.time()).encode()).hexdigest()[:8]
        return f"{self.person_id}_{self.rf_frequency:.4f}_{timestamp_hash}"
    
    def broadcast_presence(self) -> Dict:
        """
        Broadcast presence to nearby nodes
        Like a handshake invitation
        """
        presence = {
            'type': 'PRESENCE',
            'person_id': self.person_id,
            'name': self.name,
            'frequency': self.rf_frequency,
            'timestamp': time.time(),
            'signature': hashlib.md5(f"{self.person_id}_{time.time()}".encode()).hexdigest()[:16],
            'willing_to_interact': True
        }
        return presence
    
    def accept_handshake(self, peer_presence: Dict) -> Dict:
        """
        Accept handshake from another person's nodes
        Creates a secure interaction session
        """
        peer_id = peer_presence['person_id']
        
        # Check if peer is allowed
        if not self.auto_accept_peers and peer_id not in self.allowed_peers:
            return {'success': False, 'reason': 'Peer not in allowed list'}
        
        # Generate handshake
        handshake_id = hashlib.sha3_256(f"{self.person_id}_{peer_id}_{time.time()}".encode()).hexdigest()[:16]
        
        handshake = {
            'handshake_id': handshake_id,
            'my_id': self.person_id,
            'peer_id': peer_id,
            'peer_name': peer_presence.get('name', peer_id),
            'my_frequency': self.rf_frequency,
            'peer_frequency': peer_presence['frequency'],
            'timestamp': time.time(),
            'signature': hashlib.md5(f"{handshake_id}_{self.person_id}".encode()).hexdigest()
        }
        
        # Store handshake locally
        cursor = self.local_db.cursor()
        cursor.execute('''
            INSERT INTO handshakes (handshake_id, peer_id, handshake_time, signal_strength, duration_sec, successful)
            VALUES (?, ?, ?, ?, ?, ?)
        ''', (handshake_id, peer_id, handshake['timestamp'], 0.85, 0, True))
        self.local_db.commit()
        
        # Track active peer
        self.active_peers[peer_id] = {
            'handshake_id': handshake_id,
            'connected_at': handshake['timestamp'],
            'peer_frequency': peer_presence['frequency'],
            'peer_name': peer_presence.get('name', peer_id)
        }
        
        print(f"\n🤝 HANDSHAKE ACCEPTED: {self.name} ↔ {peer_presence.get('name', peer_id)}")
        print(f"   Handshake ID: {handshake_id[:16]}...")
        
        return handshake
    
    def share_information(self, peer_id: str, data: Dict, data_type: str) -> Dict:
        """
        Share information with another person's nodes
        Information is transmitted via RF and stored locally by BOTH parties
        """
        if peer_id not in self.active_peers:
            return {'success': False, 'reason': 'No active connection'}
        
        peer = self.active_peers[peer_id]
        
        # Create share record
        share_id = hashlib.sha3_256(f"{self.person_id}_{peer_id}_{time.time()}".encode()).hexdigest()[:16]
        
        # Serialize and compress data
        data_bytes = json.dumps(data).encode()
        compressed = zlib.compress(data_bytes, level=6)
        
        share_record = {
            'share_id': share_id,
            'source_id': self.person_id,
            'target_id': peer_id,
            'data_type': data_type,
            'data': data,
            'data_hash': hashlib.sha3_256(compressed).hexdigest(),
            'timestamp': time.time(),
            'handshake_id': peer['handshake_id']
        }
        
        # Store on local database (MY copy)
        cursor = self.local_db.cursor()
        cursor.execute('''
            INSERT INTO interactions (interaction_id, peer_id, peer_name, peer_frequency, 
                                      interaction_type, timestamp, data_hash, handshake_signature, local_notes)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
        ''', (share_id, peer_id, peer['peer_name'], peer['peer_frequency'],
              f"shared_{data_type}", share_record['timestamp'], share_record['data_hash'],
              share_record['handshake_id'], compressed))
        self.local_db.commit()
        
        self.interaction_history.append(share_record)
        
        print(f"\n📤 SHARED: {self.name} → {peer['peer_name']}")
        print(f"   Type: {data_type}")
        print(f"   Data Hash: {share_record['data_hash'][:16]}...")
        
        return share_record
    
    def receive_information(self, share_record: Dict) -> bool:
        """
        Receive information from another person's nodes
        Stores local copy - BOTH parties have their own record
        """
        # Verify data integrity
        data_bytes = json.dumps(share_record['data']).encode()
        compressed = zlib.compress(data_bytes, level=6)
        computed_hash = hashlib.sha3_256(compressed).hexdigest()
        
        if computed_hash != share_record['data_hash']:
            print(f"❌ DATA CORRUPTED: Hash mismatch")
            return False
        
        # Store in local database
        cursor = self.local_db.cursor()
        cursor.execute('''
            INSERT INTO interactions (interaction_id, peer_id, peer_name, peer_frequency,
                                      interaction_type, timestamp, data_hash, handshake_signature, local_notes)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
        ''', (share_record['share_id'], share_record['source_id'], 
              f"peer_{share_record['source_id'][:8]}", 
              self.active_peers.get(share_record['source_id'], {}).get('peer_frequency', 0.0),
              f"received_{share_record['data_type']}", share_record['timestamp'],
              share_record['data_hash'], share_record['handshake_id'], compressed))
        self.local_db.commit()
        
        print(f"\n📥 RECEIVED: {self.name} ← {share_record['source_id'][:16]}...")
        print(f"   Type: {share_record['data_type']}")
        
        return True
    
    def get_interaction_history(self, peer_id: Optional[str] = None) -> List[Dict]:
        """Get history of interactions"""
        cursor = self.local_db.cursor()
        
        if peer_id:
            cursor.execute('''
                SELECT interaction_id, peer_id, interaction_type, timestamp, data_hash
                FROM interactions WHERE peer_id = ?
                ORDER BY timestamp DESC LIMIT 50
            ''', (peer_id,))
        else:
            cursor.execute('''
                SELECT interaction_id, peer_id, interaction_type, timestamp, data_hash
                FROM interactions ORDER BY timestamp DESC LIMIT 100
            ''')
        
        results = []
        for row in cursor.fetchall():
            results.append({
                'interaction_id': row[0],
                'peer_id': row[1],
                'type': row[2],
                'timestamp': row[3],
                'data_hash': row[4][:16]
            })
        
        return results
    
    def get_connection_summary(self) -> Dict:
        """Summary of all connections and interactions"""
        cursor = self.local_db.cursor()
        
        # Count unique peers
        cursor.execute('SELECT DISTINCT peer_id FROM interactions')
        unique_peers = len(cursor.fetchall())
        
        # Count total interactions
        cursor.execute('SELECT COUNT(*) FROM interactions')
        total_interactions = cursor.fetchone()[0]
        
        # Count handshakes
        cursor.execute('SELECT COUNT(*) FROM handshakes WHERE successful = 1')
        handshake_count = cursor.fetchone()[0]
        
        return {
            'person': self.name,
            'person_id': self.person_id,
            'rf_frequency': self.rf_frequency,
            'unique_peers_interacted': unique_peers,
            'total_interactions': total_interactions,
            'handshakes_completed': handshake_count,
            'active_connections': len(self.active_peers),
            'current_peers': list(self.active_peers.keys())
        }


