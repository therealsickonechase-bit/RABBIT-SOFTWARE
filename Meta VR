<!DOCTYPE html>
<html>
<head>
    <title>VR Neural Simulator</title>
    <style>
        body { font-family: monospace; margin: 20px; background: black; color: lime; }
        #output { white-space: pre-wrap; background: #111; padding: 10px; border: 1px solid lime; }
        button { padding: 10px 20px; margin: 10px 0; }
    </style>
</head>
<body>
    <h1>🧠 VR Neural Backend (WebXR)</h1>
    <button id="start">Start VR Session</button>
    <button id="stop" disabled>Stop</button>
    <div id="status">Status: Waiting</div>
    <div id="output">Output will appear here</div>

    <script>
        let xrSession = null;
        let intervalId = null;

        async function startSession() {
            if (!navigator.xr) {
                document.getElementById('output').innerText = "WebXR not supported";
                return;
            }
            try {
                xrSession = await navigator.xr.requestSession('immersive-vr', {
                    optionalFeatures: ['local-floor', 'bounded-floor', 'hand-tracking']
                });
                document.getElementById('status').innerText = "VR Session active";
                document.getElementById('start').disabled = true;
                document.getElementById('stop').disabled = false;

                // Continuously read pose and send to backend
                const pollInterval = 2000; // ms
                intervalId = setInterval(sendPoseToBackend, pollInterval);

                xrSession.addEventListener('end', () => {
                    clearInterval(intervalId);
                    document.getElementById('status').innerText = "Session ended";
                    document.getElementById('start').disabled = false;
                    document.getElementById('stop').disabled = true;
                });
            } catch(e) {
                document.getElementById('output').innerText = "Error: " + e.message;
            }
        }

        async function sendPoseToBackend() {
            if (!xrSession) return;
            const frame = new XRFrame(xrSession, performance.now());
            const viewer = frame.getViewerPose?.(xrSession.renderState.baseLayer?.referenceSpace);
            if (!viewer) return;

            const pose = viewer.transform.position;
            const orientation = viewer.transform.orientation; // quaternion
            // Simulate eye gaze from head orientation (basic)
            const eyeX = orientation?.x || 0;
            const eyeY = orientation?.y || 0;

            const payload = {
                eye_gaze_x: eyeX,
                eye_gaze_y: eyeY,
                head_roll: orientation?.z || 0,
                head_pitch: orientation?.y || 0,
                head_yaw: orientation?.x || 0,
                voice_keyword: null,
                hand_gesture: null
            };

            try {
                const resp = await fetch('http://localhost:8000/process', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await resp.json();
                document.getElementById('output').innerHTML = `
                    <strong>Fingerprint:</strong> ${data.fingerprint}<br>
                    <strong>Token:</strong> ${data.token}<br>
                    <strong>Hormones:</strong> ${JSON.stringify(data.hormones)}<br>
                    <strong>LLM:</strong> ${data.llm}
                `;
            } catch(e) {
                console.error(e);
            }
        }

        function stopSession() {
            if (xrSession) xrSession.end();
        }

        document.getElementById('start').addEventListener('click', startSession);
        document.getElementById('stop').addEventListener('click', stopSession);
    </script>
</body>
</html>
