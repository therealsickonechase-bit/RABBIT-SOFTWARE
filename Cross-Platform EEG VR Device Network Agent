class RabbitAgent:
    """Sovereign device network agent."""

    def __init__(self):
        self.ble_scanner = BLEDeviceScanner()
        self.wifi_scanner = WiFiScanner()
        self.registry = None
        self.llm = None

    def init_blockchain(self, private_key: str, contract_address: str = ""):
        self.registry = DeviceRegistry(private_key, contract_address)

    def init_ai(self, model: str = "llama3.2:1b"):
        self.llm = LocalLLMClient(model)

    async def scan_and_register(self, duration: float = 5.0) -> List[DeviceFingerprint]:
        """Full scan → fingerprint → blockchain registration."""
        if not self.registry:
            raise RuntimeError("Blockchain registry not initialised. Call init_blockchain first.")
        # 1. Scan BLE
        await self.ble_scanner.scan(duration)
        devices = self.ble_scanner.get_devices()
        # 2. Optionally scan WiFi
        wifi_devs = self.wifi_scanner.scan()
        # 3. Register each BLE device on‑chain
        for dev in devices:
            device_id = self.registry.register_device(dev)
            # This is where the handshake occurs – a smart‑contract‑verified identity
            print(f"[Handshake] Device {device_id[:8]} verified and logged on Polygon.")
        return devices

    def generate_context_prompt(self, devices: List[DeviceFingerprint]) -> str:
        """Build a prompt for the local LLM based on discovered devices."""
        if not devices:
            return "No devices discovered."
        prompt = "You are a sovereign AI twin. Nearby EEG/VR devices:\n"
        for d in devices:
            prompt += f"- {d.device_name or d.mac_address} (RSSI={d.rssi}, fingerprint={d.compute_hash()[:8]})\n"
        prompt += "What emotional or environmental context do you infer?"
        return prompt


