@dataclass
class DeviceFingerprint:
    """Unique hardware fingerprint composed from multiple signals."""
    mac_address: str
    device_name: Optional[str]
    rssi: int
    manufacturer_data: Optional[bytes]
    clock_skew_ppm: float          # estimated from advertisement intervals
    ble_address_type: str
    first_seen: datetime
    last_seen: datetime

    def compute_hash(self) -> str:
        """SHA‑256 of all fingerprint fields – the on‑chain identity anchor."""
        data = f"{self.mac_address}{self.device_name}{self.rssi}{self.manufacturer_data}{self.clock_skew_ppm}{self.ble_address_type}"
        return hashlib.sha256(data.encode()).hexdigest()


class BLEDeviceScanner:
    """Cross‑platform BLE scanner using `bleak` (Windows, macOS, Linux, Android)."""

    def __init__(self):
        self.devices: Dict[str, DeviceFingerprint] = {}

    async def _detection_callback(self, device: bleak.BLEDevice, advertisement_data: bleak.AdvertisementData):
        """Called each time a BLE advertisement is received."""
        # Use the device address as primary ID
        addr = device.address
        now = datetime.utcnow()

        # Basic RSSI filtering
        rssi = getattr(advertisement_data, 'rssi', -100)

        # Estimate clock skew from advertisement intervals (simplified)
        if addr in self.devices:
            previous = self.devices[addr]
            delta = (now - previous.last_seen).total_seconds()
            # Very crude skew: ppm = (expected_interval - actual_interval) / actual_interval * 1e6
            expected = 0.1  # 100ms typical BLE advertisement interval
            clock_skew = ((expected - delta) / delta) * 1e6 if delta > 0 else 0.0
        else:
            clock_skew = 0.0

        finger = DeviceFingerprint(
            mac_address=addr,
            device_name=device.name,
            rssi=rssi,
            manufacturer_data=advertisement_data.manufacturer_data,
            clock_skew_ppm=clock_skew,
            ble_address_type=device.details.get('addressType', 'public') if device.details else 'public',
            first_seen=now if addr not in self.devices else self.devices[addr].first_seen,
            last_seen=now
        )
        self.devices[addr] = finger
        print(f"[BLE] {device.name or 'unknown'} ({addr}) RSSI={rssi}")

    async def scan(self, duration: float = 5.0):
        """Perform a BLE scan for the given duration."""
        if not BLEAK_AVAILABLE:
            raise RuntimeError("Bleak library not installed. Run: pip install bleak")
        scanner = BleakScanner(self._detection_callback)
        await scanner.start()
        await asyncio.sleep(duration)
        await scanner.stop()

    def get_devices(self) -> List[DeviceFingerprint]:
        return list(self.devices.values())


class WiFiScanner:
    """Passive WiFi scanning – works on Linux/macOS; on Windows it's a no‑op."""

    @staticmethod
    def scan():
        devices = []
        if SCAPY_AVAILABLE and platform.system() != "Windows":
            # ARP scan on local network
            conf.verb = 0
            ans, _ = srp(Ether(dst="ff:ff:ff:ff:ff:ff")/ARP(pdst="192.168.1.0/24"), timeout=2, verbose=False)
            for _, rcv in ans:
                devices.append({
                    "mac": rcv.hwsrc,
                    "ip": rcv.psrc
                })
        else:
            print("[WiFi] Passive scanning not supported on this platform, using fallback.")
        return devices


