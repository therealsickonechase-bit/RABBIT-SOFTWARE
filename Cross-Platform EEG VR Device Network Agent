class RabbitGUI(BoxLayout):
    def __init__(self, agent: RabbitAgent, **kwargs):
        super().__init__(**kwargs)
        self.agent = agent
        self.orientation = 'vertical'
        self.device_list = ScrollView()
        self.device_log = Label(size_hint_y=None, text="Click 'Scan' to discover devices.")
        self.device_list.add_widget(self.device_log)
        self.add_widget(self.device_list)

        btn_box = BoxLayout(size_hint_y=0.2)
        scan_btn = Button(text="Scan BLE devices")
        scan_btn.bind(on_press=self.on_scan)
        btn_box.add_widget(scan_btn)

        if self.agent.llm:
            ai_btn = Button(text="Generate AI context")
            ai_btn.bind(on_press=self.on_ai_context)
            btn_box.add_widget(ai_btn)

        self.add_widget(btn_box)

    def on_scan(self, instance):
        async def do_scan():
            devs = await self.agent.scan_and_register(duration=4.0)
            self.device_log.text = f"Found {len(devs)} devices:\n"
            for d in devs:
                self.device_log.text += f"{d.device_name or 'unknown'} ({d.mac_address}) RSSI={d.rssi}\n"
        asyncio.run(do_scan())

    def on_ai_context(self, instance):
        # This would run the active BLE devices through the local LLM
        prompt = self.agent.generate_context_prompt(self.agent.ble_scanner.get_devices())
        resp = self.agent.llm.generate(prompt)
        self.device_log.text += f"\nAI: {resp[:300]}"


