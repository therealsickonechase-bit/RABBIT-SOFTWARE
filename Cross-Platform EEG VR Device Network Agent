class LocalLLMClient:
    """Abstract local LLM client – supports Ollama or Foundry Local."""

    def __init__(self, model: str = "llama3.2:1b", api_url: str = "http://localhost:11434/api/generate"):
        self.model = model
        self.api_url = api_url
        self.fallback_mode = (requests is None)

    def generate(self, prompt: str) -> str:
        """Send prompt to local LLM and return text response."""
        if self.fallback_mode or not requests:
            return f"[fallback] LLM not available. Prompt: {prompt[:100]}..."
        try:
            payload = {
                "model": self.model,
                "prompt": prompt,
                "stream": False
            }
            resp = requests.post(self.api_url, json=payload, timeout=30)
            if resp.status_code == 200:
                return resp.json().get('response', '')
            else:
                return f"LLM error ({resp.status_code})"
        except Exception as e:
            return f"LLM exception: {e}"


