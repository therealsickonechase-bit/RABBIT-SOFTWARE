        print(f"      Beam Angle: {tx['beam_angle_deg']:.1f}°")
        print(f"      Collision: {'NO' if tx['zero_collision'] else 'YES'}")
    
    # Show statistics
    print("\n" + "━" * 80)
    print("📊 NETWORK STATISTICS")
    print("━" * 80)
    
    stats = network.get_network_statistics()
    for key, value in stats.items():
        if isinstance(value, float):
            print(f"   {key}: {value:.2%}" if "utilization" in key else f"   {key}: {value:.2f}")
        else:
            print(f"   {key}: {value}")
    
    # Verify no interference
    print("\n" + "━" * 80)
    print("🔬 INTERFERENCE VERIFICATION")
    print("━" * 80)
    
    # Check frequency reuse
    freq_assignments = [n["frequency_assignment"]["primary_frequency_ghz"] 
