class FrequencyAssignmentMatrix:
    """
    Assigns unique frequencies to each SDR node based on:
    - DNA sequence (primary resonance)
    - Harmonic offsets (secondary channels)
    - Geographic location (spatial reuse)
    """
   
    # DNA resonance frequencies (GHz)
    DNA_BASE_FREQS = {
        'A': 10.41,
        'T': 9.95,
        'G': 10.16,
        'C': 10.31
    }
   
    # Guard bands to prevent adjacent interference (MHz)
    GUARD_BAND_MHZ = 5.0
   
    # Harmonic offsets for secondary channels
    HARMONICS = [1.0, 1.5, 2.0, 2.5, 3.0, 3.5, 4.0]
   
    def __init__(self):
        self.assigned_frequencies = {}
        self.frequency_usage = defaultdict(int)
        self.spatial_grid = {}
       
    def assign_node_frequency(self, node_id: str, dna_sequence: str,
                              location: Tuple[float, float]) -> Dict:
        """
        Assign interference-free frequency to node
        Returns: frequency_ghz, channel_number, backup_frequencies
        """
        # Calculate primary frequency from DNA
        dna_freq = self._calculate_dna_resonance(dna_sequence)
       
        # Find free frequency slot near DNA resonance
        assigned_freq, channel_num = self._find_free_frequency(dna_freq, location)
       
        # Assign backup frequencies for failover
        backup_freqs = self._assign_backup_frequencies(dna_freq, len(self.HARMONICS))
       
        self.assigned_frequencies[node_id] = {
            "primary": assigned_freq,
            "channel": channel_num,
            "backups": backup_freqs,
            "location": location,
            "dna_fingerprint": hashlib.sha256(dna_sequence.encode()).hexdigest()[:16]
        }
       
        self.frequency_usage[assigned_freq] += 1
        self.spatial_grid[f"{location[0]:.2f}_{location[1]:.2f}"] = assigned_freq
       
        return {
            "node_id": node_id,
            "primary_frequency_ghz": assigned_freq,
            "guard_band_mhz": self.GUARD_BAND_MHZ,
            "backup_frequencies_ghz": backup_freqs[:3],
            "channel_allocation": f"CH-{channel_num:04d}"
        }
   
    def _calculate_dna_resonance(self, dna: str) -> float:
        """Calculate resonance frequency from DNA sequence"""
        freqs = [self.DNA_BASE_FREQS.get(c, 10.0) for c in dna.upper()]
        return np.mean(freqs)
   
    def _find_free_frequency(self, target_ghz: float,
                             location: Tuple[float, float]) -> Tuple[float, int]:
        """Find non-interfering frequency near target"""
       
        # Check spatial reuse - nodes >500m apart can reuse frequencies
        reuse_distance_km = 0.5
        spatial_conflict = False
       
        for pos, freq in self.spatial_grid.items():
            lat, lon = map(float, pos.split('_'))
            distance = self._haversine_distance(lat, lon, location[0], location[1])
            if distance < reuse_distance_km and abs(freq - target_ghz) < 0.01:
                spatial_conflict = True
                break
       
        if not spatial_conflict:
            # Can use exact DNA resonance
            channel_num = int((target_ghz - 9.0) * 100)
            return target_ghz, channel_num
       
        # Find nearest free frequency
        offset = 0.001  # Start with 1 MHz offset
        max_offset = 0.050  # Max 50 MHz deviation
       
        while offset <= max_offset:
            candidate_freqs = [
                target_ghz + offset,
                target_ghz - offset,
                target_ghz + offset * 1.5,
                target_ghz - offset * 1.5
            ]
           
            for freq in candidate_freqs:
                if self.frequency_usage[freq] == 0:
                    channel_num = int((freq - 9.0) * 100)
                    return freq, channel_num
           
            offset += 0.001
       
        # Fallback: assign unique frequency from pool
        pool = [10.01, 10.02, 10.03, 10.04, 10.05, 10.06, 10.07, 10.08, 10.09, 10.10]
        for freq in pool:
            if self.frequency_usage[freq] == 0:
                channel_num = int((freq - 9.0) * 100)
                return freq, channel_num
       
        return target_ghz, int((target_ghz - 9.0) * 100)
   
    def _assign_backup_frequencies(self, base_freq: float, count: int) -> List[float]:
        """Assign backup frequencies for failover"""
        backups = []
        for i, harmonic in enumerate(self.HARMONICS[:count]):
            backup_freq = base_freq * harmonic
            # Keep within 9-11 GHz band
            if 9.0 < backup_freq < 11.0:
                backups.append(round(backup_freq, 4))
        return backups
   
    def _haversine_distance(self, lat1: float, lon1: float,
                            lat2: float, lon2: float) -> float:
        """Calculate distance between two points in km"""
        from math import radians, sin, cos, sqrt, atan2
        R = 6371  # Earth radius in km
        dlat = radians(lat2 - lat1)
        dlon = radians(lon2 - lon1)
        a = sin(dlat/2)**2 + cos(radians(lat1)) * cos(radians(lat2)) * sin(dlon/2)**2
        c = 2 * atan2(sqrt(a), sqrt(1-a))
        return R * c


