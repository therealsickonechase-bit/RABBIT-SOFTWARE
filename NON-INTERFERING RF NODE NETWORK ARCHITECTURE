class TimeDivisionScheduler:
    """
    TDMA-based transmission scheduling
    Each node gets dedicated time slots - ZERO COLLISIONS
    """
   
    def __init__(self, frame_duration_ms: int = 100, num_slots: int = 1000):
        self.frame_duration_ms = frame_duration_ms
        self.num_slots = num_slots
        self.slot_duration_us = (frame_duration_ms * 1000) / num_slots
        self.assignments = {}
        self.slot_owners = {}
       
    def assign_time_slot(self, node_id: str, required_bandwidth_kbps: float) -> Dict:
        """Assign dedicated time slot to node"""
       
        # Calculate slots needed based on bandwidth
        slots_needed = max(1, int(required_bandwidth_kbps / 10))
       
        # Find free consecutive slots
        assigned_slots = self._find_free_slots(slots_needed)
       
        if not assigned_slots:
            return {"error": "No free time slots available"}
       
        schedule = {
            "node_id": node_id,
            "assigned_slots": assigned_slots,
            "slot_duration_us": self.slot_duration_us,
            "frame_duration_ms": self.frame_duration_ms,
            "transmission_window": {
                "start_us": assigned_slots[0] * self.slot_duration_us,
                "end_us": (assigned_slots[-1] + 1) * self.slot_duration_us
            },
            "duty_cycle_percent": (len(assigned_slots) / self.num_slots) * 100
        }
       
        self.assignments[node_id] = schedule
        for slot in assigned_slots:
            self.slot_owners[slot] = node_id
       
        return schedule
   
    def _find_free_slots(self, count: int) -> List[int]:
        """Find consecutive free time slots"""
        free_run = 0
        start_slot = 0
       
        for slot in range(self.num_slots):
            if slot not in self.slot_owners:
                if free_run == 0:
                    start_slot = slot
                free_run += 1
                if free_run >= count:
                    return list(range(start_slot, start_slot + count))
            else:
                free_run = 0
       
        return []
   
    def get_transmission_time(self, node_id: str) -> Optional[Tuple[float, float]]:
        """Get node's transmission window in seconds"""
        if node_id not in self.assignments:
            return None
       
        schedule = self.assignments[node_id]
        return (schedule["transmission_window"]["start_us"] / 1_000_000,
                schedule["transmission_window"]["end_us"] / 1_000_000)


