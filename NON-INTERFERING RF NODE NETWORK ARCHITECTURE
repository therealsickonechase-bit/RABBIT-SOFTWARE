class CognitiveRadioController:
    """
    Cognitive radio that dynamically hops frequencies to avoid interference
    Uses spectrum sensing to find clean channels
    """
    
    def __init__(self):
        self.spectrum_map = {}
        self.hop_sequence = {}
        self.noise_floor = -100  # dBm
        
    def sense_spectrum(self, start_ghz: float, end_ghz: float, step_mhz: float) -> Dict:
        """Spectrum sensing to detect interference"""
        measurements = {}
        
        for freq in np.arange(start_ghz, end_ghz, step_mhz / 1000):
            # Simulate noise and interference detection
            interference = random.uniform(-110, -80)
            
            measurements[freq] = {
                "signal_strength_dBm": interference,
                "is_clean": interference < self.noise_floor,
                "interference_source": "none" if interference < self.noise_floor else "unknown"
            }
        
        self.spectrum_map = measurements
        return measurements
    
    def generate_hop_sequence(self, node_id: str, num_hops: int = 100) -> Dict:
        """Generate frequency hopping sequence"""
        clean_freqs = [f for f, m in self.spectrum_map.items() if m["is_clean"]]
        
        if len(clean_freqs) < num_hops:
            # Use available frequencies with repetition
            clean_freqs = clean_freqs * (num_hops // len(clean_freqs) + 1)
        
        hop_sequence = clean_freqs[:num_hops]
        
        self.hop_sequence[node_id] = {
            "sequence": hop_sequence,
            "hop_rate_hz": 100,  # 100 hops per second
            "dwell_time_ms": 10,
            "current_hop": 0
        }
        
        return {
            "node_id": node_id,
            "hop_sequence_preview": hop_sequence[:10],
            "hop_rate_hz": 100,
            "num_frequencies": len(set(hop_sequence))
        }
    
    def get_current_frequency(self, node_id: str) -> Optional[float]:
        """Get current frequency in hop sequence"""
        if node_id not in self.hop_sequence:
            return None
        
        hop_data = self.hop_sequence[node_id]
        current_idx = hop_data["current_hop"] % len(hop_data["sequence"])
        hop_data["current_hop"] += 1
        
        return hop_data["sequence"][current_idx]


