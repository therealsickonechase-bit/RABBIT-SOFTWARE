@dataclass
class NeuroConnection:
    """Represents a single neural connection from node to brain region"""
    connection_id: str
    target_region: BrainRegion
    connection_type: str  # excitatory, inhibitory, modulatory
    strength: float       # 0-1 synaptic weight
    frequency_mhz: float  # RF frequency for this connection
    latency_ms: float     # Transmission latency
    plasticity: float     # Learning capability (0-1)
   
class NeuroNode:
    """
    SDR-based neuro node with synthetic neural connections
    Each node can connect to multiple brain regions with biological density
    """
   
    # Biological reference: Human brain has ~86 billion neurons
    # Each neuro node simulates a cluster of biological neurons
    NEURONS_PER_NODE_BASE = 1_000_000  # 1M synthetic neurons per node
   
    # Connection branching factor (each neuron connects to ~7,000 others)
    CONNECTIONS_PER_NEURON = 7_000
   
    def __init__(self, node_id: str, dna_sequence: str, location: Tuple[float, float, float]):
        self.node_id = node_id
        self.dna_sequence = dna_sequence
        self.location = location  # x,y,z in mm (brain coordinates)
       
        # Core properties
        self.total_neurons = self.NEURONS_PER_NODE_BASE
        self.total_connections = self.total_neurons * self.CONNECTIONS_PER_NEURON
       
        # Brain region connections
        self.region_connections: Dict[BrainRegion, List[NeuroConnection]] = {}
        self.connection_matrix = np.zeros((len(BrainRegion), len(BrainRegion)))
       
        # RF tuning per region
        self.region_frequencies = self._calculate_region_frequencies()
       
        # Initialize connections to all brain regions
        self._initialize_connections()
       
        print(f"🧠 Neuro Node {node_id} Initialized:")
        print(f"   Total Synthetic Neurons: {self.total_neurons:,}")
        print(f"   Total Connections: {self.total_connections:,}")
        print(f"   DNA Frequency: {self._calculate_dna_frequency():.4f} GHz")
   
    def _calculate_dna_frequency(self) -> float:
        """Calculate base frequency from DNA sequence"""
        base_freqs = {'A': 10.41, 'T': 9.95, 'G': 10.16, 'C': 10.31}
        freqs = [base_freqs.get(c, 10.0) for c in self.dna_sequence.upper()]
        return np.mean(freqs)
   
    def _calculate_region_frequencies(self) -> Dict[BrainRegion, float]:
        """Calculate RF frequency for each brain region based on depth and function"""
        base_freq = self._calculate_dna_frequency()
        frequencies = {}
       
        for region in BrainRegion:
            # Frequency varies by region depth and function
            depth_factor = self.location[2] / 100  # Depth in brain (0-100mm)
           
            if "cortex" in region.value:
                # Surface structures: higher frequencies
                freq_offset = 0.05 * hash(region.value) % 0.3
            elif region in [BrainRegion.THALAMUS, BrainRegion.BASAL_GANGLIA]:
                # Deep structures: lower frequencies
                freq_offset = -0.1 * hash(region.value) % 0.2
            else:
                freq_offset = 0.02 * hash(region.value) % 0.1
           
            frequencies[region] = base_freq + freq_offset - depth_factor * 0.1
       
        return frequencies
   
    def _initialize_connections(self):
        """Initialize connections from node to all brain regions"""
       
        for region in BrainRegion:
            # Number of connections proportional to biological density
            density = NEURAL_DENSITY.get(region, 50_000)
            connections_count = int(self.total_connections * (density / 1_000_000))
           
            connections = []
            for i in range(min(connections_count, 100_000)):  # Limit for performance
                connection = NeuroConnection(
                    connection_id=f"{self.node_id}_{region.value}_{i}",
                    target_region=region,
                    connection_type=np.random.choice(['excitatory', 'inhibitory', 'modulatory'],
                                                     p=[0.8, 0.15, 0.05]),
                    strength=np.random.beta(2, 5),  # Most connections weak
                    frequency_mhz=self.region_frequencies[region],
                    latency_ms=np.random.exponential(5),  # 5ms average latency
                    plasticity=np.random.uniform(0.1, 0.9)
                )
                connections.append(connection)
           
            self.region_connections[region] = connections
           
            # Update connection matrix
            for other in BrainRegion:
                self.connection_matrix[list(BrainRegion).index(region)][list(BrainRegion).index(other)] = \
                    len(connections) / self.total_connections
   
    def get_connections_summary(self) -> Dict:
        """Get detailed connection summary by brain region"""
        summary = {}
       
        for region, connections in self.region_connections.items():
            excitatory = sum(1 for c in connections if c.connection_type == 'excitatory')
            inhibitory = sum(1 for c in connections if c.connection_type == 'inhibitory')
            modulatory = sum(1 for c in connections if c.connection_type == 'modulatory')
           
            summary[region.value] = {
                "total_connections": len(connections),
                "excitatory": excitatory,
                "inhibitory": inhibitory,
                "modulatory": modulatory,
                "avg_strength": np.mean([c.strength for c in connections]),
                "avg_latency_ms": np.mean([c.latency_ms for c in connections]),
                "frequency_mhz": self.region_frequencies[region]
            }
       
        return summary
   
    def get_total_connections(self) -> int:
        """Get total number of connections across all regions"""
        return sum(len(conns) for conns in self.region_connections.values())


