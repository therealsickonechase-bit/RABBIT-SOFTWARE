    print("  Condition check:")
    print("    Same frequency? NO (10.23 ≠ 10.24)")
    print("    Overlapping time? NO (0-50µs ≠ 50-100µs)")
    print("    Orthogonal codes? YES (<C1,C2> = 0)")
    print("    Same beam direction? NO (0° ≠ 90°)")
    print("  ")
    print("  → INTERFERENCE: 0 ✓")
    
    return True


