class PhasedArrayBeamformer:
    """
    Spatial filtering using phased array antennas
    Each node transmits in focused beam - NO SPREADING
    """
    
    def __init__(self, num_elements: int = 16):
        self.num_elements = num_elements
        self.element_spacing_m = 0.015  # 1.5 cm at 10 GHz
        self.beam_angles = {}
        
    def calculate_beam_vector(self, angle_deg: float, frequency_ghz: float) -> List[complex]:
        """Calculate steering vector for given angle"""
        wavelength_m = 0.3 / frequency_ghz  # λ = c/f
        phase_increment = 2 * np.pi * self.element_spacing_m * np.sin(np.radians(angle_deg)) / wavelength_m
        
        steering_vector = []
        for i in range(self.num_elements):
            phase = i * phase_increment
            steering_vector.append(complex(np.cos(phase), np.sin(phase)))
        
        return steering_vector
    
    def steer_beam(self, node_id: str, target_angle_deg: float, frequency_ghz: float) -> Dict:
        """Steer beam toward target"""
        beam_vector = self.calculate_beam_vector(target_angle_deg, frequency_ghz)
        
        self.beam_angles[node_id] = {
            "angle_deg": target_angle_deg,
            "frequency_ghz": frequency_ghz,
            "beam_width_deg": 50 / (self.num_elements * frequency_ghz),  # Approximate
            "gain_db": 10 * np.log10(self.num_elements),
            "sidelobe_attenuation_db": -13.5
        }
        
        return self.beam_angles[node_id]
    
    def spatial_filter(self, node_id: str, 
                       incoming_angles: List[float]) -> List[float]:
        """Filter out signals from unwanted directions"""
        if node_id not in self.beam_angles:
            return [0.0]
        
        target_angle = self.beam_angles[node_id]["angle_deg"]
        beam_width = self.beam_angles[node_id]["beam_width_deg"]
        
        # Only accept signals within beam width
        filtered = [a for a in incoming_angles 
                   if abs(a - target_angle) < beam_width]
        
        return filtered


