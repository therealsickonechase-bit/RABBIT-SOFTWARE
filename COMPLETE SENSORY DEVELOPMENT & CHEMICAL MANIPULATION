# =============================================================================
# SECTION 1: SENSORY STATE CLASSIFICATION
# =============================================================================

class SensoryState(Enum):
    UNDERLOAD = "underload"
    OPTIMAL = "optimal"
    OVERLOAD = "overload"
    CRITICAL_OVERLOAD = "critical_overload"


class StimulusType(Enum):
    SOUND = "sound"
    WIND = "wind"
    TOUCH = "touch"
    TASTE = "taste"
    SMELL = "smell"
    VISUAL = "visual"
    TEMPERATURE = "temperature"
    SOCIAL = "social"


@dataclass
class SensoryEvent:
    """Complete sensory event with chemical/hormonal tracking"""
    event_id: str
    age: float
    date: str
    sensory_state: SensoryState
    stimulus_type: StimulusType
    intensity: float  # 0-1
    duration_minutes: float
   
    # Environmental context
    location: str
    environment_description: str
   
    # Chemical/hormonal changes (before, during, after)
    dopamine_before: float
    dopamine_during: float
    dopamine_after: float
    serotonin_before: float
    serotonin_during: float
    serotonin_after: float
    cortisol_before: float
    cortisol_during: float
    cortisol_after: float
    oxytocin_before: float
    oxytocin_during: float
    oxytocin_after: float
    norepinephrine_before: float
    norepinephrine_during: float
    norepinephrine_after: float
   
    # EEG/VR-EEG data
    eeg_recorded: bool
    eeg_bands: Dict[str, float]
    vr_exposure: bool
   
    # Medical intervention
    medical_intervention: bool
    intervention_type: str
    intervention_effectiveness: float
   
    # Prediction markers
    predicted_outcome: str
    chemical_prediction_accuracy: float


