# ----------------------------------------------------------------------
# 3. Vector store (using Sentence Transformers)
# ----------------------------------------------------------------------

class VectorCorpus:
    def __init__(self):
        self.model = SentenceTransformer('all-MiniLM-L6-v2')
        self.vectors = []
        self.metadata = []
    
    def add(self, text: str, meta: dict):
        vec = self.model.encode(text).astype(np.float32)
        self.vectors.append(vec)
        self.metadata.append(meta)
    
    def search(self, query: str, top_k=1) -> List[Tuple[dict, float]]:
        qvec = self.model.encode(query).astype(np.float32)
        sims = np.dot(self.vectors, qvec) / (np.linalg.norm(self.vectors, axis=1) * np.linalg.norm(qvec) + 1e-8)
        top_idx = np.argsort(sims)[-top_k:][::-1]
        return [(self.metadata[i], float(sims[i])) for i in top_idx]

# Build corpus from frozen data
