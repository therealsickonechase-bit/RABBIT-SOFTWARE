    def _create_hyperledger_tx(self, eeg_hash: str, patient_id: str) -> Dict:
        """Hyperledger private channel for clinical trials"""
        return {
            "transaction_hash": hashlib.sha256(f"{eeg_hash}_hlf".encode()).hexdigest(),
            "channel": "clinical-trials",
            "chaincode": "medical-records",
            "purpose": "Private clinical trial data",
