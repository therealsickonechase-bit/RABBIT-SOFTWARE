class RFTunedNode:
    """
    Node tuned via RF frequency to specific DNA resonance
    Nodes are physical SDR devices tuned to receive EEG/medical data
    """
    
    def __init__(self, node_id: str, dna_sequence: str, location: str):
        self.node_id = node_id
        self.dna_sequence = dna_sequence
        self.resonance_freq = self._calculate_resonance(dna_sequence)
        self.location = location
        self.stake_amount = 0
        self.is_active = False
        self.eeG_readings = []
        self.blockchain_addresses = {}
        
        print(f"   Node {node_id}: Tuned to {self.resonance_freq:.4f} GHz")
    
    def _calculate_resonance(self, dna: str) -> float:
        """Calculate RF resonance frequency from DNA sequence"""
        freq = np.mean([DNA_RESONANCE.get(c, 10.0) for c in dna.upper()])
        return freq
    
    def tune_to_frequency(self, target_freq_ghz: float) -> Dict:
        """Tune SDR to specific frequency"""
        offset = abs(self.resonance_freq - target_freq_ghz)
        tuned = offset < 0.01  # Within 10 MHz
        
        return {
            "node_id": self.node_id,
            "target_freq_ghz": target_freq_ghz,
            "node_resonance_ghz": self.resonance_freq,
            "tuned": tuned,
            "signal_quality": "EXCELLENT" if tuned else "POOR"
        }
    
    def stake_node(self, amount: float, blockchain: str) -> Dict:
        """Stake tokens to activate node for processing"""
        self.stake_amount = amount
        self.is_active = True
        self.blockchain_addresses[blockchain] = f"0x{self.node_id[:40]}"
        
        return {
            "node_id": self.node_id,
            "staked_amount": amount,
            "blockchain": blockchain,
            "activation_time": TIMESTAMP,
            "rewards_rate": 0.05  # 5% APY
        }
    
    def process_medical_data(self, eeg_data: Dict) -> Dict:
        """Process EEG medical data through RF-tuned node"""
        processed = {
            "node_id": self.node_id,
            "timestamp": TIMESTAMP,
            "eeg_hash": hashlib.sha3_256(json.dumps(eeg_data).encode()).hexdigest(),
            "resonance_freq": self.resonance_freq,
            "processing_power": self.stake_amount * 1000  # Watts equivalent
        }
        
        self.eeG_readings.append(processed)
        return processed


