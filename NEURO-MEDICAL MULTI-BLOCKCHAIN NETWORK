    def _create_iota_tx(self, eeg_hash: str, patient_id: str) -> Dict:
        """IOTA feeless data stream"""
        return {
            "message_id": hashlib.sha256(f"{eeg_hash}_iota".encode()).hexdigest(),
            "explorer_url": f"https://explorer.iota.org/mainnet/message/{eeg_hash[:32]}",
            "cost_usd": self.BLOCKCHAINS["iota"]["cost_usd"],
            "purpose": "Feeless medical data streaming"
        }
    
    def get_anchoring_status(self) -> Dict:
        """Get status of all anchors"""
        return {
            "total_anchors": len(self.anchors),
            "anchors": self.anchors,
            "total_cost_usd": sum(
                self.BLOCKCHAINS.get(chain.split('_')[0], {}).get("cost_usd", 0)
                for chain in self.anchors.keys()
            )
        }


