class MedicalDataToken:
    """
    Tokenizes EEG medical data for blockchain trading
    Each token represents a medical data point or outcome
    """
    
    TOKEN_TYPES = {
        "raw_eeg": {"value_usd": 10, "purpose": "Raw EEG signal data"},
        "processed_features": {"value_usd": 50, "purpose": "Processed biomarkers"},
        "diagnosis_outcome": {"value_usd": 500, "purpose": "Clinical outcome proof"},
        "treatment_response": {"value_usd": 1000, "purpose": "Treatment efficacy"},
        "full_session": {"value_usd": 2500, "purpose": "Complete session record"}
    }
    
    def __init__(self, patient_uuid: str, blockchain: str):
        self.patient_uuid = patient_uuid
        self.blockchain = blockchain
        self.tokens_minted = []
        
    def mint_token(self, token_type: str, data_hash: str, node_id: str) -> Dict:
        """Mint medical data token on specified blockchain"""
        
        if token_type not in self.TOKEN_TYPES:
            return {"error": f"Unknown token type: {token_type}"}
        
        token = {
            "token_id": hashlib.sha3_256(f"{self.patient_uuid}_{token_type}_{time.time()}".encode()).hexdigest()[:16],
            "token_type": token_type,
            "value_usd": self.TOKEN_TYPES[token_type]["value_usd"],
            "purpose": self.TOKEN_TYPES[token_type]["purpose"],
            "data_hash": data_hash,
            "patient_uuid": self.patient_uuid,
            "node_id": node_id,
            "blockchain": self.blockchain,
            "minted_at": TIMESTAMP,
            "owner": f"0x{self.patient_uuid[:40]}"
        }
        
        # Add blockchain-specific token standard
        if self.blockchain == "ethereum":
            token["standard"] = "ERC-721"
            token["contract"] = f"0x{hashlib.sha3_256(token['token_id'].encode()).hexdigest()[:40]}"
        elif self.blockchain == "solana":
            token["standard"] = "SPL"
            token["mint_address"] = token['token_id']
        
        self.tokens_minted.append(token)
        
        return token
    
    def get_token_value(self, token_id: str) -> Dict:
        """Get current market value of token"""
        for token in self.tokens_minted:
            if token["token_id"] == token_id:
                return {
                    "token_id": token_id,
                    "base_value_usd": token["value_usd"],
                    "appreciation": 1.0,  # Would track market price
                    "current_value_usd": token["value_usd"],
                    "trading_volume": 0
                }
        return {"error": "Token not found"}
    
    def trade_token(self, token_id: str, buyer: str, price_usd: float) -> Dict:
        """Execute token trade on blockchain"""
        token = None
        for t in self.tokens_minted:
            if t["token_id"] == token_id:
                token = t
                break
        
        if not token:
            return {"error": "Token not found"}
        
        trade = {
            "token_id": token_id,
            "seller": token["owner"],
            "buyer": buyer,
            "price_usd": price_usd,
            "blockchain": self.blockchain,
            "trade_hash": hashlib.sha3_256(f"{token_id}_{buyer}_{price_usd}".encode()).hexdigest(),
            "timestamp": TIMESTAMP,
            "royalty_percentage": 5,
            "royalty_distribution": {
                "patient": price_usd * 0.50,
                "clinic": price_usd * 0.25,
                "platform": price_usd * 0.25
            }
        }
        
        # Update token ownership
        token["owner"] = buyer
        token["last_trade"] = trade
        
        return trade


