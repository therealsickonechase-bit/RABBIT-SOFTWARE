class StakedNodeNetwork:
    """
    Proof-of-Stake network for RF-tuned medical nodes
    Nodes stake tokens to process EEG data and earn rewards
    """
    
    def __init__(self):
        self.nodes: Dict[str, RFTunedNode] = {}
        self.total_stake = 0
        self.reward_pool = 0
        self.block_reward = 10.0  # Tokens per block
        
    def register_node(self, node: RFTunedNode, stake_amount: float) -> Dict:
        """Register and stake a node"""
        self.nodes[node.node_id] = node
        node.stake_amount = stake_amount
        node.is_active = True
        self.total_stake += stake_amount
        
        return {
            "node_id": node.node_id,
            "staked": stake_amount,
            "share_of_network": (stake_amount / self.total_stake) * 100 if self.total_stake > 0 else 0,
            "activation_time": TIMESTAMP
        }
    
    def process_medical_block(self, eeg_data: Dict, processor_node: str) -> Dict:
        """Process EEG data block and distribute rewards"""
        if processor_node not in self.nodes:
            return {"error": "Node not found"}
        
        node = self.nodes[processor_node]
        
        # Process the data
        processed = node.process_medical_data(eeg_data)
        
        # Calculate reward based on stake
        reward = (node.stake_amount / self.total_stake) * self.block_reward
        
        # Distribute rewards
        reward_distribution = {
            "processor_node": processor_node,
            "processor_reward": reward * 0.8,  # 80% to processor
            "staking_pool_reward": reward * 0.2,  # 20% to stakers
            "total_reward": reward,
            "block_hash": hashlib.sha3_256(json.dumps(processed).encode()).hexdigest()
        }
        
        return {
            "block_processed": processed,
            "rewards": reward_distribution,
            "timestamp": TIMESTAMP
        }
    
    def get_node_health(self) -> Dict:
        """Get health status of all nodes"""
        health = {}
        for node_id, node in self.nodes.items():
            health[node_id] = {
                "active": node.is_active,
                "stake": node.stake_amount,
                "readings_processed": len(node.eeG_readings),
                "resonance_freq_ghz": node.resonance_freq
            }
        return health


