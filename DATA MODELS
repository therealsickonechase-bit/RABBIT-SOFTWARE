# SIGNAL PROCESSING ENGINE
# =============================================================================

class SignalProcessor:
    """Clinical-grade EEG spectral analysis and filtering."""

    @staticmethod
    def spectral_analysis(reading: EEGReading) -> Dict:
        """Compute PSD, band powers, and clinical metrics."""
        sig = reading.to_numpy()
        fs = reading.sample_rate_hz
        n = len(sig)

        # Apply Hanning window to reduce spectral leakage
        window = np.hanning(n)
        fft_vals = rfft(sig * window)
        freqs = rfftfreq(n, 1.0 / fs)
        psd = np.abs(fft_vals) ** 2 / (fs * (window ** 2).sum())

        # Calculate band powers
        bands = {}
        for band, (lo, hi) in EEG_BANDS.items():
            mask = (freqs >= lo) & (freqs <= hi)
            bands[band] = float(np.trapz(psd[mask], freqs[mask])) if mask.any() else 0.0

        # Find peak frequency in clinical range (1-50 Hz)
        clinical_mask = (freqs >= 1) & (freqs <= 50)
        if clinical_mask.any():
            peak_idx = np.argmax(psd[clinical_mask])
            peak_freq = float(freqs[clinical_mask][peak_idx])
            peak_power = float(psd[clinical_mask][peak_idx])
        else:
            peak_freq = 0.0
            peak_power = 0.0

        # Calculate SNR
        signal_power = np.sum(psd[(freqs >= 0.5) & (freqs <= 40)])
        noise_floor = np.mean(psd[-20:]) if len(psd) > 20 else signal_power * 0.1
        snr = 10 * np.log10(signal_power / (noise_floor + 1e-12))

        # Clinical indices
        theta_alpha_ratio = bands.get("theta", 0) / (bands.get("alpha", 1e-9) + 1e-9)
        beta_alpha_ratio = bands.get("beta", 0) / (bands.get("alpha", 1e-9) + 1e-9)

        return {
            "bands": {k: round(v, 5) for k, v in bands.items()},
            "peak_freq_hz": round(peak_freq, 2),
            "peak_power": round(peak_power, 5),
            "snr_db": round(snr, 2),
            "dominant_band": max(bands, key=bands.get),
            "theta_alpha_ratio": round(theta_alpha_ratio, 3),
            "beta_alpha_ratio": round(beta_alpha_ratio, 3),
            "total_power": round(float(np.sum(psd)), 5),
            "spectral_edge_freq": round(freqs[np.searchsorted(np.cumsum(psd), np.sum(psd) * 0.95)], 2)
        }

    @staticmethod
    def bandpass_filter(reading: EEGReading, low_hz: float, high_hz: float, order: int = 4) -> EEGReading:
        """Apply Butterworth bandpass filter."""
        sig = reading.to_numpy()
        nyq = reading.sample_rate_hz / 2.0
        low_n, high_n = low_hz / nyq, high_hz / nyq

        if 0 < low_n < 1 and 0 < high_n < 1 and low_n < high_n:
            b, a = sp_signal.butter(order, [low_n, high_n], btype="band")
            filtered = sp_signal.filtfilt(b, a, sig)
        else:
            filtered = sig.copy()

        reading.signal_uv = filtered.tolist()
        return reading

    @staticmethod
    def notch_filter(reading: EEGReading, freq_hz: float = 50.0, q: float = 30.0) -> EEGReading:
        """Remove mains interference (50/60 Hz)."""
        sig = reading.to_numpy()
        fs = reading.sample_rate_hz

        if freq_hz < fs / 2:
            b, a = sp_signal.iirnotch(freq_hz, q, fs)
            filtered = sp_signal.filtfilt(b, a, sig)
        else:
            filtered = sig.copy()

        reading.signal_uv = filtered.tolist()
        return reading

