# CLI INTERFACE
# =============================================================================

def run_cli(pipeline: EEGProvenancePipeline):
    """Interactive command-line interface."""

    console.rule("[bold cyan]🧠 EEG Research Provenance Chain[/bold cyan]")
    console.print(f"[dim]Ledger: {LEDGER_PATH.resolve()}[/dim]")
    console.print(f"[dim]Chain height: {pipeline.ledger.height} blocks[/dim]\n")

    table = Table(title="Commands", show_header=True, header_style="bold cyan")
    table.add_column("Command", style="cyan")
    table.add_column("Description", style="white")
    table.add_row("record <ch> <ms>", "Acquire, tokenize, analyze, and commit to ledger")
    table.add_row("verify", "Verify full chain integrity")
    table.add_row("export <index>", "Export provenance record for publication")
    table.add_row("impedance <ch>", "Check electrode impedance")
    table.add_row("status", "Show system status")
    table.add_row("quit", "Exit")
    console.print(table)
    console.print()

    while True:
        try:
            raw = input(">>> ").strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\n[yellow]Goodbye.[/yellow]")
            break

        if not raw:
            continue

        parts = raw.lower().split()
        cmd = parts[0]

        if cmd in ("quit", "exit", "q"):
            break

        elif cmd == "record":
            ch = int(parts[1]) if len(parts) > 1 else 0
            ms = float(parts[2]) if len(parts) > 2 else 2000.0

            result = pipeline.run(ch, ms)

            console.print(f"\n[bold green]✓ Block #{result['block_index']}[/bold green]")
            console.print(f"  Block hash:   [dim]{result['block_hash'][:32]}…[/dim]")
            console.print(f"  Channel:      {pipeline.hw._get_channel_name(ch)} (CH{ch})")
            console.print(f"  Dominant:     {result['spectral']['dominant_band']} @ {result['spectral']['peak_freq_hz']} Hz")
            console.print(f"  SNR:          {result['spectral']['snr_db']} dB")
            console.print(f"  Entropy:      {result['entropy_bits']} bits")
            console.print(f"  Tokens:       {result['tokens_preview']}")

            if result.get('eth_anchor'):
                console.print(f"  ETH anchor:   [dim]{result['eth_anchor'][:32]}…[/dim]")

            console.print(f"\n[bold]LLM Analysis:[/bold]")
            for line in result['llm_analysis'].split('\n')[:10]:
                console.print(f"  {line}")

        elif cmd == "verify":
            result = pipeline.verify()
            if result["valid"]:
                console.print(f"[green]✓ Chain VALID — {result['height']} blocks verified[/green]")
            else:
                console.print(f"[red]✗ Chain INVALID — {len(result['errors'])} errors[/red]")
                for e in result["errors"]:
                    console.print(f"  [red]{e}[/red]")

        elif cmd == "export":
            idx = int(parts[1]) if len(parts) > 1 else 0
            record = pipeline.export(idx)
            console.print(json.dumps(record, indent=2))

        elif cmd == "impedance":
            ch = int(parts[1]) if len(parts) > 1 else 0
            imp = pipeline.impedance(ch)
            color = {"GOOD": "green", "FAIR": "yellow", "POOR": "red"}.get(imp["quality"], "white")
            console.print(f"  [{color}]{imp['channel_name']}: {imp['impedance_ohms']} Ω — {imp['quality']}[/{color}]")

        elif cmd == "status":
            status = pipeline.status()
            console.print(f"  Device:       {status['device']}")
            console.print(f"  Connected:    {'✓' if status['connected'] else '✗'}")
            console.print(f"  Sample rate:  {status['sample_rate_hz']} Hz")
            console.print(f"  Channels:     {status['channels']}")
            console.print(f"  Ledger:       {status['ledger_path']}")
            console.print(f"  Chain height: {status['chain_height']}")
            console.print(f"  Chain valid:  {'✓' if status['chain_valid'] else '✗'}")

        else:
            console.print(f"[yellow]Unknown: {cmd}. Try 'record 0 2000'[/yellow]")

    console.rule()

