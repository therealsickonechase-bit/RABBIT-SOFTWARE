# =============================================================================

def main():
    parser = argparse.ArgumentParser(description="EEG Research Provenance Chain")
    parser.add_argument("--mode", choices=["cli", "server"], default="cli")
    parser.add_argument("--device", default="neuromind_v2", choices=list(DEVICE_SPECS.keys()))
    parser.add_argument("--port", default=None, help="Serial port")
    parser.add_argument("--ws-port", type=int, default=8765)
    parser.add_argument("--api-key", default=DEEPSEEK_API_KEY)
    parser.add_argument("--ledger", default="ledger.jsonl", help="Ledger file path")
    parser.add_argument("--verify", default=None, help="Verify ledger file and exit")

    args = parser.parse_args()

    if args.verify:
        verify_standalone(args.verify)
        return

    pipeline = EEGProvenancePipeline(
        device_type=args.device,
        port=args.port,
        api_key=args.api_key,
        ledger_path=Path(args.ledger)
    )

    if args.mode == "cli":
        run_cli(pipeline)
    else:
        if not HAS_WEBSOCKETS:
            console.print("[red]websockets not installed — run: pip install websockets[/red]")
            return

        async def ws_server():
            async def handler(websocket, path):
                async for message in websocket:
                    try:
                        data = json.loads(message)
                        cmd = data.get("cmd", "")

                        if cmd == "record":
                            result = pipeline.run(
                                data.get("channel", 0),
                                data.get("duration_ms", 2000)
                            )
                            await websocket.send(json.dumps(result))
                        elif cmd == "verify":
                            await websocket.send(json.dumps(pipeline.verify()))
                        elif cmd == "export":
                            await websocket.send(json.dumps(pipeline.export(data.get("index", 0))))
                        elif cmd == "status":
                            await websocket.send(json.dumps(pipeline.status()))
                        else:
                            await websocket.send(json.dumps({"error": f"Unknown: {cmd}"}))
                    except Exception as e:
                        await websocket.send(json.dumps({"error": str(e)}))

            console.print(f"[green]🌐 WebSocket server on ws://0.0.0.0:{args.ws_port}[/green]")
            async with websockets.serve(handler, "0.0.0.0", args.ws_port):
                await asyncio.Future()

        asyncio.run(ws_server())

if __name__ == "__main__":
    main()
