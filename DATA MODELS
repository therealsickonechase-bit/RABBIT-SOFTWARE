EEG_10_20 = ["Fp1", "Fp2", "F3", "F4", "C3", "C4", "P3", "P4",
             "O1", "O2", "F7", "F8", "T3", "T4", "T5", "T6",
             "Fz", "Cz", "Pz"]

DEVICE_SPECS = {
    "neuromind_v2": {"channels": 8, "fs": 256, "freq_range": [0.5, 100]},
    "neuromind_v3": {"channels": 16, "fs": 512, "freq_range": [0.5, 150]},
    "openbci_cyton": {"channels": 8, "fs": 250, "freq_range": [0.5, 100]},
    "muse_2": {"channels": 4, "fs": 256, "freq_range": [1.0, 50]},
    "eeg_generic": {"channels": 32, "fs": 1000, "freq_range": [0.1, 300]},
    "sdr_dna": {"channels": 1, "fs": 2000000, "freq_range": [1e6, 2e9]},
}

class HardwareLayer:
    """Medical device abstraction with realistic EEG simulation."""

    def __init__(self, device_type: str = "neuromind_v2", port: Optional[str] = None):
        self.device_type = device_type
        self.spec = DEVICE_SPECS.get(device_type, DEVICE_SPECS["neuromind_v2"])
        self._ser = None
        self._connected = False

        if port and HAS_SERIAL:
            try:
                self._ser = serial.Serial(port, baudrate=115200, timeout=1)
                self._connected = True
                console.print(f"[green]✓ Connected: {device_type} on {port}[/green]")
            except Exception as e:
                console.print(f"[yellow]⚠ Serial failed ({e}) — simulation[/yellow]")
        else:
            console.print(f"[blue]ℹ Simulation mode: {device_type}[/blue]")

    def read(self, channel: int, duration_ms: float) -> EEGReading:
        """Acquire EEG signal from device or simulation."""
        n = int(self.spec["fs"] * duration_ms / 1000)
        t = np.linspace(0, duration_ms / 1000, n)

        if self._connected and self._ser:
            sig = self._read_hardware(channel, n)
        else:
            sig = self._simulate_eeg(t, channel)

        ch_name = EEG_10_20[channel] if channel < len(EEG_10_20) else f"CH{channel}"

        return EEGReading(
            device_id=self.device_type,
            channel=channel,
            channel_name=ch_name,
            sample_rate_hz=float(self.spec["fs"]),
            duration_ms=duration_ms,
            timestamp_utc=datetime.datetime.utcnow().isoformat() + "Z",
            signal_uv=sig.tolist(),
            metadata={"simulated": not self._connected}
        )

    def _read_hardware(self, ch: int, n: int) -> np.ndarray:
        """Read from physical device."""
        cmd = struct.pack(">BBH", 0xA5, ch, n)
        self._ser.write(cmd)
        raw = self._ser.read(n * 4)
        if len(raw) >= n * 4:
            return np.frombuffer(raw[:n * 4], dtype=np.float32)
        return np.random.normal(0, 10, n).astype(np.float32)

    def _simulate_eeg(self, t: np.ndarray, ch: int) -> np.ndarray:
        """Generate clinically realistic EEG with per-channel variation."""
        rng = np.random.default_rng(ch * 31 + int(time.time()) % 997)

        # Individual alpha peak frequency (IAF) varies by person and channel
        iaf = 9.5 + rng.uniform(-2.0, 2.0)
        theta_freq = 5.5 + rng.uniform(-1.0, 1.0)
        beta_freq = 20.0 + rng.uniform(-5.0, 5.0)

        # Generate rhythmic components
        alpha = 25.0 * np.sin(2 * np.pi * iaf * t + rng.uniform(0, 2*np.pi))
        theta = 12.0 * np.sin(2 * np.pi * theta_freq * t + rng.uniform(0, 2*np.pi))
        beta = 8.0 * np.sin(2 * np.pi * beta_freq * t + rng.uniform(0, 2*np.pi))
        noise = 4.0 * rng.standard_normal(len(t))

        sig = alpha + theta + beta + noise

        # Add eye blink artifacts on frontal channels
        if ch < 2 and rng.random() < 0.15:
            blink_idx = rng.integers(50, len(t) - 100)
            blink_shape = 100 * np.exp(-np.arange(100) / 15)
            end_idx = min(blink_idx + 100, len(sig))
            sig[blink_idx:end_idx] += blink_shape[:end_idx - blink_idx]

        return sig.astype(np.float32)

    def check_impedance(self, channel: int) -> Dict:
        """Check electrode impedance (kΩ)."""
        if self._connected and self._ser:
            self._ser.write(struct.pack(">BB", 0xA8, channel))
            raw = self._ser.read(4)
            ohms = struct.unpack(">f", raw)[0] if len(raw) == 4 else 15000.0
        else:
            ohms = float(np.random.uniform(800, 45000))

        quality = "GOOD" if ohms < 5000 else ("FAIR" if ohms < 20000 else "POOR")
        ch_name = EEG_10_20[channel] if channel < len(EEG_10_20) else f"CH{channel}"

        return {
            "channel": channel,
            "channel_name": ch_name,
            "impedance_ohms": round(ohms, 1),
            "quality": quality,
            "clinical_recommendation": "Reapply electrode" if quality == "POOR" else "OK"
        }

