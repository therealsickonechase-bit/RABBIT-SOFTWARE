class BlockchainAnchor:
    """Anchor provenance hashes to public blockchains."""

    def __init__(self):
        self.web3 = None
        self.solana_client = None

        if ANCHOR_TO_ETH and HAS_WEB3 and ETH_PRIVATE_KEY:
            try:
                self.web3 = Web3(Web3.HTTPProvider(ETH_RPC_URL))
                if self.web3.is_connected():
                    self.eth_account = self.web3.eth.account.from_key(ETH_PRIVATE_KEY)
                    console.print("[green]✓ Ethereum anchoring ready[/green]")
            except Exception as e:
                console.print(f"[yellow]⚠ ETH anchoring failed: {e}[/yellow]")

    def anchor_to_ethereum(self, block_hash: str, data_hash: str) -> Optional[str]:
        """Anchor hash pair to Ethereum (cheap via blob or calldata)."""
        if not self.web3 or not self.eth_account:
            return None

        try:
            # Simplified: send transaction with hash in data field
            # In production: use cheaper blob transactions (EIP-4844)
            tx = {
                'to': self.eth_account.address,
                'value': 0,
                'gas': 21000,
                'gasPrice': self.web3.eth.gas_price,
                'nonce': self.web3.eth.get_transaction_count(self.eth_account.address),
                'data': f"0x{block_hash}{data_hash}"[:10000].encode()
            }
            signed = self.web3.eth.account.sign_transaction(tx, ETH_PRIVATE_KEY)
            tx_hash = self.web3.eth.send_raw_transaction(signed.rawTransaction)
            return tx_hash.hex()
        except Exception as e:
            console.print(f"[red]ETH anchor failed: {e}[/red]")
            return None

