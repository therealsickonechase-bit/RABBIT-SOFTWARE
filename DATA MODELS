# PROVENANCE LEDGER (Immutable Chain)
# =============================================================================

class ProvenanceLedger:
    """Append-only JSONL blockchain with cryptographic verification."""

    def __init__(self, path: Path = LEDGER_PATH):
        self.path = path
        self._lock = threading.Lock()
        self._blocks: List[Dict] = []

        if path.exists():
            self._load()
            console.print(f"[cyan]📒 Ledger loaded: {len(self._blocks)} blocks[/cyan]")
        else:
            console.print(f"[cyan]📒 New ledger: {path}[/cyan]")

    def _load(self):
        with open(self.path, "r") as f:
            for line in f:
                line = line.strip()
                if line:
                    self._blocks.append(json.loads(line))

    @property
    def head_hash(self) -> str:
        return self._blocks[-1]["block_hash"] if self._blocks else GENESIS_HASH

    @property
    def height(self) -> int:
        return len(self._blocks)

    def append(self, block: ProvenanceBlock) -> ProvenanceBlock:
        """Append block to ledger with thread safety."""
        with self._lock:
            block.block_hash = block.compute_block_hash()

            # Write to file
            with open(self.path, "a") as f:
                f.write(json.dumps(block.to_dict()) + "\n")

            self._blocks.append(block.to_dict())
            return block

    def verify(self) -> Tuple[bool, List[str]]:
        """Verify full chain integrity."""
        errors = []
        prev_hash = GENESIS_HASH

        for i, raw in enumerate(self._blocks):
            # Reconstruct block without block_hash
            block_data = {k: v for k, v in raw.items() if k != "block_hash"}
            b = ProvenanceBlock(**block_data)
            expected_hash = b.compute_block_hash()

            if raw["block_hash"] != expected_hash:
                errors.append(f"Block {i}: hash mismatch — data tampered")

            if raw["previous_hash"] != prev_hash:
                errors.append(f"Block {i}: chain break — previous_hash invalid")

            prev_hash = raw["block_hash"]

        return len(errors) == 0, errors

    def get_block(self, index: int) -> Optional[Dict]:
        return self._blocks[index] if 0 <= index < len(self._blocks) else None

    def export_provenance_record(self, block_index: int) -> Dict:
        """Export self-contained provenance for publication."""
        block = self.get_block(block_index)
        if not block:
            return {"error": "Block not found"}

        valid, errors = self.verify()

        return {
            "provenance_record": {
                "ledger_file": str(self.path),
                "chain_height": self.height,
                "chain_valid": valid,
                "verification_errors": errors,
                "block": block,
                "verification_method": "SHA3-256 hash chain with previous_hash linking",
                "cryptographic_strength": "256-bit preimage and collision resistance"
            }
        }

