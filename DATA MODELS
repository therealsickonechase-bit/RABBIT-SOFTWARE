# MAIN PIPELINE
# =============================================================================

class EEGProvenancePipeline:
    """Complete pipeline orchestrator."""

    def __init__(self,
                 device_type: str = "neuromind_v2",
                 port: Optional[str] = None,
                 api_key: str = DEEPSEEK_API_KEY,
                 ledger_path: Path = LEDGER_PATH):

        self.hw = HardwareLayer(device_type, port)
        self.processor = SignalProcessor()
        self.analyzer = DeepSeekAnalyzer(api_key)
        self.ledger = ProvenanceLedger(ledger_path)
        self.blockchain = BlockchainAnchor()
        self._last_block: Optional[ProvenanceBlock] = None

    def run(self,
            channel: int,
            duration_ms: float,
            bandpass: Tuple[float, float] = (1.0, 40.0),
            notch_hz: Optional[float] = 50.0) -> Dict:
        """Execute full pipeline: acquire → process → tokenize → analyze → record."""

        with Progress(
            SpinnerColumn(),
            TextColumn("[progress.description]{task.description}"),
            BarColumn(),
            console=console,
            transient=False
        ) as progress:
            task = progress.add_task("[cyan]Pipeline running...", total=5)

            # 1. Acquire signal
            progress.update(task, description="[cyan]1/5 Acquiring EEG signal...")
            reading = self.hw.read(channel, duration_ms)
            reading_hash = reading.reading_hash()
            progress.advance(task)

            # 2. Filter signal
            progress.update(task, description="[cyan]2/5 Applying filters...")
            if notch_hz:
                reading = self.processor.notch_filter(reading, notch_hz)
            reading = self.processor.bandpass_filter(reading, bandpass[0], bandpass[1])
            progress.advance(task)

            # 3. Spectral analysis
            progress.update(task, description="[cyan]3/5 Computing spectral features...")
            spectral = self.processor.spectral_analysis(reading)
            progress.advance(task)

            # 4. Quantize to binary tokens
            progress.update(task, description="[cyan]4/5 Quantizing to binary tokens...")
            tokens = BinaryTokens.from_signal(reading.to_numpy(), QUANTIZATION_BITS)
            progress.advance(task)

            # 5. LLM analysis
            progress.update(task, description="[cyan]5/5 Analyzing with DeepSeek...")
            prompt = tokens.to_llm_prompt(reading, spectral)
            analysis = self.analyzer.analyze(prompt)
            llm_hash = hashlib.sha3_256(analysis.encode()).hexdigest()
            progress.advance(task)

        # Create block
        block = ProvenanceBlock(
            block_index=self.ledger.height,
            timestamp_utc=datetime.datetime.utcnow().isoformat() + "Z",
            previous_hash=self.ledger.head_hash,
            reading_hash=reading_hash,
            token_hash=tokens.token_hash,
            llm_analysis_hash=llm_hash,
            device_id=reading.device_id,
            channel=reading.channel,
            channel_name=reading.channel_name,
            sample_rate_hz=reading.sample_rate_hz,
            duration_ms=reading.duration_ms,
            spectral_summary=spectral,
            llm_analysis=analysis,
        )

        # Optional blockchain anchoring
        if ANCHOR_TO_ETH:
            anchor_hash = hashlib.sha3_256(f"{block.reading_hash}{block.token_hash}".encode()).hexdigest()
            tx_hash = self.blockchain.anchor_to_ethereum(block.block_hash, anchor_hash)
            if tx_hash:
                block.eth_tx_hash = tx_hash
                console.print(f"[green]📡 Anchored to Ethereum: {tx_hash[:16]}...[/green]")

        # Commit to ledger
        block = self.ledger.append(block)
        self._last_block = block

        return {
            "block_index": block.block_index,
            "block_hash": block.block_hash,
            "reading_hash": reading_hash,
            "token_hash": tokens.token_hash,
            "llm_hash": llm_hash,
            "spectral": spectral,
            "llm_analysis": analysis,
            "tokens_preview": tokens.hex_tokens[:64] + "…",
            "entropy_bits": tokens.entropy_bits,
            "eth_anchor": block.eth_tx_hash
        }

    def verify(self) -> Dict:
        valid, errors = self.ledger.verify()
        return {
            "valid": valid,
            "height": self.ledger.height,
            "head_hash": self.ledger.head_hash[:32] + "…",
            "errors": errors
        }

    def export(self, block_index: int) -> Dict:
        return self.ledger.export_provenance_record(block_index)

    def impedance(self, channel: int) -> Dict:
        return self.hw.check_impedance(channel)

    def status(self) -> Dict:
        valid, _ = self.ledger.verify()
        return {
            "device": self.hw.device_type,
            "connected": self.hw._connected,
            "sample_rate_hz": self.hw.spec["fs"],
            "channels": self.hw.spec["channels"],
            "ledger_path": str(self.ledger.path),
            "chain_height": self.ledger.height,
            "chain_valid": valid
        }

