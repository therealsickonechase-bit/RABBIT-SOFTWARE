@dataclass
class EEGReading:
    """Raw EEG acquisition with cryptographic hash."""
    device_id: str
    channel: int
    channel_name: str
    sample_rate_hz: float
    duration_ms: float
    timestamp_utc: str
    signal_uv: List[float]
    metadata: Dict = field(default_factory=dict)

    def to_numpy(self) -> np.ndarray:
        return np.array(self.signal_uv, dtype=np.float32)

    def reading_hash(self) -> str:
        """SHA3-256 of raw signal for tamper-proof record."""
        payload = json.dumps({
            "device_id": self.device_id,
            "channel": self.channel,
            "sample_rate_hz": self.sample_rate_hz,
            "timestamp_utc": self.timestamp_utc,
            "signal_checksum": hashlib.md5(str(self.signal_uv[:100]).encode()).hexdigest(),
            "signal_length": len(self.signal_uv)
        }, sort_keys=True)
        return hashlib.sha3_256(payload.encode()).hexdigest()

    def compress(self) -> bytes:
        """Compress signal for storage efficiency."""
        return zlib.compress(np.array(self.signal_uv).astype(np.float32).tobytes(), level=9)

@dataclass
class BinaryTokens:
    """EEG signal quantized into binary token sequence."""
    raw_bytes: bytes
    hex_tokens: str
    bit_depth: int
    n_samples: int
    amplitude_range_uv: Tuple[float, float]
    entropy_bits: float
    token_hash: str

    @classmethod
    def from_signal(cls, signal: np.ndarray, bits: int = QUANTIZATION_BITS) -> "BinaryTokens":
        """Quantize float32 EEG → unsigned integers → bytes."""
        levels = 2 ** bits
        sig_min, sig_max = float(signal.min()), float(signal.max())
        sig_range = sig_max - sig_min if sig_max != sig_min else 1.0

        # Normalize to [0, levels-1]
        quantized = np.clip(
            ((signal - sig_min) / sig_range * (levels - 1)).astype(np.uint8),
            0, levels - 1
        )
        raw_bytes = quantized.tobytes()
        hex_tokens = raw_bytes.hex()

        # Calculate entropy (measure of information content)
        hist, _ = np.histogram(quantized, bins=levels, density=True)
        hist = hist[hist > 0]
        entropy = -np.sum(hist * np.log2(hist)) if len(hist) > 0 else 0

        token_hash = hashlib.sha3_256(raw_bytes).hexdigest()

        return cls(
            raw_bytes=raw_bytes,
            hex_tokens=hex_tokens,
            bit_depth=bits,
            n_samples=len(signal),
            amplitude_range_uv=(round(sig_min, 3), round(sig_max, 3)),
            entropy_bits=round(entropy, 3),
            token_hash=token_hash
        )

    def to_llm_prompt(self, reading: EEGReading, spectral: Dict) -> str:
        """Build research-grade LLM prompt with tokens + metadata."""
        # Trim tokens for context window
        tokens_for_llm = self.hex_tokens[:TOKEN_WINDOW_SIZE * 2]

        return f"""EEG RESEARCH RECORD — PROVENANCE ID: {self.token_hash[:16]}

ACQUISITION:
  Device: {reading.device_id}
  Channel: {reading.channel_name} (CH{reading.channel})
  Sample Rate: {reading.sample_rate_hz} Hz
  Duration: {reading.duration_ms} ms
  Timestamp: {reading.timestamp_utc}
  Amplitude: {self.amplitude_range_uv[0]:.1f} to {self.amplitude_range_uv[1]:.1f} µV

SPECTRAL ANALYSIS:
{chr(10).join(f'  {b}: {v:.4f} µV²/Hz' for b, v in spectral["bands"].items())}
  Peak Frequency: {spectral['peak_freq_hz']:.2f} Hz
  SNR: {spectral['snr_db']:.1f} dB
  Dominant Band: {spectral['dominant_band']}
  Theta/Alpha Ratio: {spectral['theta_alpha_ratio']:.3f}
  Entropy: {self.entropy_bits:.3f} bits

TOKEN SEQUENCE ({self.bit_depth}-bit quantization, {min(self.n_samples, TOKEN_WINDOW_SIZE)}/{self.n_samples} samples):
{tokens_for_llm}

Analyze this EEG token sequence for research provenance."""

@dataclass
class ProvenanceBlock:
    """Immutable block in research provenance ledger."""
    block_index: int
    timestamp_utc: str
    previous_hash: str

    # Pipeline stage hashes
    reading_hash: str
    token_hash: str
    llm_analysis_hash: str

    # Metadata
    device_id: str
    channel: int
    channel_name: str
    sample_rate_hz: float
    duration_ms: float
    spectral_summary: Dict
    llm_analysis: str

    # Blockchain anchors (optional)
    eth_tx_hash: Optional[str] = None
    solana_signature: Optional[str] = None

    # Integrity
    block_hash: str = ""

    def compute_block_hash(self) -> str:
        """SHA3-256 of all block fields (excluding block_hash)."""
        payload = json.dumps({
            "block_index": self.block_index,
            "timestamp_utc": self.timestamp_utc,
            "previous_hash": self.previous_hash,
            "reading_hash": self.reading_hash,
            "token_hash": self.token_hash,
            "llm_analysis_hash": self.llm_analysis_hash,
            "device_id": self.device_id,
            "channel": self.channel,
            "sample_rate_hz": self.sample_rate_hz,
            "duration_ms": self.duration_ms,
            "eth_tx_hash": self.eth_tx_hash,
            "solana_signature": self.solana_signature,
        }, sort_keys=True)
        return hashlib.sha3_256(payload.encode()).hexdigest()

    def to_dict(self) -> Dict:
        d = asdict(self)
        d["block_hash"] = self.block_hash
        return d

