🧠 9. SWARM RUNTIME LOOP

from core.swarm_coordinator import SwarmCoordinator
from agents.observability_agent import ObservabilityAgent
from agents.execution_agent import ExecutionAgent

import time

coord = SwarmCoordinator()
obs = ObservabilityAgent()
exec_agent = ExecutionAgent()

while True:
    metrics = obs.get_metrics()

    if metrics["cpu"] > 80 or metrics["latency"] > 150:
        event = {"type": "incident", "metrics": metrics}

        result = coord.handle_event(event)

        exec_agent.run_action(result["action"])

        print("INCIDENT HANDLED:", result)

    time.sleep(2)


