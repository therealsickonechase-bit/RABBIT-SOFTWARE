🧠 6. MEMORY AGENT (LONG-TERM LEARNING)

class MemoryAgent:
    def __init__(self):
        self.store = []

    def remember(self, event, outcome):
        self.store.append({
            "event": event,
            "outcome": outcome
        })

    def retrieve_patterns(self):
        return self.store[-100:]


