🧠 1. SWARM COORDINATOR (ORCHESTRATOR BRAIN)

from communication.event_bus import EventBus
from agents.planner import PlannerAgent
from agents.diagnoser import DiagnoserAgent
from agents.repair_agent import RepairAgent

class SwarmCoordinator:
    def __init__(self):
        self.bus = EventBus()
        self.planner = PlannerAgent()
        self.diagnoser = DiagnoserAgent()
        self.repair = RepairAgent()

    def handle_event(self, event):
        if event["type"] == "incident":
            plan = self.planner.create_plan(event)
            cause = self.diagnoser.analyze(event)
            action = self.repair.execute(cause)

            return {
                "plan": plan,
                "cause": cause,
                "action": action
            }


