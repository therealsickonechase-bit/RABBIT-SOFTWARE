🧠 4. DIAGNOSER AGENT (ROOT CAUSE AI)

class DiagnoserAgent:
    def analyze(self, event):
        metrics = event.get("metrics", {})

        if metrics.get("cpu", 0) > 85:
            return "OVERLOAD"

        if metrics.get("latency", 0) > 200:
            return "NETWORK_FAILURE"

        return "UNKNOWN"


