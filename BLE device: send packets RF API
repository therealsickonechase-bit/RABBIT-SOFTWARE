import asyncio
import json
import requests
from bleak import BleakClient

BLE_ADDRESS = "AA:BB:CC:DD:EE:FF"      # MAC or ID of your BLE device
SERVICE_UUID = "0000xxxx-0000-1000-8000-00805f9b34fb"
CHAR_UUID = "0000yyyy-0000-1000-8000-00805f9b34fb"

API_URL = "https://example.com/ingest"  # Your backend HTTP API

def send_to_api(payload: bytes):
    # Convert bytes to something your API accepts (here: hex string)
    data = {
        "source": "ble_device_1",
        "payload_hex": payload.hex(),
    }
    try:
        r = requests.post(API_URL, json=data, timeout=5)
        r.raise_for_status()
    except Exception as e:
        print("HTTP send failed:", e)

def notification_handler(_: int, data: bytearray):
    # Called every time the BLE device sends a notification on CHAR_UUID
    print("Got BLE packet:", data.hex())
    send_to_api(bytes(data))

async def main():
    async with BleakClient(BLE_ADDRESS) as client:
        print("Connected to BLE device:", BLE_ADDRESS)

        await client.start_notify(CHAR_UUID, notification_handler)
        print("Listening for BLE packets; Ctrl+C to exit.")
        while True:
            await asyncio.sleep(1)

if __name__ == "__main__":
    asyncio.run(main())  
