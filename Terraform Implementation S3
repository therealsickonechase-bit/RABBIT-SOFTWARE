# S3 Gateway Endpoint (FREE)
resource "aws_vpc_endpoint" "s3_genomic" {
  vpc_id            = aws_vpc.genomic.id
  service_name      = "com.amazonaws.us-east-1.s3"
  vpc_endpoint_type = "Gateway"
  route_table_ids   = [aws_route_table.private.id]
  tags = { Name = "s3-eeg-hashes" }
}

# Private Route Table  
resource "aws_route" "s3_endpoint" {
  route_table_id         = aws_route_table.private.id
  destination_prefix_list_id = "pl-63a3694a"  # S3 prefix list
  vpc_endpoint_id        = aws_vpc_endpoint.s3_genomic.id
}