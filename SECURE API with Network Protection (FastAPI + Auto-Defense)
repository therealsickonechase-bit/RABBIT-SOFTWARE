app = FastAPI(title="MedicalBlockNet SECURE API")
security = HTTPBearer()

BITCOIN_CLI = r'"C:\Program Files\Bitcoin\daemon\bitcoin-cli.exe"'
db = sqlite3.connect("medical_shards_secure.db", check_same_thread=False)

# Security Config
SECURITY_KEYS = set()  # Dynamic API keys
BLOCKLIST = set()      # Auto-ban IPs
RATE_LIMIT = {}        # Per-IP rate limiting

class SecureShardNetwork:
    def __init__(self):
        self.peers = {}
        self.shards = {}
        self.threat_history = []
        self.init_security()
    
    def init_security(self):
        """Initialize self-protection"""
        init_db()
        asyncio.create_task(self.security_monitor())
    
    async def security_monitor(self):
        """Continuous network protection"""
        while True:
            await asyncio.sleep(30)
            # Auto-blocklist suspicious IPs
            threats = threat_detector.scan_network()
            for threat in threats:
                BLOCKLIST.add(threat["ip"])
                print(f"🚨 AUTO-BLOCKED: {threat['ip']} - {threat['reason']}")
            
            # Rotate API keys
            self.rotate_keys()
    
    def rotate_keys(self):
        """Generate new session keys"""
        new_key = hashlib.sha256(secrets.token_bytes(32)).hexdigest()[:32]
        SECURITY_KEYS.add(new_key)
        # Expire old keys after 24h
        SECURITY_KEYS.difference_update([k for k in SECURITY_KEYS if self.is_expired(k)])

# Global secure network
secure_net = SecureShardNetwork()

def get_current_time():
    return datetime.utcnow()

def api_key_auth(credentials: HTTPAuthorizationCredentials = Security(security)):
    """Validate API key + rate limit"""
    client_ip = "127.0.0.1"  # Extract from headers in prod
    
    # Rate limiting
    now = get_current_time()
    RATE_LIMIT[client_ip] = RATE_LIMIT.get(client_ip, []) + [now]
    RATE_LIMIT[client_ip] = [t for t in RATE_LIMIT[client_ip] 
                           if now - t < timedelta(minutes=1)]
    if len(RATE_LIMIT[client_ip]) > 100:
        raise HTTPException(429, "Rate limited")
    
    # Blocklist check
    if client_ip in BLOCKLIST:
        raise HTTPException(403, "IP blocked")
    
    # API key validation
    if credentials.credentials not in SECURITY_KEYS:
        raise HTTPException(401, "Invalid API key")
    
    return credentials.credentials

def init_db():
    db.execute("""
        CREATE TABLE IF NOT EXISTS secure_shards (
            shard_id TEXT PRIMARY KEY, owner_id TEXT, btc_height INTEGER,
            data_hash TEXT, signature TEXT, peers TEXT, 
            threat_score REAL DEFAULT 0, last_seen TIMESTAMP
        )
    """)
    db.execute("""
        CREATE TABLE IF NOT EXISTS security_log (
            ip TEXT, action TEXT, timestamp TIMESTAMP, threat_level INTEGER
        )
    """)
    db.commit()

