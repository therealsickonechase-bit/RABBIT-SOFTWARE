# === BITCOIN CORE AUTO-SCANNING ===
async def bitcoin_threat_monitor():
    """Monitor Bitcoin blocks for malicious medical data"""
    while True:
        try:
            current_height = json.loads(subprocess.check_output([BITCOIN_CLI, "getblockchaininfo"], text=True))["blocks"]
            block = bitcoin_scan_block(current_height - 10)  # Recent block
            
            threats = threat_detector.scan_block_for_threats(block)
            for threat in threats:
                log_security_event("127.0.0.1", "btc_threat", threat["level"])
                
        except Exception as e:
            print(f"Threat monitor error: {e}")
        
        await asyncio.sleep(300)  # 5min

def bitcoin_scan_block(height: int) -> Dict:
    hash_ = subprocess.check_output([BITCOIN_CLI, "getblockhash", str(height)], text=True).strip()
    return json.loads(subprocess.check_output([BITCOIN_CLI, "getblock", hash_, "1"], text=True))

def verify_signature(owner_id: str, data_hash: str, signature: str) -> bool:
    """ECDSA signature verification"""
    try:
        # Simplified - implement full ECDSA
        return hashlib.sha256(f"{owner_id}{data_hash}".encode()).hexdigest()[:16] == signature[:16]
    except:
        return False

def log_security_event(ip: str, action: str, threat_level: int):
    db.execute("INSERT INTO security_log (ip, action, timestamp, threat_level) VALUES (?, ?, ?, ?)",
              (ip, action, get_current_time(), threat_level))
    db.commit()

