@app.get("/api-key")
async def get_api_key():
    """Generate secure API key"""
    key = hashlib.sha256(secrets.token_bytes(32)).hexdigest()[:32]
    SECURITY_KEYS.add(key)
    return {"api_key": key, "expires": (get_current_time() + timedelta(hours=24)).isoformat()}

@app.post("/shard/register", dependencies=[Depends(api_key_auth)])
async def register_shard(shard: Dict):
    """Register shard with cryptographic signature"""
    # Verify owner signature
    if not verify_signature(shard["owner_id"], shard["data_hash"], shard["signature"]):
        raise HTTPException(400, "Invalid signature")
    
    shard_id = hashlib.sha256(f"{shard['data_hash']}{shard['owner_id']}".encode()).hexdigest()[:16]
    
    db.execute("""
        INSERT OR REPLACE INTO secure_shards 
        (shard_id, owner_id, btc_height, data_hash, signature, last_seen)
        VALUES (?, ?, ?, ?, ?, ?)
    """, (shard_id, shard["owner_id"], shard["btc_height"], 
          shard["data_hash"], shard["signature"], get_current_time()))
    db.commit()
    
    # Secure P2P propagation
    secure_net.broadcast_secure({"type": "new_shard", "shard": shard, "sig": shard["signature"]})
    
    return {"shard_id": shard_id, "status": "SECURELY_REGISTERED"}

@app.get("/shard/{shard_id}", dependencies=[Depends(api_key_auth)])
async def get_shard(shard_id: str):
    """Secure shard lookup with threat scanning"""
    row = db.execute("SELECT * FROM secure_shards WHERE shard_id=?", (shard_id,)).fetchone()
    if row:
        shard = dict(zip([c[0] for c in db.description], row))
        # Threat scan before return
        threat_score = threat_detector.scan_shard(shard)
        shard["threat_score"] = threat_score
        
        if threat_score > 0.8:
            network_protector.quarantine_shard(shard_id)
            raise HTTPException(451, "Shard quarantined - high threat")
        
        return shard
    
    # P2P secure lookup
    p2p_result = await secure_net.secure_shard_query(shard_id)
    return {"found": bool(p2p_result), "network_result": p2p_result}

