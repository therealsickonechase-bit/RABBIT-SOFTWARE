    print(f"   Biometric key (hex): {bio_key.hex()[:16]}...")

    # --- Step 3: simulate distribution of shares across offline nodes ---
    print("\n3. Shares locked to life events:")
    for event_id, info in sharder.shares.items():
        print(f"   - {LIFE_EVENTS[event_id]['description']}")
        # The actual share is encrypted and stored locally; we keep a copy.

    # --- Step 4: simulate a theft / offline period ---
    print("\n4. Simulating offline period / theft event...")
    time.sleep(1)   # pause for effect
    print("   (The system continues to run locally; no data leaves the device.)")

    # --- Step 5: recovery phase (user collects shares) ---
    print("\n5. Recovery process begins:")
    # For demonstration, we collect a subset of shares (meeting the threshold)
    # In a real scenario, the user would answer the LLM’s prompts or
    # provide the shares manually (e.g., from family nodes).

    # Use the LLM to generate a contextual recovery prompt
    llm = LocalRecoveryLLM()
    emotional_context = "calm but slightly anxious after a long offline period"
    recovery_question = llm.generate_prompt(emotional_context)
    print(f"   LLM prompt: '{recovery_question}'")

    # Here we simulate that the user (Chase) retrieves enough shares.
    # For testing, we take the first 'threshold' shares from the store.
    collected = []
    events_list = list(sharder.shares.items())
    for i in range(sharder.threshold):
        event_id, info = events_list[i]
        collected.append((event_id, info["encrypted_share"]))
        print(f"   - Collected share for: {LIFE_EVENTS[event_id]['description']}")

    # Derive the biometric key again (from live EEG)
    print("\n   Re‑deriving biometric key from live EEG...")
    current_bio_key = BiometricKey.from_eeg_stream(duration=1.0)
    # Normally we would set sharder.biometric_key = current_bio_key,
    # but for simplicity we reuse the instance variable (same key)
    sharder.biometric_key = current_bio_key

    # Reconstruct the secret
    try:
        recovered = sharder.reconstruct_secret(collected)
        print(f"\n6. Secret recovered successfully: {recovered[:20]}...")
    except Exception as e:
        print(f"\n   Recovery failed: {e}")
        sys.exit(1)

    # --- Step 6: anchor the recovery event to the blockchain ---
    blockchain = MockBlockchain()
    tx_hash = blockchain.record("RECOVERY_EVENT", {
        "user_id": "Chase_Ringquist",
        "timestamp": time.time(),
        "status": "secret_restored",
        "shares_used": sharder.threshold
    })
    print(f"\n7. Recovery event anchored to (simulated) blockchain. Tx hash: {tx_hash}")

    # --- Step 7: verification that the system is whole again ---
    assert recovered == master_secret, "Recovered secret does not match the original!"
    print("\n✅ SUCCESS: The digital twin is complete and self‑healed.\n")
    return 0


if __name__ == "__main__":
