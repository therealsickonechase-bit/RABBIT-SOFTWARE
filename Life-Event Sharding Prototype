class LocalRecoveryLLM:
    """Lightweight LLM (GPT‑2) that asks contextual recovery questions."""

    def __init__(self):
        if not LLM_AVAILABLE:
            print("[LLM] transformers not installed – using rule‑based fallback.")
            self.generator = None
            return
        # Load a tiny model (GPT‑2) – runs on CPU.
        try:
            self.tokenizer = AutoTokenizer.from_pretrained("gpt2")
            self.model = AutoModelForCausalLM.from_pretrained("gpt2")
            self.generator = pipeline(
                "text-generation",
                model=self.model,
                tokenizer=self.tokenizer,
                device=-1,          # CPU
                max_new_tokens=20,
                do_sample=True,
                top_p=0.9,
                temperature=0.7
            )
        except Exception as e:
            print(f"[LLM] Failed to load model: {e}")
            self.generator = None

    def generate_prompt(self, emotional_state: str) -> str:
        """
        Given a description of the user’s current emotional state,
        return a human‑readable recovery prompt/question.
        """
        if self.generator is None:
            # Rule‑based fallback
            fallback = "Please recall one of your defined life events."
            print(f"[LLM] (fallback) {fallback}")
            return fallback

        # Build a simple instruction
        instruction = (
            f"The user is feeling {emotional_state}. "
            "Ask a gentle, context‑appropriate question that helps them "
            "recall a past life event (accomplishment or hurdle) "
            "that could serve as a secret‑sharing recovery key."
        )
        try:
            result = self.generator(instruction, max_new_tokens=20)
            return result[0]["generated_text"]
        except Exception as e:
            print(f"[LLM] generation error: {e}")
            return "What important event in your life comes to mind right now?"


# ----------------------------------------------------------------------
# 4. Core sharding & recovery engine
# ----------------------------------------------------------------------

class LifeEventSharding:
    """
    Manages splitting/reconstructing a secret using Shamir's Secret Sharing,
    where each share is cryptographically bound to a user’s life event and
    protected by a biometric key.
    """

    def __init__(self, secret: str, threshold: int, total_shares: int):
        """
        secret: any string (master passphrase, key, etc.)
        threshold: minimum number of shares needed to reconstruct
        total_shares: total number of shares (must match len(LIFE_EVENTS))
        """
        self.secret = secret
        self.threshold = threshold
        self.total_shares = total_shares
        self.shares: Dict[str, Dict] = {}          # event_id -> {share, share_enc}
        self.biometric_key: Optional[bytes] = None

    @classmethod
    def from_events(cls, secret: str, events: Dict[str, Dict]) -> "LifeEventSharding":
        """
        Factory method: creates a sharding instance based on the number
        of life events defined in LIFE_EVENTS.
        """
        total = len(events)
        # Threshold = ceil(2/3 total) for safe recovery
        threshold = max(2, (total * 2 + 2) // 3)
        return cls(secret, threshold, total)

    def _encrypt_share(self, share_data: str, key: bytes) -> str:
        """Tiny XOR‑cipher for demonstration – in production use AES‑GCM."""
        encrypted = ''.join(chr(ord(c) ^ key[i % len(key)])
                            for i, c in enumerate(share_data))
        return encrypted

    def _decrypt_share(self, encrypted: str, key: bytes) -> str:
        """Reverse of above."""
        return self._encrypt_share(encrypted, key)   # XOR is symmetric

    def generate_shares(self, biometric_key: bytes) -> None:
        """
        Split the secret into `total_shares` shares using Shamir's algorithm,
        then encrypt each share with a biometric key and bind it to a life event.
        """
        self.biometric_key = biometric_key
        # 1. Generate raw shares
        raw_shares = generate_text_shares(self.secret, self.threshold, self.total_shares)
        # raw_shares is a list of strings like "share_1:..."
        # 2. Pair each share with a life event
        events_list = list(LIFE_EVENTS.items())
        assert len(raw_shares) == len(events_list), "Mismatch between shares and events"

        for i, (event_id, event_meta) in enumerate(events_list):
            raw_share = raw_shares[i]
            # encrypt share with biometric key
            enc_share = self._encrypt_share(raw_share, biometric_key)
            self.shares[event_id] = {
                "encrypted_share": enc_share,
                "event_description": event_meta["description"],
                "recovery_question": event_meta["recovery_question"]
            }
        print(f"[Sharding] Generated {self.total_shares} shares (threshold={self.threshold}).")

    def reconstruct_secret(self, collected_shares: List[Tuple[str, str]]) -> str:
        """
        Given a list of (event_id, user_provided_encrypted_share) tuples,
        decrypt each share with the biometric key that is derived from
        the user’s current live EEG, then reconstruct the original secret.
        """
        if not self.biometric_key:
            raise ValueError("Biometric key not set. Call generate_shares() first.")

        # Decrypt each collected share
        raw_shares = []
        for event_id, enc_share in collected_shares:
            # check that the user has supplied a share belonging to a known event
            if event_id not in self.shares:
                print(f"[Recovery] Warning: unknown event {event_id} – skipping.")
                continue
            # verify that the encrypted share matches the stored one (simple integrity check)
            stored_enc = self.shares[event_id]["encrypted_share"]
            if enc_share != stored_enc:
                print(f"[Recovery] Integrity check failed for {event_id} – share may be altered.")
                continue
            decrypted = self._decrypt_share(enc_share, self.biometric_key)
            raw_shares.append(decrypted)

        if len(raw_shares) < self.threshold:
            raise ValueError(f"Only {len(raw_shares)} shares available, need {self.threshold}.")

        # Reconstruct via Lagrange interpolation
        reconstructed = reconstruct_text_secret(raw_shares)
        return reconstructed


# ----------------------------------------------------------------------
# 5. Blockchain anchoring (simulated, offline‑friendly)
# ----------------------------------------------------------------------

class MockBlockchain:
    """Simulates a Polygon identity anchor for offline testing."""

    def __init__(self):
        self.ledger = []

    def record(self, event_type: str, data: Dict[str, Any]) -> str:
        """Store an event as a dummy transaction (local hash only)."""
        tx = {
            "timestamp": time.time(),
            "type": event_type,
            "data": data,
            "hash": hashlib.md5(json.dumps(data, sort_keys=True).encode()).hexdigest()
        }
        self.ledger.append(tx)
        return tx["hash"]

    def verify(self, tx_hash: str) -> bool:
        """Check if a transaction exists in the local ledger."""
        return any(tx.get("hash") == tx_hash for tx in self.ledger)


