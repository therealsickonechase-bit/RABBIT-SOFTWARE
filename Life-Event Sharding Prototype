class BiometricKey:
    """Derive a 32‑byte key from live EEG (or a mock fixed value)."""

    @staticmethod
    def from_mock() -> bytes:
        """Mock biometric key for offline testing."""
        return b"mock_master_key_00000000000000000000000000000000"

    @staticmethod
    def from_eeg_stream(duration: float = 2.0) -> bytes:
        """
        Capture real EEG from Muse headset (if available) and hash it.
        Falls back to mock key if no headset is found.
        """
        if not REAL_EEG_AVAILABLE:
            print("[EEG] muselsl not installed – using mock key.")
            return BiometricKey.from_mock()

        try:
            # Discover first available Muse
            # (In a real implementation you would call muselsl.stream())
            print("[EEG] Attempting to connect to Muse headset...")
            # Here we simply simulate a reading; real code would collect raw data.
            mock_samples = b"live_eeg_data_placeholder"
            return hashlib.sha256(mock_samples).digest()
        except Exception as e:
            print(f"[EEG] Connection failed: {e}. Falling back to mock key.")
            return BiometricKey.from_mock()


