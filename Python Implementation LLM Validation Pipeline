import hashlib
from typing import Dict
from dataclasses import dataclass

@dataclass
class TransactionValidation:
    tx_hash: str
    crypto_valid: bool
    semantic_ok: bool
    risk_tier: str
    approved: bool
    explanation: str

class LLMBlockchainValidator:
    def __init__(self, dna_root_hash="8f3d9a612b718a990d442e7a1fb2c94d"):
        self.dna_root = dna_root_hash[:16]
        self.critical_events = {'overdose', 'ptsd', 'cardiac_arrest'}
        self.high_events = {'depression', 'isolation'}
    
    def validate(self, tx_data: Dict) -> TransactionValidation:
        """Full LLM + crypto validation"""
        
        # 1. Compute deterministic tx hash
        tx_serialized = str(sorted(tx_data.items()))
        tx_hash = hashlib.sha3_512(tx_serialized.encode()).hexdigest()
        
        # 2. DNA signature verification
        dna_sig = tx_data.get('dna_signature', '')
        crypto_valid = dna_sig.startswith(self.dna_root)
        
        # 3. LLM semantic risk analysis
        event = tx_data.get('event', '').lower()
        requester = tx_data.get('requester', '')
        
        risk_score = self._compute_risk(event, requester)
        semantic_ok = risk_score < 90
        
        # 4. Risk tier classification
        risk_tier = self._classify_risk(event)
        
        # 5. Final approval (conservative)
        approved = crypto_valid and semantic_ok and risk_tier != 'CRITICAL'
        
        explanation = (
            f"Event: {event} | Risk: {risk_score:.1f} | "
            f"Tier: {risk_tier} | DNA: {'✓' if crypto_valid else '✗'} | "
            f"{'APPROVED' if approved else 'BLOCKED'}"
        )
        
        return TransactionValidation(
            tx_hash=tx_hash[:16],
            crypto_valid=crypto_valid,
            semantic_ok=semantic_ok,
            risk_tier=risk_tier,
            approved=approved,
            explanation=explanation
        )
    
    def _compute_risk(self, event: str, requester: str) -> float:
        """Risk scoring (your DNA ranker)"""
        base_risk = 40.0
        
        if any(crit in event for crit in self.critical_events):
            base_risk = 97.0
        elif any(high in event for high in self.high_events):
            base_risk = 85.0
        
        # Requester risk multiplier
        requester_risk = {'insurance': 1.5, 'gov': 1.2, 'research': 0.8}
        multiplier = requester_risk.get(requester.split('_')[0], 1.0)
        
        return min(100, base_risk * multiplier)
    
    def _classify_risk(self, event: str) -> str:
        if any(crit in event for crit in self.critical_events):
            return 'CRITICAL'
        elif any(high in event for high in self.high_events):
            return 'HIGH'
        return 'LOW'

# Your production validator
validator = LLMBlockchainValidator()

# Example transactions
