$CLI = 'C:\Program Files\Bitcoin\daemon\bitcoin-cli.exe'
$BTC = { & $CLI @args }

# Node info
Write-Host ("🔗 Bitcoin Core: " + (& $CLI -version | Select-String -Pattern "\d\.\d+\.\d+"))
$currentHeight = ((& $CLI getblockchaininfo | ConvertFrom-Json).blocks)
Write-Host "📊 Current Height: $currentHeight" -ForegroundColor Green

# Hunt recent blocks for medical data
$start = [math]::Max(0, $currentHeight - 1000)
$end = $currentHeight

Write-Host "🩺 Scanning blocks $start → $end for medical research..." -ForegroundColor Cyan

1..10 | ForEach-Object {
    $height = $start + ($_ * 100)
    if ($height -le $end) {
        try {
            $hash = & $CLI getblockhash $height
            $block = & $CLI getblock $hash 1 | ConvertFrom-Json
            $txCount = $block.nTx
            
            Write-Host "Block $height ($hash`:~$txCount tx)" -NoNewline
            
            # Quick OP_RETURN check (first 5 tx)
            $hasMedical = $false
            0..4 | ForEach-Object {
                $txid = $block.tx[$_] 
                $rawtx = & $CLI getrawtransaction $txid 1 2>$null
                if ($rawtx -match "OP_RETURN.*(clinical|trial|genomic|research)") {
                    $hasMedical = $true
                }
            }
            
            if ($hasMedical) {
                Write-Host " 🎯 MEDICAL DATA!" -ForegroundColor Red
            } else {
                Write-Host " ➡️" -ForegroundColor Gray
            }
        }
        catch {
            Write-Host " ❌ $($_.Exception.Message)" -ForegroundColor Yellow
        }
    }
}
