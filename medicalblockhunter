param([int]$BlocksBack = 100, [int]$SampleTx = 5)

function Scan-Block-Medical($height) {
    $hash = bitcoin-cli getblockhash $height
    $block = bitcoin-cli getblock $hash 1 | ConvertFrom-Json
    $hits = @()
    
    0..($SampleTx-1) | ForEach-Object {
        $txid = $block.tx[$_] 
        try {
            $tx = bitcoin-cli getrawtransaction $txid 1 | ConvertFrom-Json
            $tx.vout | ForEach-Object {
                if ($_.scriptPubKey.asm -match "OP_RETURN") {
                    $asm = $_.scriptPubKey.asm
                    if ($asm -match "(clinical|trial|genomic|research|nih|fda|pubmed|patient|dna)") {
                        $hits += [PSCustomObject]@{
                            Height = $height
                            Hash = $hash.Substring(0,16)
                            TxID = $txid.Substring(0,16)
                            OP_RETURN = $asm
                        }
                    }
                }
            }
        } catch {}
    }
    return $hits
}

# MAIN SCAN
$current = (bitcoin-cli getblockchaininfo | ConvertFrom-Json).blocks
$scanRange = ($current - $BlocksBack)..$current

Write-Host "🩺 Scanning $BlocksBack blocks for medical research data..." -ForegroundColor Cyan

$allHits = @()
$scanRange | ForEach-Object { $allHits += Scan-Block-Medical $_ }

if ($allHits) {
    Write-Host "`n🎯 $($allHits.Count) MEDICAL BLOCKS FOUND!" -ForegroundColor Red
    $allHits | Format-Table -AutoSize
    $allHits | Export-Csv "medical_blocks_$(Get-Date -f 'yyyyMMdd').csv" -NoTypeInformation
} else {
    Write-Host "❌ No medical research blocks in range" -ForegroundColor Yellow
}
