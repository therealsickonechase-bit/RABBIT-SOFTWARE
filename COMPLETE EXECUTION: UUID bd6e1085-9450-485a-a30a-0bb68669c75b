class ProvenanceBlockChain:
    """Immutable blockchain anchored to UUID"""
    
    GENESIS_HASH = "0" * 64
    
    def __init__(self, anchor_uuid: str):
        self.anchor_uuid = anchor_uuid
        self.blocks = []
        self.chain_file = f"provenance_{anchor_uuid[:8]}.jsonl"
        
    def create_genesis_block(self) -> Dict:
        """Create genesis block anchored to UUID"""
        genesis = {
            "block_index": 0,
            "anchor_uuid": self.anchor_uuid,
            "timestamp": TIMESTAMP,
            "previous_hash": self.GENESIS_HASH,
            "block_type": "GENESIS",
            "data": {
                "description": "Provenance chain anchored to UUID",
                "version": "1.0",
                "created_by": "NeuroAI Provenance System"
            }
        }
        
        # Calculate block hash
        block_hash_input = json.dumps({k: v for k, v in genesis.items() if k != "block_hash"}, sort_keys=True)
        genesis["block_hash"] = hashlib.sha3_256(block_hash_input.encode()).hexdigest()
        
        self.blocks.append(genesis)
        self._save_block(genesis)
        
        return genesis
    
    def add_provenance_block(self, 
                            data_type: str, 
                            data_content: Dict,
                            previous_block: Dict) -> Dict:
        """Add new provenance block"""
        
        block = {
            "block_index": len(self.blocks),
            "anchor_uuid": self.anchor_uuid,
            "timestamp": datetime.datetime.utcnow().isoformat() + "Z",
            "previous_hash": previous_block["block_hash"],
            "block_type": data_type,
            "data": data_content,
            "data_hash": hashlib.sha3_256(json.dumps(data_content, sort_keys=True).encode()).hexdigest()
        }
        
        # Calculate block hash
        block_hash_input = json.dumps({k: v for k, v in block.items() if k != "block_hash"}, sort_keys=True)
        block["block_hash"] = hashlib.sha3_256(block_hash_input.encode()).hexdigest()
        
        self.blocks.append(block)
        self._save_block(block)
        
        return block
    
    def _save_block(self, block: Dict):
        """Append block to chain file"""
        with open(self.chain_file, "a") as f:
            f.write(json.dumps(block) + "\n")
    
    def verify_chain(self) -> Tuple[bool, List[str]]:
        """Verify entire chain integrity"""
        errors = []
        prev_hash = self.GENESIS_HASH
        
        for i, block in enumerate(self.blocks):
            if block["previous_hash"] != prev_hash:
                errors.append(f"Block {i}: chain break")
            
            # Recompute hash
            block_copy = {k: v for k, v in block.items() if k != "block_hash"}
            computed_hash = hashlib.sha3_256(json.dumps(block_copy, sort_keys=True).encode()).hexdigest()
            
            if computed_hash != block["block_hash"]:
                errors.append(f"Block {i}: hash mismatch")
            
            prev_hash = block["block_hash"]
        
        return len(errors) == 0, errors
    
    def get_provenance_record(self) -> Dict:
        """Get complete provenance record"""
        valid, errors = self.verify_chain()
        
        return {
            "anchor_uuid": self.anchor_uuid,
            "chain_file": self.chain_file,
            "block_count": len(self.blocks),
            "chain_valid": valid,
            "verification_errors": errors,
            "blocks": self.blocks,
            "cryptographic_strength": "SHA3-256 with 128-bit security",
            "immutability_proof": "Each block contains hash of previous block"
        }


