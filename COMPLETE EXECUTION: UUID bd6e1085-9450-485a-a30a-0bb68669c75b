class EEGSession:
    """Complete EEG session using UUID as primary identifier"""
    
    def __init__(self, session_uuid: str):
        self.session_uuid = session_uuid
        self.created_at = TIMESTAMP
        self.status = "initialized"
        self.blocks = []
        self.metadata = {}
        
    def create_session_record(self) -> Dict:
        """Create the session record"""
        session_record = {
            "session_uuid": self.session_uuid,
            "created_at": self.created_at,
            "status": self.status,
            "pipeline_version": "3.0",
            "components": [
                "EEG Acquisition",
                "Signal Processing",
                "Binary Tokenization",
                "LLM Analysis",
                "Blockchain Provenance"
            ],
            "session_hash": hashlib.sha3_256(
                f"{self.session_uuid}_{self.created_at}".encode()
            ).hexdigest()
        }
        
        # Save session record
        with open(f"session_{self.session_uuid[:8]}.json", "w") as f:
            json.dump(session_record, f, indent=2)
        
        return session_record
    
    def add_acquisition_data(self, channel: int, duration_ms: float) -> Dict:
        """Add EEG acquisition data to session"""
        
        # Simulate EEG signal (realistic alpha rhythm)
        fs = 256  # Hz
        n = int(fs * duration_ms / 1000)
        t = np.linspace(0, duration_ms / 1000, n)
        
        # Generate EEG with alpha dominance
        alpha_freq = 9.8
        signal = 25.0 * np.sin(2 * np.pi * alpha_freq * t)
        signal += 10.0 * np.random.normal(0, 1, n)
        
        acquisition = {
            "session_uuid": self.session_uuid,
            "channel": channel,
            "channel_name": self._get_channel_name(channel),
            "duration_ms": duration_ms,
            "sample_rate_hz": fs,
            "samples": n,
            "signal_preview": signal[:50].tolist(),
            "signal_hash": hashlib.sha3_256(signal.tobytes()).hexdigest()[:16],
            "timestamp": datetime.datetime.utcnow().isoformat() + "Z"
        }
        
        self.blocks.append(acquisition)
        return acquisition
    
    def _get_channel_name(self, channel: int) -> str:
        """Get standard EEG 10-20 channel name"""
        channels = ["Fp1", "Fp2", "F3", "F4", "C3", "C4", "P3", "P4", 
                    "O1", "O2", "F7", "F8", "T3", "T4", "T5", "T6"]
        return channels[channel] if channel < len(channels) else f"CH{channel}"
    
    def get_complete_session(self) -> Dict:
        """Get complete session data"""
        return {
            "session_uuid": self.session_uuid,
            "created_at": self.created_at,
            "status": self.status,
            "block_count": len(self.blocks),
            "blocks": self.blocks,
            "session_hash": hashlib.sha3_256(
                json.dumps(self.blocks, sort_keys=True).encode()
            ).hexdigest()
        }


