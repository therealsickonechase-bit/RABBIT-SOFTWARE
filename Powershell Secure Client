# SecureMedicalBlockNet.ps1
$apiUrl = "http://localhost:8000"
$apiKey = (Invoke-RestMethod -Uri "$apiUrl/api-key").api_key

function New-SecureShard {
    param($OwnerId, $DataHash, $BtcHeight)
    
    $shard = @{
        owner_id = $OwnerId
        data_hash = $DataHash
        btc_height = $BtcHeight
        signature = "ecdsasig..."  # Generate real ECDSA
    } | ConvertTo-Json
    
    Invoke-RestMethod -Uri "$apiUrl/shard/register" -Method POST -Body $shard `
        -Headers @{Authorization="Bearer $apiKey"} -ContentType "application/json"
}

# Launch secure network
Start-Process python "medical_blocknet_secure.py"
Start-Sleep 3

