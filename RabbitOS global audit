class AuditEvent:
    def __init__(self, event_type, actor, domain, payload):
        self.event_type = event_type
        self.actor = actor
        self.domain = domain
        self.payload_hash = hash(str(payload))
        self.timestamp = time.time()


---

⛓️ BLOCKCHAIN ANCHOR LAYER

class AuditChain:

    def __init__(self):
        self.chain = []

    def add_event(self, event):
        block = {
            "index": len(self.chain),
            "event_hash": event.payload_hash,
            "prev_hash": self.chain[-1]["hash"] if self.chain else "GENESIS",
        }
        self.chain.append(block)
        return block


