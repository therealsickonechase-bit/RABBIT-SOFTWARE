            if aa in ['Met', 'Leu', 'Ile']:  # Hydrophobic
                effect['sensitivity_modulation'] += 0.05
            elif aa in ['Lys', 'Arg', 'His']:  # Basic
                effect['frequency_drift'] += 0.001
            elif aa in ['Asp', 'Glu']:  # Acidic
                effect['memory_retention'] -= 0.02
        
        return effect
    
