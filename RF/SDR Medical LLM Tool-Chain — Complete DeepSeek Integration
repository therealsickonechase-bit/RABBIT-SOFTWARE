    def call_tool(self, name: str, arguments: Dict) -> Dict:
        """Dispatch tool calls to appropriate handler"""
        handlers = {
            "read_sensor": self._read_sensor,
            "analyze_spectrum": self._analyze_spectrum,
            "apply_bandpass_filter": self._apply_bandpass,
            "remove_mains_noise": self._remove_mains,
            "detect_anomalies": self._detect_anomalies,
            "detect_artifacts": self._detect_artifacts,
            "check_impedance": self._check_impedance,
            "calculate_clinical_indices": self._calculate_indices,
            "set_amplifier_gain": self._set_gain,
            "generate_clinical_report": self._generate_report,
            "scan_available_ports": self._scan_ports,
            "get_device_status": self._get_status
        }
       
        handler = handlers.get(name)
        if handler is None:
            return {"error": f"Unknown tool: {name}"}
       
        try:
            result = handler(**arguments)
            return result
        except Exception as e:
            return {"error": str(e)}
   
    # ===== Tool Implementations =====
   
    def _read_sensor(self, channel: int, duration_ms: float) -> Dict:
        reading = self.device.read_signal(channel, min(duration_ms, 10000))
        self._last_reading = reading
        self._session_data.append(reading)
       
        signal_array = reading.to_numpy()
        return {
            "success": True,
            "channel": channel,
            "channel_name": reading.metadata.get("channel_name", f"CH{channel}"),
            "samples": len(reading.signal_raw),
            "sample_rate_hz": reading.sample_rate_hz,
            "duration_ms": duration_ms,
            "rms_uv": round(np.sqrt(np.mean(signal_array ** 2)), 3),
            "peak_uv": round(np.max(np.abs(signal_array)), 3),
            "mean_uv": round(np.mean(signal_array), 3),
            "data_hash": reading.get_hash(),
            "timestamp": reading.timestamp
        }
   
    def _analyze_spectrum(self) -> Dict:
        if self._last_reading is None:
            return {"error": "No reading available. Call read_sensor first."}
       
        spectral = self.processor.spectral_analysis(self._last_reading)
       
        return {
            "peak_frequency_hz": spectral.peak_freq,
            "peak_power": spectral.peak_power,
            "snr_db": spectral.snr_db,
            "total_power": spectral.total_power,
            "median_frequency_hz": spectral.median_freq,
            "spectral_edge_hz": spectral.spectral_edge,
            "band_powers": spectral.bands,
            "dominant_band": max(spectral.bands, key=spectral.bands.get),
            "theta_alpha_ratio": round(spectral.bands.get("theta", 1) / (spectral.bands.get("alpha", 1) + 1e-6), 3)
        }
   
    def _apply_bandpass(self, low_hz: float, high_hz: float, order: int = 4) -> Dict:
        if self._last_reading is None:
            return {"error": "No reading available"}
       
        result = self.processor.apply_bandpass_filter(self._last_reading, low_hz, high_hz, order)
        self._last_reading.signal_raw = result.signal_filtered
       
        return {
            "filter": result.filter_type,
            "cutoff_hz": result.cutoff_hz,
            "order": result.order,
            "rms_before_uv": result.rms_before,
            "rms_after_uv": result.rms_after,
            "attenuation_db": result.attenuation_db,
            "noise_reduction_percent": round((1 - result.rms_after / (result.rms_before + 1e-6)) * 100, 1)
        }
   
    def _remove_mains(self, notch_hz: float) -> Dict:
        if self._last_reading is None:
            return {"error": "No reading available"}
       
        result = self.processor.apply_notch_filter(self._last_reading, notch_hz)
        self._last_reading.signal_raw = result.signal_filtered
       
        return {
            "notch_frequency_hz": notch_hz,
            "rms_after_uv": result.rms_after,
            "attenuation_db": result.attenuation_db
        }
   
    def _detect_anomalies(self) -> Dict:
        if self._last_reading is None:
            return {"error": "No reading available"}
       
        report = self.processor.detect_epileptiform_activity(self._last_reading)
        return {
            "detected": report.detected,
            "anomaly_type": report.anomaly_type,
            "confidence": report.confidence,
            "spike_count": len(report.segments),
            "affected_channels": report.affected_channels,
            "recommendation": report.recommendation,
            "clinical_significance": report.clinical_significance,
            "first_spike_ms": report.segments[0]["time_ms"] if report.segments else None
        }
   
    def _detect_artifacts(self) -> Dict:
        if self._last_reading is None:
            return {"error": "No reading available"}
       
        report = self.processor.detect_artifacts(self._last_reading)
        return {
            "artifacts_present": report.detected,
            "artifact_types": [s["type"] for s in report.segments],
            "confidence": report.confidence,
            "recommendation": report.recommendation
        }
   
    def _check_impedance(self, channel: int) -> Dict:
        return self.device.get_impedance(channel)
   
    def _calculate_indices(self) -> Dict:
        if self._last_reading is None:
            return {"error": "No reading available"}
       
        spectral = self.processor.spectral_analysis(self._last_reading)
        indices = self.processor.calculate_clinical_indices(self._last_reading, spectral)
       
        return {
            **indices,
            "recommendation": "Patient appears drowsy" if indices["theta_alpha_ratio"] > 1.5 else "Normal alertness"
        }
   
    def _set_gain(self, gain_db: float) -> Dict:
        return self.device.set_gain(gain_db)
   
    def _generate_report(self, patient_id: str, clinician_notes: str = "") -> Dict:
        report_id = f"RPT-{patient_id}-{int(time.time())}"
        spectral = None
       
        if self._last_reading:
            spectral = self.processor.spectral_analysis(self._last_reading)
       
        report = {
            "report_id": report_id,
            "patient_id": patient_id,
            "generated_at": datetime.datetime.utcnow().isoformat() + "Z",
            "device_id": self.device.device_type,
            "sessions_recorded": len(self._session_data),
            "last_channel": self._last_reading.channel if self._last_reading else None,
            "signal_quality": "ACCEPTABLE" if (self._last_reading and len(self._last_reading.signal_raw) > 0) else "NO_DATA",
            "clinician_notes": clinician_notes,
            "spectral_summary": {
                "dominant_frequency": spectral.peak_freq if spectral else None,
                "dominant_band": max(spectral.bands, key=spectral.bands.get) if spectral else None
            } if spectral else None
        }
       
        return report
   
    def _scan_ports(self) -> Dict:
        ports = self.device.scan_ports()
        return {"available_ports": ports, "count": len(ports)}
   
    def _get_status(self) -> Dict:
        return {
            "connected": self.device._connected,
            "device_type": self.device.device_type,
            "channels": self.device.spec["channels"],
            "sample_rate_hz": self.device.spec["sample_rate"],
            "frequency_range_hz": self.device.spec["freq_range"],
            "protocol": self.device.spec["protocol"],
            "simulation_mode": not self.device._connected,
            "session_duration_sec": len(self._session_data) * (self._session_data[0].duration_ms / 1000) if self._session_data else 0
        }

