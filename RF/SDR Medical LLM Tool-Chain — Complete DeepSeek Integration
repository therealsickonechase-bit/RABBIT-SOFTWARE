def run_cli(agent: DeepSeekMedicalAgent):
    """Interactive command-line interface"""
    console.rule("[bold cyan]🧠 NeuroAI: RF/SDR Medical LLM Tool-Chain[/bold cyan]")
    console.print()
    console.print("[dim]Connected to:[/dim] " + agent.registry.device.device_type)
    console.print("[dim]Commands:[/dim] type your request, 'reset', 'status', or 'quit'")
    console.print()
   
    # Example prompts
    examples = [
        "Read 2 seconds from channel 0 and analyze spectrum",
        "Check electrode impedance on channels 0, 1, and 2",
        "Apply bandpass filter 1-40 Hz and detect anomalies",
        "Generate a clinical report for patient PARK-001",
        "What is the dominant brain rhythm in the last reading?"
    ]
   
    console.print("[bold]Example queries:[/bold]")
    for i, ex in enumerate(examples, 1):
        console.print(f"  {i}. {ex}")
    console.print()
   
    while True:
        try:
            user_input = input("You: ").strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\n[yellow]Goodbye![/yellow]")
            break
       
        if not user_input:
            continue
       
        if user_input.lower() in ["quit", "exit", "q"]:
            console.print("[yellow]Shutting down...[/yellow]")
            break
       
        if user_input.lower() == "reset":
            agent.reset_session()
            console.print("[green]Session reset.[/green]")
            continue
       
        if user_input.lower() == "status":
            status = agent.registry.call_tool("get_device_status", {})
            console.print(f"[cyan]Device: {status['device_type']}[/cyan]")
            console.print(f"  Connected: {status['connected']}")
            console.print(f"  Channels: {status['channels']}")
            console.print(f"  Sample Rate: {status['sample_rate_hz']} Hz")
            continue
       
        # Handle numeric shortcuts
        if user_input.isdigit() and 1 <= int(user_input) <= len(examples):
            user_input = examples[int(user_input) - 1]
            console.print(f"[dim]→ {user_input}[/dim]")
       
        with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"), transient=True) as progress:
            progress.add_task(description="Processing...", total=None)
            response = agent.chat(user_input)
       
        console.print(f"\n[bold cyan]NeuroAI:[/bold cyan] {response}\n")
        console.rule()

