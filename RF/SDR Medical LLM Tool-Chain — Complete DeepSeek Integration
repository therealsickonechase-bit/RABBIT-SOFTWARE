class DeepSeekMedicalAgent:
    """
    AI agent that connects DeepSeek LLM to medical RF/SDR instruments
    Enables natural language control of medical devices
    """
   
    def __init__(self, tool_registry: ToolRegistry, api_key: str = DEEPSEEK_API_KEY):
        self.registry = tool_registry
        self.api_key = api_key
        self.conversation_history: List[Dict] = []
        self.client = None
       
        if HAS_OPENAI and api_key and api_key != "YOUR_DEEPSEEK_API_KEY":
            self.client = OpenAI(api_key=api_key, base_url=DEEPSEEK_BASE_URL)
            console.print("[green]✅ DeepSeek API connected[/green]")
        else:
            console.print("[yellow]⚠️ DeepSeek API not configured — using local fallback[/yellow]")
            self.client = None
   
    def chat(self, user_message: str, max_tool_rounds: int = 10) -> str:
        """
        Process user message with tool-calling loop
        Returns final response from DeepSeek
        """
        self.conversation_history.append({"role": "user", "content": user_message})
        messages = [
            {"role": "system", "content": SYSTEM_PROMPT},
            *self.conversation_history
        ]
       
        for round_num in range(max_tool_rounds):
            if self.client is None:
                # Fallback: direct response without tools
                response_text = self._local_fallback_response(user_message)
                self.conversation_history.append({"role": "assistant", "content": response_text})
                return response_text
           
            try:
                response = self.client.chat.completions.create(
                    model=DEEPSEEK_MODEL,
                    messages=messages,
                    tools=self.registry.tool_schemas,
                    tool_choice="auto",
                    temperature=0.7,
                    max_tokens=1000
                )
            except Exception as e:
                console.print(f"[red]API Error: {e}[/red]")
                response_text = f"Error connecting to DeepSeek: {str(e)}"
                self.conversation_history.append({"role": "assistant", "content": response_text})
                return response_text
           
            message = response.choices[0].message
           
            # No tool calls → return final response
            if not message.tool_calls:
                final_response = message.content or "Processing complete."
                self.conversation_history.append({"role": "assistant", "content": final_response})
                return final_response
           
            # Execute tool calls
            messages.append(message)
            for tool_call in message.tool_calls:
                function_name = tool_call.function.name
                arguments = json.loads(tool_call.function.arguments)
               
                console.print(f"[cyan]🔧 Calling: {function_name}({arguments})[/cyan]")
                result = self.registry.call_tool(function_name, arguments)
                console.print(f"[green]   → {result.get('success', True)}[/green]")
               
                messages.append({
                    "role": "tool",
                    "tool_call_id": tool_call.id,
                    "content": json.dumps(result)
                })
       
        return "Max tool rounds reached. Please refine your request."
   
    def _local_fallback_response(self, message: str) -> str:
        """Provide realistic responses when DeepSeek API unavailable"""
        message_lower = message.lower()
       
        if "read" in message_lower and "sensor" in message_lower:
            result = self.registry.call_tool("read_sensor", {"channel": 0, "duration_ms": 2000})
            return f"📊 Sensor reading: RMS {result.get('rms_uv', 0)}µV, Peak {result.get('peak_uv', 0)}µV. {result.get('samples', 0)} samples at {result.get('sample_rate_hz', 0)}Hz."
       
        elif "fft" in message_lower or "spectrum" in message_lower:
            result = self.registry.call_tool("analyze_spectrum", {})
            if "error" in result:
                return "No data available. Please read a sensor first."
            return f"📈 Spectral analysis: Peak at {result['peak_frequency_hz']}Hz ({result['dominant_band']} band). SNR: {result['snr_db']}dB."
       
        elif "report" in message_lower:
            result = self.registry.call_tool("generate_clinical_report", {"patient_id": "DEMO-001"})
            return f"📋 Clinical report generated: {result['report_id']}. {result.get('sessions_recorded', 0)} sessions recorded."
       
        elif "impedance" in message_lower:
            result = self.registry.call_tool("check_impedance", {"channel": 0})
            return f"⚡ Channel {result['channel']} ({result.get('channel_name', 'unknown')}): {result['impedance_ohms']}Ω - {result['quality']} quality."
       
        else:
            return (f"I can help with medical RF/SDR signal analysis.\n\n"
                   f"Available commands:\n"
                   f"  • 'Read sensor on channel 0 for 2 seconds'\n"
                   f"  • 'Run FFT analysis'\n"
                   f"  • 'Check electrode impedance'\n"
                   f"  • 'Generate clinical report for patient XYZ'\n"
                   f"  • 'Detect anomalies or artifacts'\n\n"
                   f"Current device: {self.registry.device.device_type}")
   
    def reset_session(self):
        """Clear conversation history"""
        self.conversation_history = []
        console.print("[yellow]🔄 Session reset[/yellow]")

