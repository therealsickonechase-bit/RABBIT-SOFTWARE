class MedicalDeviceManager:
    """
    Manages connections to medical RF/SDR devices
    Supports: NeuroMind, EEG caps, ECG monitors, SDR receivers
    """
   
    SUPPORTED_DEVICES = {
        "neuromind_v2": {
            "channels": 8, "sample_rate": 256, "freq_range": [0.5, 100],
            "protocol": "serial", "baudrate": 115200
        },
        "neuromind_v3": {
            "channels": 16, "sample_rate": 512, "freq_range": [0.5, 150],
            "protocol": "serial", "baudrate": 115200
        },
        "neuro_avatar": {
            "channels": 32, "sample_rate": 1000, "freq_range": [0.1, 300],
            "protocol": "websocket", "port": 8765
        },
        "openbci_cyton": {
            "channels": 8, "sample_rate": 250, "freq_range": [0.5, 100],
            "protocol": "serial", "baudrate": 115200
        },
        "muse_2": {
            "channels": 4, "sample_rate": 256, "freq_range": [1, 50],
            "protocol": "bluetooth", "baudrate": None
        },
        "sdr_dna": {
            "channels": 1, "sample_rate": 2000000, "freq_range": [1000000, 2000000000],
            "protocol": "usb", "baudrate": None
        }
    }
   
    # EEG 10-20 channel mapping
    EEG_CHANNELS = ["Fp1", "Fp2", "F3", "F4", "C3", "C4", "P3", "P4",
                    "O1", "O2", "F7", "F8", "T3", "T4", "T5", "T6", "Fz", "Cz", "Pz"]
   
    def __init__(self, device_type: str = "neuromind_v2", port: Optional[str] = None):
        self.device_type = device_type
        self.port = port
        self.spec = self.SUPPORTED_DEVICES.get(device_type, self.SUPPORTED_DEVICES["neuromind_v2"])
        self._serial = None
        self._connected = False
        self._connect()
       
        console.print(f"[cyan]📡 Medical Device Manager: {device_type}[/cyan]")
   
    def _connect(self):
        """Establish connection to medical device"""
        if self.port and HAS_SERIAL and self.spec["protocol"] == "serial":
            try:
                self._serial = serial.Serial(
                    self.port,
                    baudrate=self.spec["baudrate"],
                    timeout=1
                )
                self._connected = True
                console.print(f"[green]✓ Connected to {self.device_type} on {self.port}[/green]")
                return
            except Exception as e:
                console.print(f"[yellow]⚠ Serial failed: {e} — using simulation[/yellow]")
       
        console.print(f"[blue]ℹ Simulation mode: {self.device_type}[/blue]")
        self._connected = False
   
    def scan_ports(self) -> List[str]:
        """Scan available serial ports for medical devices"""
        if not HAS_SERIAL:
            return []
        ports = serial.tools.list_ports.comports()
        return [p.device for p in ports]
   
    def read_signal(self, channel: int, duration_ms: float) -> SensorReading:
        """
        Read signal from medical device
        Returns realistic EEG/ECG/MMG data with clinical characteristics
        """
        n_samples = int(self.spec["sample_rate"] * duration_ms / 1000)
        t = np.linspace(0, duration_ms / 1000, n_samples)
       
        if self._connected and self._serial:
            signal = self._read_hardware(channel, n_samples)
        else:
            signal = self._simulate_medical_signal(t, channel)
       
        return SensorReading(
            device_id=self.device_type,
            device_type=self._get_signal_type(),
            timestamp=datetime.datetime.utcnow().isoformat() + "Z",
            channel=channel,
            sample_rate_hz=self.spec["sample_rate"],
            duration_ms=duration_ms,
            signal_raw=signal.tolist(),
            unit="µV",
            metadata={"simulated": not self._connected, "channel_name": self._get_channel_name(channel)}
        )
   
    def _read_hardware(self, channel: int, n_samples: int) -> np.ndarray:
        """Read raw data from physical device"""
        if not self._serial:
            return np.random.normal(0, 10, n_samples)
       
        cmd = struct.pack(">BBH", 0xA5, channel, n_samples)
        self._serial.write(cmd)
        raw_bytes = self._serial.read(n_samples * 4)
        if len(raw_bytes) >= n_samples * 4:
            return np.frombuffer(raw_bytes[:n_samples*4], dtype=np.float32)
        return np.random.normal(0, 10, n_samples)
   
    def _simulate_medical_signal(self, t: np.ndarray, channel: int) -> np.ndarray:
        """
        Generate clinically realistic signals
        - EEG: alpha, beta, theta, delta rhythms
        - ECG: P-QRS-T complex
        - MMG: muscle vibration patterns
        """
        rng = np.random.default_rng(channel + int(time.time()) % 1000)
       
        if self.device_type in ["neuromind_v2", "neuromind_v3", "openbci_cyton", "muse_2"]:
            # EEG simulation with physiological rhythms
            alpha_freq = 8 + rng.uniform(-2, 2)
            beta_freq = 18 + rng.uniform(-3, 3)
            theta_freq = 5 + rng.uniform(-1, 1)
            delta_freq = 1.5 + rng.uniform(-0.5, 0.5)
           
            signal = (
                15.0 * np.sin(2 * np.pi * delta_freq * t) +   # Delta (deep sleep)
                12.0 * np.sin(2 * np.pi * theta_freq * t) +   # Theta (drowsiness)
                25.0 * np.sin(2 * np.pi * alpha_freq * t) +   # Alpha (relaxed)
                8.0 * np.sin(2 * np.pi * beta_freq * t) +     # Beta (active)
                4.0 * np.random.normal(0, 1, len(t))          # Background noise
            )
           
            # Add channel-specific variation
            signal *= (0.8 + 0.4 * channel / self.spec["channels"])
           
            # Simulate eye blinks (large frontal spikes)
            if channel < 2 and rng.random() < 0.1:
                blink_idx = rng.integers(0, len(t))
                signal[blink_idx:blink_idx+50] += 80 * np.exp(-np.arange(50)/10)
           
        elif self.device_type == "sdr_dna":
            # DNA resonance simulation (GHz RF)
            resonance_freq = 10.23e9
            signal = np.sin(2 * np.pi * resonance_freq * t / 1e9)
            signal += 0.1 * np.random.normal(0, 1, len(t))
        else:
            # Generic medical signal
            signal = 10 * np.sin(2 * np.pi * 10 * t) + 5 * np.random.normal(0, 1, len(t))
       
        return signal
   
    def _get_signal_type(self) -> SignalType:
        """Determine signal type from device"""
        if "eeg" in self.device_type or "mind" in self.device_type or self.device_type in ["muse_2", "openbci_cyton"]:
            return SignalType.EEG
        elif "ecg" in self.device_type:
            return SignalType.ECG
        elif "emg" in self.device_type:
            return SignalType.EMG
        elif "dna" in self.device_type:
            return SignalType.DNA_RF
        else:
            return SignalType.EEG
   
    def _get_channel_name(self, channel: int) -> str:
        """Get standard EEG channel name (10-20 system)"""
        if self.device_type in ["neuromind_v2", "neuromind_v3"]:
            if channel < len(self.EEG_CHANNELS):
                return self.EEG_CHANNELS[channel]
        return f"CH{channel}"
   
    def set_gain(self, gain_db: float) -> Dict:
        """Set amplifier gain"""
        if self._connected and self._serial:
            self._serial.write(struct.pack(">Bf", 0xA6, gain_db))
        return {"status": "ok", "gain_db": gain_db}
   
    def get_impedance(self, channel: int) -> Dict:
        """Check electrode impedance"""
        if self._connected and self._serial:
            self._serial.write(struct.pack(">BB", 0xA8, channel))
            raw = self._serial.read(4)
            ohms = struct.unpack(">f", raw)[0] if len(raw) >= 4 else 10000
        else:
            # Simulate impedance (good: <5kΩ, fair: 5-20kΩ, poor: >20kΩ)
            ohms = np.random.uniform(1000, 50000)
       
        quality = "GOOD" if ohms < 5000 else ("FAIR" if ohms < 20000 else "POOR")
        return {"channel": channel, "channel_name": self._get_channel_name(channel),
                "impedance_ohms": round(ohms, 1), "quality": quality}

