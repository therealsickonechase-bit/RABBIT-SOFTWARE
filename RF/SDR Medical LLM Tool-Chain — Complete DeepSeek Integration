class WebSocketServer:
    """WebSocket server for remote medical device control"""
   
    def __init__(self, agent: DeepSeekMedicalAgent, host: str = "0.0.0.0", port: int = 8765):
        self.agent = agent
        self.host = host
        self.port = port
        self.connected_clients = set()
   
    async def start(self):
        """Start WebSocket server"""
        try:
            import websockets
        except ImportError:
            console.print("[red]websockets not installed. Run: pip install websockets[/red]")
            return
       
        async def handler(websocket, path):
            self.connected_clients.add(websocket)
            console.print(f"[green]Client connected: {websocket.remote_address}[/green]")
           
            try:
                async for message in websocket:
                    try:
                        data = json.loads(message)
                        command = data.get("command", data.get("message", ""))
                       
                        if command:
                            response = self.agent.chat(command)
                            await websocket.send(json.dumps({
                                "type": "response",
                                "content": response,
                                "timestamp": time.time()
                            }))
                        elif data.get("reset"):
                            self.agent.reset_session()
                            await websocket.send(json.dumps({"type": "reset", "status": "ok"}))
                        else:
                            await websocket.send(json.dumps({"type": "error", "message": "Unknown command"}))
                   
                    except json.JSONDecodeError:
                        await websocket.send(json.dumps({"type": "error", "message": "Invalid JSON"}))
           
            except websockets.exceptions.ConnectionClosed:
                pass
            finally:
                self.connected_clients.remove(websocket)
                console.print(f"[yellow]Client disconnected[/yellow]")
       
        async with websockets.serve(handler, self.host, self.port):
            console.print(f"[bold green]🌐 WebSocket server running on ws://{self.host}:{self.port}[/bold green]")
            await asyncio.Future()  # Run forever

