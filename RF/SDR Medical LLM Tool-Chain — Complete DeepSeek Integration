class MedicalSignalProcessor:
    """
    Clinical signal processing for medical RF/SDR data
    Implements validated algorithms for:
    - EEG spectral analysis (theta/alpha ratio, peak frequency)
    - Artifact detection (eye blinks, muscle, electrode pops)
    - Seizure detection (spike-wave complexes)
    - Cardiac arrhythmia detection
    """
   
    # EEG frequency bands (clinical definitions)
    EEG_BANDS = {
        "delta": (0.5, 4.0),   # Deep sleep, infants
        "theta": (4.0, 8.0),   # Drowsiness, meditation
        "alpha": (8.0, 13.0),  # Relaxed wakefulness
        "beta": (13.0, 30.0),  # Active thinking, anxiety
        "gamma": (30.0, 100.0) # Higher cognitive processing
    }
   
    # Clinical thresholds
    SPIKE_THRESHOLD_SD = 4.5      # Spike detection (4.5 standard deviations)
    SHARP_WAVE_DURATION_MS = 70    # Sharp wave duration (70-200ms)
    SUPPRESSION_THRESHOLD_UV = 5   # Burst suppression amplitude
   
    def __init__(self):
        console.print("[cyan]🔬 Medical Signal Processor initialized[/cyan]")
   
    def spectral_analysis(self, reading: SensorReading) -> SpectralResult:
        """
        Clinical spectral analysis with power spectral density
        Returns band powers, peak frequency, SNR
        """
        signal = reading.to_numpy()
        fs = reading.sample_rate_hz
        n = len(signal)
       
        # Apply Hanning window to reduce spectral leakage
        window = np.hanning(n)
        signal_windowed = signal * window
       
        # Compute FFT
        fft_vals = fft(signal_windowed)
        psd = (np.abs(fft_vals[:n//2]) ** 2) / (fs * (window ** 2).sum())
        freqs = fftfreq(n, 1/fs)[:n//2]
       
        # Calculate band powers
        bands = {}
        for band, (low, high) in self.EEG_BANDS.items():
            mask = (freqs >= low) & (freqs <= high)
            if np.any(mask):
                bands[band] = float(np.trapz(psd[mask], freqs[mask]))
            else:
                bands[band] = 0.0
       
        # Find peak frequency (1-50 Hz range for clinical EEG)
        clinical_mask = (freqs >= 1) & (freqs <= 50)
        if np.any(clinical_mask):
            peak_idx = np.argmax(psd[clinical_mask])
            peak_freq = float(freqs[clinical_mask][peak_idx])
            peak_power = float(psd[clinical_mask][peak_idx])
        else:
            peak_freq = 0.0
            peak_power = 0.0
       
        # Calculate SNR (signal to noise ratio)
        signal_power = np.sum(psd[(freqs >= 0.5) & (freqs <= 30)])
        noise_power = np.mean(psd[-20:]) * len(psd) if len(psd) > 20 else signal_power * 0.1
        snr = 10 * np.log10(signal_power / (noise_power + 1e-12))
       
        # Median frequency (50% power)
        cumulative_power = np.cumsum(psd)
        total_power = cumulative_power[-1]
        if total_power > 0:
            median_idx = np.searchsorted(cumulative_power, total_power / 2)
            median_freq = freqs[median_idx] if median_idx < len(freqs) else 0
        else:
            median_freq = 0
       
        # Spectral edge frequency (95% power)
        edge_idx = np.searchsorted(cumulative_power, total_power * 0.95)
        spectral_edge = freqs[edge_idx] if edge_idx < len(freqs) else 0
       
        return SpectralResult(
            freqs=freqs[:200].tolist(),
            psd=psd[:200].tolist(),
            bands={k: round(v, 4) for k, v in bands.items()},
            peak_freq=round(peak_freq, 2),
            peak_power=round(peak_power, 4),
            snr_db=round(snr, 2),
            total_power=round(total_power, 4),
            median_freq=round(median_freq, 2),
            spectral_edge=round(spectral_edge, 2)
        )
   
    def apply_bandpass_filter(self, reading: SensorReading, low_hz: float,
                              high_hz: float, order: int = 4) -> FilterResult:
        """Clinical bandpass filter (Butterworth)"""
        signal = reading.to_numpy()
        fs = reading.sample_rate_hz
        nyq = fs / 2.0
       
        # Calculate RMS before filtering
        rms_before = np.sqrt(np.mean(signal ** 2))
       
        if HAS_SCIPY and low_hz < nyq and high_hz < nyq:
            b, a = sp_signal.butter(order, [low_hz / nyq, high_hz / nyq], btype="band")
            filtered = sp_signal.filtfilt(b, a, signal)
        else:
            # Simple moving average fallback for clinical contexts
            window_size = int(fs / ((low_hz + high_hz) / 2))
            window_size = max(3, min(window_size, len(signal) // 4))
            kernel = np.ones(window_size) / window_size
            filtered = np.convolve(signal, kernel, mode='same')
       
        rms_after = np.sqrt(np.mean(filtered ** 2))
        attenuation = 20 * np.log10((rms_after + 1e-12) / (rms_before + 1e-12))
       
        return FilterResult(
            filter_type="butterworth_bandpass",
            cutoff_hz=[low_hz, high_hz],
            order=order,
            signal_filtered=filtered.tolist(),
            rms_before=round(float(rms_before), 4),
            rms_after=round(float(rms_after), 4),
            attenuation_db=round(float(attenuation), 2)
        )
   
    def apply_notch_filter(self, reading: SensorReading, notch_hz: float = 50.0,
                           q: float = 30.0) -> FilterResult:
        """Remove mains interference (50/60 Hz)"""
        signal = reading.to_numpy()
        fs = reading.sample_rate_hz
        rms_before = np.sqrt(np.mean(signal ** 2))
       
        if HAS_SCIPY and notch_hz < fs / 2:
            b, a = sp_signal.iirnotch(notch_hz, q, fs)
            filtered = sp_signal.filtfilt(b, a, signal)
        else:
            filtered = signal.copy()
       
        rms_after = np.sqrt(np.mean(filtered ** 2))
       
        return FilterResult(
            filter_type="iir_notch",
            cutoff_hz=[notch_hz],
            order=2,
            signal_filtered=filtered.tolist(),
            rms_before=round(float(rms_before), 4),
            rms_after=round(float(rms_after), 4),
            attenuation_db=round(20 * np.log10((rms_after + 1e-12) / (rms_before + 1e-12)), 2)
        )
   
    def detect_epileptiform_activity(self, reading: SensorReading) -> AnomalyReport:
        """
        Detect epileptiform spikes and sharp waves
        Clinical algorithm based on:
        - Amplitude threshold (>4.5 SD)
        - Duration (70-200ms for sharp waves)
        - Slope (steep rising/falling edges)
        """
        signal = reading.to_numpy()
        fs = reading.sample_rate_hz
        mean_signal = np.mean(signal)
        std_signal = np.std(signal)
        threshold = mean_signal + self.SPIKE_THRESHOLD_SD * std_signal
       
        # Detect peaks above threshold
        spike_mask = np.abs(signal - mean_signal) > threshold
        spike_indices = np.where(spike_mask)[0]
       
        segments = []
        affected_channels = []
       
        for idx in spike_indices[:20]:
            # Calculate duration around spike
            start_idx = max(0, idx - int(0.100 * fs))  # 100ms before
            end_idx = min(len(signal), idx + int(0.200 * fs))  # 200ms after
            duration_ms = (end_idx - start_idx) / fs * 1000
           
            # Classify by duration
            artifact_type = ArtifactType.ELECTRODE_POP
            if 70 <= duration_ms <= 200:
                artifact_type = ArtifactType.ELECTRODE_POP  # Sharp wave candidate
                affected_channels.append(reading.channel)
           
            segments.append({
                "sample_index": int(idx),
                "time_ms": round(idx / fs * 1000, 1),
                "amplitude_uv": round(float(signal[idx]), 2),
                "duration_ms": round(duration_ms, 1),
                "type": artifact_type.value
            })
       
        detected = len(spike_indices) > 0
        confidence = min(0.95, len(spike_indices) / 10.0) if detected else 0.0
       
        return AnomalyReport(
            detected=detected,
            anomaly_type="epileptiform_spike" if detected else "none",
            confidence=confidence,
            segments=segments[:10],
            affected_channels=list(set(affected_channels)),
            recommendation=(
                "Clinical correlation recommended. Consider reducing stimulation amplitude."
                if detected else "No significant epileptiform activity detected."
            ),
            clinical_significance=(
                f"{len(spike_indices)} spikes detected. Suggest neurological review."
                if detected else "Normal background activity."
            )
        )
   
    def detect_artifacts(self, reading: SensorReading) -> AnomalyReport:
        """
        Comprehensive artifact detection:
        - Eye blinks (frontal, slow, large amplitude)
        - Muscle artifact (high frequency, EMG)
        - Movement artifact (slow, baseline wander)
        - 50/60 Hz mains interference
        """
        signal = reading.to_numpy()
        fs = reading.sample_rate_hz
        n = len(signal)
       
        # Compute frequency content
        fft_vals = np.abs(fft(signal))[:n//2]
        freqs = fftfreq(n, 1/fs)[:n//2]
       
        artifacts_detected = []
       
        # Check for mains interference (50/60 Hz)
        for mains_freq in [50, 60]:
            mask = (freqs >= mains_freq - 1) & (freqs <= mains_freq + 1)
            if np.any(mask) and np.max(fft_vals[mask]) > np.mean(fft_vals) * 5:
                artifacts_detected.append({
                    "type": ArtifactType.MAINS_50HZ.value if mains_freq == 50 else ArtifactType.MAINS_60HZ.value,
                    "frequency_hz": mains_freq,
                    "power": float(np.max(fft_vals[mask]))
                })
       
        # Check for eye blinks (frontal channels, <4 Hz, large amplitude)
        if reading.channel < 2:  # Frontal channels
            low_freq_power = np.sum(fft_vals[freqs < 4])
            if low_freq_power > np.mean(fft_vals) * 10:
                artifacts_detected.append({
                    "type": ArtifactType.EYE_BLINK.value,
                    "power": float(low_freq_power)
                })
       
        # Check for muscle artifact (high frequency, >30 Hz)
        muscle_power = np.sum(fft_vals[freqs > 30])
        total_power = np.sum(fft_vals)
        if muscle_power > total_power * 0.3:
            artifacts_detected.append({
                "type": ArtifactType.MUSCLE.value,
                "power_ratio": round(muscle_power / total_power, 3)
            })
       
        return AnomalyReport(
            detected=len(artifacts_detected) > 0,
            anomaly_type="multiple_artifacts" if len(artifacts_detected) > 1 else artifacts_detected[0]["type"] if artifacts_detected else "none",
            confidence=min(0.95, len(artifacts_detected) * 0.3),
            segments=artifacts_detected,
            affected_channels=[reading.channel],
            recommendation="Check electrode contact and patient relaxation." if artifacts_detected else "Signal quality acceptable.",
            clinical_significance="Artifacts may confound interpretation." if artifacts_detected else "Good signal quality."
        )
   
    def calculate_clinical_indices(self, reading: SensorReading, spectral: SpectralResult) -> Dict:
        """
        Calculate clinical EEG indices
        - Theta/Alpha ratio (drowsiness indicator)
        - Beta/Alpha ratio (attention index)
        - Alpha asymmetry (stroke/TBI indicator)
        - Burst suppression ratio (anesthesia monitoring)
        """
        theta_alpha_ratio = spectral.bands.get("theta", 1) / (spectral.bands.get("alpha", 1) + 1e-6)
        beta_alpha_ratio = spectral.bands.get("beta", 1) / (spectral.bands.get("alpha", 1) + 1e-6)
       
        # Alpha asymmetry (simplified - would need homologous channels)
        alpha_asymmetry = 0.0
       
        # Burst suppression detection
        signal = reading.to_numpy()
        below_threshold = np.abs(signal) < self.SUPPRESSION_THRESHOLD_UV
        burst_suppression_ratio = np.sum(below_threshold) / len(signal)
       
        return {
            "theta_alpha_ratio": round(theta_alpha_ratio, 3),
            "beta_alpha_ratio": round(beta_alpha_ratio, 3),
            "alpha_asymmetry_percent": round(alpha_asymmetry, 1),
            "burst_suppression_ratio": round(burst_suppression_ratio, 3),
            "dominant_rhythm": max(spectral.bands, key=spectral.bands.get),
            "clinical_interpretation": self._interpret_clinical_indices(theta_alpha_ratio, beta_alpha_ratio)
        }
   
    def _interpret_clinical_indices(self, theta_alpha_ratio: float, beta_alpha_ratio: float) -> str:
        """Generate clinical interpretation of EEG indices"""
        if theta_alpha_ratio > 2.0:
            return "Elevated theta/alpha ratio suggests drowsiness or cognitive slowing."
        elif theta_alpha_ratio < 0.5:
            return "Reduced theta/alpha ratio indicates heightened alertness."
        elif beta_alpha_ratio > 1.5:
            return "Increased beta activity - possible anxiety or medication effect."
        else:
            return "Normal EEG spectral indices."

