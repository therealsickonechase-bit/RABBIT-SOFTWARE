    registry = ToolRegistry(device, processor)
    agent = DeepSeekMedicalAgent(registry, api_key=args.api_key)
   
    console.print(Panel.fit(
        "[bold]🧠 NeuroAI: RF/SDR Medical LLM Tool-Chain[/bold]\n"
        "Connecting DeepSeek AI to Medical RF/SDR Instruments\n"
        f"[dim]Device: {args.device} | Mode: {args.mode}[/dim]",
        border_style="cyan"
    ))
   
    if args.mode == "server":
        server = WebSocketServer(agent, port=args.ws_port)
        try:
            asyncio.run(server.start())
        except KeyboardInterrupt:
            console.print("\n[yellow]Server shutdown[/yellow]")
    else:
        run_cli(agent)

if __name__ == "__main__":
    main()
