class SignalType(Enum):
    EEG = "eeg"
    ECG = "ecg"
    EMG = "emg"
    MMG = "mmg"
    DNA_RF = "dna_rf"
    IMPEDANCE = "impedance"

class ArtifactType(Enum):
    NONE = "none"
    EYE_BLINK = "eye_blink"
    MUSCLE = "muscle"
    MOVEMENT = "movement"
    ELECTRODE_POP = "electrode_pop"
    MAINS_50HZ = "mains_50hz"
    MAINS_60HZ = "mains_60hz"
    SATURATION = "saturation"

@dataclass
class SensorReading:
    device_id: str
    device_type: SignalType
    timestamp: str
    channel: int
    sample_rate_hz: float
    duration_ms: float
    signal_raw: List[float]
    unit: str = "µV"
    metadata: Dict = field(default_factory=dict)
   
    def to_numpy(self) -> np.ndarray:
        return np.array(self.signal_raw)
   
    def get_hash(self) -> str:
        """Cryptographic hash for data integrity"""
        data_str = f"{self.device_id}_{self.timestamp}_{self.channel}_{self.signal_raw[:100]}"
        return hashlib.sha3_256(data_str.encode()).hexdigest()[:16]

@dataclass
class SpectralResult:
    freqs: List[float]
    psd: List[float]
    bands: Dict[str, float]  # delta/theta/alpha/beta/gamma
    peak_freq: float
    peak_power: float
    snr_db: float
    total_power: float
    median_freq: float
    spectral_edge: float

@dataclass
class FilterResult:
    filter_type: str
    cutoff_hz: List[float]
    order: int
    signal_filtered: List[float]
    rms_before: float
    rms_after: float
    attenuation_db: float

