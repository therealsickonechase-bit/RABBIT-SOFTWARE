class TimelineAPI:
    """
    API for external software and LLMs to access frozen timeline data
    Protected by same security as main system (smoke detector, zero-trust)
    """
   
    def __init__(self, store: FrozenTimelineStore, protected_network: Any):
        self.store = store
        self.network = protected_network
        self.api_keys = {}  # registered API consumers
        self.access_log = []
       
        print(f"\n🌐 TIMELINE API ACTIVE")
        print(f"   External software/LLM can access frozen data")
        print(f"   Protected by: smoke detector, rate limiting, authentication")
   
    def register_api_consumer(self, consumer_name: str, permissions: List[str]) -> str:
        """Register external software/LLM to access API"""
        api_key = hashlib.sha3_256(f"{consumer_name}_{secrets.token_hex(16)}".encode()).hexdigest()[:32]
       
        self.api_keys[api_key] = {
            'name': consumer_name,
            'permissions': permissions,
            'created_at': time.time(),
            'last_used': None,
            'requests': 0
        }
       
        print(f"\n🔑 API KEY GENERATED for {consumer_name}")
        print(f"   Key: {api_key[:16]}...")
        print(f"   Permissions: {permissions}")
       
        return api_key
   
    def get_timeline_data(self, api_key: str, age_years: float,
                          data_fields: List[str]) -> Dict:
        """
        API endpoint: Get frozen timeline data
        External software/LLM can call this to access data
        """
        # Verify API key
        if api_key not in self.api_keys:
            return {'error': 'Invalid API key'}
       
        consumer = self.api_keys[api_key]
        consumer['last_used'] = time.time()
        consumer['requests'] += 1
       
        # Check smoke detector (security)
        if self.network and hasattr(self.network, 'traffic_analyzer'):
            traffic = self.network.traffic_analyzer.analyze_packet(5.0)
            if traffic['state'] == 'smoke_detector':
                return {'error': 'API temporarily blocked - network anomaly detected'}
       
        # Get timeline
        timeline = self.store.get_timeline(age_years)
        if not timeline:
            return {'error': f'Timeline at age {age_years} not found'}
       
        # Return requested fields
        result = {'timeline_id': timeline.timeline_id, 'age_years': age_years}
       
        for field in data_fields:
            if field == 'hormonal_profile':
                result['hormonal_profile'] = timeline.hormonal_profile
            elif field == 'neurotransmitters':
                result['neurotransmitters'] = timeline.neurotransmitter_levels
            elif field == 'eeg_fingerprint':
                result['eeg_fingerprint'] = timeline.eeg_fingerprint
            elif field == 'node_parameters':
                result['node_sensitivity'] = timeline.node_sensitivity
                result['node_tuning'] = timeline.node_tuning_parameters
            elif field == 'environment':
                result['environment'] = timeline.environment_snapshot
       
        # Log access
        self.access_log.append({
            'timestamp': time.time(),
            'consumer': consumer['name'],
            'age_years': age_years,
            'fields': data_fields
        })
       
        return result
   
    def install_into_llm(self, api_key: str, age_years: float,
                         llm_context_window: Dict) -> Dict:
        """
        Install frozen timeline data into LLM
        LLM can use the person's frozen state as context
        """
        # Get timeline data
        timeline_data = self.get_timeline_data(api_key, age_years,
                                               ['hormonal_profile', 'neurotransmitters', 'eeg_fingerprint'])
       
        if 'error' in timeline_data:
            return timeline_data
       
        # Format for LLM context
        llm_context = {
            'system_prompt': f"You are now simulating a person at age {age_years}",
            'persona_data': {
                'age': age_years,
                'hormonal_state': timeline_data.get('hormonal_profile', {}),
                'neurotransmitter_levels': timeline_data.get('neurotransmitters', {}),
                'eeg_signature': timeline_data.get('eeg_fingerprint', '')
            },
            'behavioral_parameters': {
                'emotional_tendency': self._calculate_emotional_tendency(timeline_data),
                'stress_response': self._calculate_stress_response(timeline_data)
            },
            'frozen_at': datetime.fromtimestamp(self.store.get_timeline(age_years).timestamp).isoformat()
        }
       
        # Merge with provided context window
        llm_context.update(llm_context_window)
       
        print(f"\n🤖 TIMELINE INSTALLED INTO LLM")
        print(f"   Age: {age_years}")
        print(f"   Context size: {len(str(llm_context))} bytes")
       
        return {
            'llm_ready': True,
            'context': llm_context,
            'installation_id': hashlib.md5(str(time.time()).encode()).hexdigest()[:16]
        }
   
    def _calculate_emotional_tendency(self, data: Dict) -> str:
        dopamine = data.get('hormonal_profile', {}).get('dopamine', 0.5)
        serotonin = data.get('hormonal_profile', {}).get('serotonin', 0.5)
       
        if dopamine > 0.6 and serotonin > 0.6:
            return "positive_optimistic"
        elif dopamine < 0.4 or serotonin < 0.4:
            return "reserved_cautious"
        else:
            return "balanced"
   
    def _calculate_stress_response(self, data: Dict) -> str:
        cortisol = data.get('hormonal_profile', {}).get('cortisol', 0.5)
       
        if cortisol > 0.6:
            return "heightened_alert"
        elif cortisol < 0.4:
            return "calm"
        else:
            return "moderate"


