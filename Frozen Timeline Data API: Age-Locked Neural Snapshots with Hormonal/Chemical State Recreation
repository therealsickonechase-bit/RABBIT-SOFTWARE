class TimelineBreakdownEngine:
    """
    Breaks down frozen timeline data by date, hormones, chemicals
    Allows WHAT-IF manipulation (simulations, not actual changes)
    """
   
    def __init__(self, store: FrozenTimelineStore):
        self.store = store
        self.manipulation_history = []
       
        print(f"\n🔬 TIMELINE BREAKDOWN ENGINE")
        print(f"   Can break down data by: date, hormones, neurotransmitters, stress markers")
        print(f"   Manipulation: WHAT-IF simulations (does not change frozen data)")
   
    def breakdown_by_date(self, age_years: float) -> Dict:
        """Break down frozen timeline by date"""
        timeline = self.store.get_timeline(age_years)
        if not timeline:
            return {'error': 'Timeline not found'}
       
        # Convert timestamp to readable date
        freeze_date = datetime.fromtimestamp(timeline.timestamp)
       
        breakdown = {
            'timeline_id': timeline.timeline_id,
            'freeze_date': freeze_date.strftime('%Y-%m-%d %H:%M:%S'),
            'age_years': timeline.age_years,
            'age_days': timeline.age_days,
            'hormonal_profile': timeline.hormonal_profile,
            'neurotransmitters': timeline.neurotransmitter_levels,
            'stress_markers': timeline.stress_markers,
            'metabolic_markers': timeline.metabolic_markers,
            'eeg_fingerprint': timeline.eeg_fingerprint,
            'node_sensitivity': timeline.node_sensitivity
        }
       
        return breakdown
   
    def breakdown_by_hormone(self, age_years: float, hormone: str) -> Dict:
        """Break down specific hormone at frozen timeline"""
        timeline = self.store.get_timeline(age_years)
        if not timeline:
            return {'error': 'Timeline not found'}
       
        hormone_value = timeline.hormonal_profile.get(hormone)
       
        return {
            'timeline_id': timeline.timeline_id,
            'age_years': age_years,
            'hormone': hormone,
            'value': hormone_value,
            'unit': 'normalized (0-1)',
            'timestamp': timeline.datetime_utc,
            'interpretation': self._interpret_hormone_level(hormone, hormone_value)
        }
   
    def _interpret_hormone_level(self, hormone: str, value: float) -> str:
        if value > 0.7:
            return "Elevated"
        elif value < 0.3:
            return "Depressed"
        else:
            return "Normal"
   
    def manipulate_timeline(self, age_years: float, manipulations: Dict) -> Dict:
        """
        MANIPULATE frozen timeline data (WHAT-IF simulation)
        Does NOT change the original frozen data - only creates simulation
        """
        original = self.store.get_timeline(age_years)
        if not original:
            return {'error': 'Timeline not found'}
       
        # Create simulated timeline (copy, then modify)
        simulated = {
            'original_timeline_id': original.timeline_id,
            'age_years': age_years,
            'manipulations_applied': manipulations,
            'simulated_at': time.time(),
            'is_simulation': True,
            'original_frozen': True
        }
       
        # Apply manipulations to hormonal profile
        simulated_hormones = original.hormonal_profile.copy()
        for hormone, delta in manipulations.get('hormone_changes', {}).items():
            if hormone in simulated_hormones:
                simulated_hormones[hormone] = max(0, min(1, simulated_hormones[hormone] + delta))
       
        simulated['modified_hormonal_profile'] = simulated_hormones
       
        # Apply manipulations to node parameters
        simulated_node_sensitivity = original.node_sensitivity + manipulations.get('node_sensitivity_delta', 0)
        simulated['modified_node_sensitivity'] = max(0.1, min(1.0, simulated_node_sensitivity))
       
        # Calculate predicted outcomes
        simulated['predicted_outcomes'] = self._predict_outcomes(simulated_hormones, manipulations)
       
        # Record manipulation
        self.manipulation_history.append({
            'timestamp': time.time(),
            'age_years': age_years,
            'manipulations': manipulations,
            'simulated_id': hashlib.md5(str(time.time()).encode()).hexdigest()[:16]
        })
       
        print(f"\n🔧 TIMELINE MANIPULATED (SIMULATION): Age {age_years}")
        for hormone, delta in manipulations.get('hormone_changes', {}).items():
            print(f"   {hormone}: {delta:+.2f}")
       
        return simulated
   
    def _predict_outcomes(self, hormones: Dict, manipulations: Dict) -> Dict:
        """Predict outcomes of hormonal manipulation"""
        dopamine = hormones.get('dopamine', 0.5)
        serotonin = hormones.get('serotonin', 0.5)
       
        return {
            'mood_prediction': 'improved' if dopamine > 0.6 else 'decreased' if dopamine < 0.4 else 'stable',
            'stress_prediction': 'reduced' if hormones.get('cortisol', 0.5) < 0.4 else 'elevated',
            'cognitive_impact': 'enhanced' if serotonin > 0.6 else 'normal'
        }


