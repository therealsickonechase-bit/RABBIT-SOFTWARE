@dataclass
class FrozenTimeline:
    """Complete frozen snapshot of a person at a specific age"""
    timeline_id: str
    person_id: str
    age_years: float
    age_days: int
    timestamp: float
    datetime_utc: str
   
    # Biological data at freeze moment
    dna_hash: str
    dna_sample_preview: str
    eeg_fingerprint: str
    eeg_full_pattern: np.ndarray  # Compressed
   
    # Hormonal/chemical profile at exact moment
    hormonal_profile: Dict[str, float]
    neurotransmitter_levels: Dict[str, float]
    stress_markers: Dict[str, float]
    metabolic_markers: Dict[str, float]
   
    # Node state at freeze moment
    node_sensitivity: float
    node_tuning_parameters: Dict
    rf_frequency_ghz: float
   
    # Environment at freeze moment
    environment_snapshot: Dict
    recognized_sounds: List[Dict]
   
    # Immutability
    blockchain_hash: str
    previous_timeline_hash: str
    is_frozen: bool = True


class FrozenTimelineStore:
    """
    Immutable store of frozen timelines
    Each timeline is a complete snapshot of the person at that age
    Data CANNOT be altered after freezing
    """
   
    def __init__(self, person_id: str):
        self.person_id = person_id
        self.timelines: Dict[float, FrozenTimeline] = {}  # age_years -> timeline
        self.timeline_chain = []  # Blockchain of timelines
        self.timeline_db = sqlite3.connect(f"frozen_timelines_{person_id}.db", check_same_thread=False)
        self._init_database()
       
        print(f"\n❄️ FROZEN TIMELINE STORE: {person_id}")
        print(f"   Each timeline is IMMUTABLE")
        print(f"   Data cannot be altered after freezing")
   
    def _init_database(self):
        cursor = self.timeline_db.cursor()
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS frozen_timelines (
                timeline_id TEXT PRIMARY KEY,
                age_years REAL,
                timestamp REAL,
                hormonal_profile TEXT,
                eeg_hash TEXT,
                dna_hash TEXT,
                blockchain_hash TEXT,
                is_frozen BOOLEAN
            )
        ''')
        self.timeline_db.commit()
   
    def freeze_timeline(self, age_years: float,
                        hormonal_profile: Dict,
                        eeg_pattern: np.ndarray,
                        dna_hash: str,
                        environment: Dict) -> FrozenTimeline:
        """
        FREEZE a timeline at specific age
        Creates immutable record of person at that moment
        """
        timeline_id = hashlib.sha3_256(f"{self.person_id}_{age_years}_{time.time()}".encode()).hexdigest()[:16]
       
        # Create timeline
        timeline = FrozenTimeline(
            timeline_id=timeline_id,
            person_id=self.person_id,
            age_years=age_years,
            age_days=int(age_years * 365.25),
            timestamp=time.time(),
            datetime_utc=datetime.utcnow().isoformat(),
            dna_hash=dna_hash,
            dna_sample_preview=dna_hash[:16],
            eeg_fingerprint=hashlib.sha3_256(eeg_pattern.tobytes()).hexdigest()[:16],
            eeg_full_pattern=eeg_pattern,
            hormonal_profile=hormonal_profile,
            neurotransmitter_levels=self._extract_neurotransmitters(hormonal_profile),
            stress_markers=self._extract_stress_markers(hormonal_profile),
            metabolic_markers=self._extract_metabolic_markers(hormonal_profile),
            node_sensitivity=0.7 + (age_years / 100),
            node_tuning_parameters={'learning_rate': 0.6 - (age_years / 200),
                                     'rf_power': -90 + (age_years / 10)},
            rf_frequency_ghz=10.23 + (age_years / 1000),
            environment_snapshot=environment,
            recognized_sounds=environment.get('sounds', []),
            blockchain_hash=hashlib.sha3_256(f"{timeline_id}_{time.time()}".encode()).hexdigest(),
            previous_timeline_hash=self.timeline_chain[-1].blockchain_hash if self.timeline_chain else '0'*64,
            is_frozen=True
        )
       
        self.timelines[age_years] = timeline
       
        # Add to blockchain
        block = {
            'index': len(self.timeline_chain),
            'timeline_id': timeline_id,
            'age': age_years,
            'timestamp': time.time(),
            'previous_hash': self.timeline_chain[-1]['hash'] if self.timeline_chain else '0'*64
        }
        block['hash'] = hashlib.sha3_256(json.dumps(block, sort_keys=True).encode()).hexdigest()
        self.timeline_chain.append(block)
       
        # Store in database
        cursor = self.timeline_db.cursor()
        cursor.execute('''
            INSERT INTO frozen_timelines (timeline_id, age_years, timestamp, hormonal_profile, eeg_hash, dna_hash, blockchain_hash, is_frozen)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
        ''', (timeline_id, age_years, time.time(), json.dumps(hormonal_profile),
              timeline.eeg_fingerprint, dna_hash, timeline.blockchain_hash, True))
        self.timeline_db.commit()
       
        print(f"\n❄️ TIMELINE FROZEN: Age {age_years}")
        print(f"   ID: {timeline_id}")
        print(f"   Date: {timeline.datetime_utc}")
        print(f"   Hormones: {len(hormonal_profile)} markers")
       
        return timeline
   
    def _extract_neurotransmitters(self, profile: Dict) -> Dict:
        return {
            'dopamine': profile.get('dopamine', 0.5),
            'serotonin': profile.get('serotonin', 0.5),
            'oxytocin': profile.get('oxytocin', 0.5),
            'norepinephrine': profile.get('norepinephrine', 0.5),
            'GABA': profile.get('GABA', 0.5),
            'glutamate': profile.get('glutamate', 0.5)
        }
   
    def _extract_stress_markers(self, profile: Dict) -> Dict:
        return {
            'cortisol': profile.get('cortisol', 0.5),
            'adrenaline': profile.get('adrenaline', 0.3),
            'hrv': profile.get('hrv', 50)
        }
   
    def _extract_metabolic_markers(self, profile: Dict) -> Dict:
        return {
            'thyroid': profile.get('thyroid', 0.7),
            'insulin': profile.get('insulin', 0.5),
            'melatonin': profile.get('melatonin', 0.4)
        }
   
    def get_timeline(self, age_years: float) -> Optional[FrozenTimeline]:
        """Get frozen timeline at specific age"""
        return self.timelines.get(age_years)
   
    def get_all_timelines(self) -> List[FrozenTimeline]:
        """Get all frozen timelines for this person"""
        return list(self.timelines.values())


