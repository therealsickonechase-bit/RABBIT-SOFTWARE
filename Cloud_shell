                "network", "usb", "bluetooth", "audio", "graphics", 
                "storage", "touch", "stylus", "webcam"
            ]
        }
        return capabilities.get(platform, [])
    
    def connect_device(self, device_info: Dict) -> PlatformDevice:
        """Connect a new device"""
        try:
            with self.device_lock:
                device = PlatformDevice(
                    device_id=device_info.get("device_id", f"DEV_{hashlib.md5(str(time.time()).encode()).hexdigest()[:10]}"),
                    platform=device_info.get("platform", PlatformType.UNKNOWN.value),
                    platform_version=device_info.get("platform_version", "unknown"),
                    architecture=device_info.get("architecture", PlatformArchitecture.UNKNOWN.value),
                    device_name=device_info.get("device_name", "Unnamed Device"),
                    device_model=device_info.get("device_model", "Unknown Model"),
                    is_emulator=device_info.get("is_emulator", False),
                    connection_status="connected",
                    last_seen=datetime.now().isoformat(),
                    security_profile=self._get_security_profile(device_info.get("platform", PlatformType.UNKNOWN.value)),
                    data_stats={
                        "data_processed": 0,
                        "connections": 1,
                        "errors": 0
                    },
                    connection_info={
                        "ip_address": device_info.get("ip_address", "unknown"),
                        "port": device_info.get("port", 0),
                        "connection_type": device_info.get("connection_type", "unknown")
                    },
                    capabilities=self._get_device_capabilities(device_info.get("platform", PlatformType.UNKNOWN.value))
                )
                
                self.connected_devices[device.device_id] = device
                self.system_config.system_stats["platform_count"] += 1
                self.system_config.system_stats["active_connections"] += 1
                
                logger.info(f"Device connected: {device.device_name} ({device.platform})")
                return device
                
        except Exception as e:
            logger.error(f"Device connection failed: {e}")
            return None
    
    def disconnect_device(self, device_id: str) -> bool:
        """Disconnect a device"""
        try:
            with self.device_lock:
                if device_id in self.connected_devices:
                    device = self.connected_devices[device_id]
                    device.connection_status = "disconnected"
                    self.system_config.system_stats["active_connections"] -= 1
                    del self.connected_devices[device_id]
                    logger.info(f"Device disconnected: {device.device_name}")
                    return True
            return False
        except Exception as e:
            logger.error(f"Device disconnection failed: {e}")
            return False
    
    def _get_security_profile(self, platform: str) -> Dict:
        """Get security profile for platform"""
        if platform in self.security_profiles:
            profile = self.security_profiles[platform]
            return {
                "security_level": profile.security_level,
                "encryption_required": profile.encryption_required,
                "authentication_required": profile.authentication_required,
                "security_policies": profile.security_policies
            }
        return {
            "security_level": "medium",
            "encryption_required": True,
            "authentication_required": True,
            "security_policies": ["Basic Security"]
        }
    
    def _get_device_capabilities(self, platform: str) -> List[str]:
        """Get device capabilities for platform"""
        if platform in self.platform_configs:
            return self.platform_configs[platform].capabilities
        return []
    
    def get_platform_info(self, platform: str) -> Dict:
        """Get platform information"""
        with self.system_config.platforms_lock:
            return self.system_config.platforms.get(platform, {})
    
    def list_connected_devices(self) -> List[Dict]:
        """List all connected devices"""
        try:
            with self.device_lock:
                return [asdict(device) for device in self.connected_devices.values()]
        except Exception as e:
            logger.error(f"Failed to list devices: {e}")
            return []
    
    def get_device_stats(self) -> Dict:
        """Get device system statistics"""
        try:
            with self.device_lock:
                return {
                    "connected_devices": len(self.connected_devices),
                    "active_connections": self.system_config.system_stats["active_connections"],
                    "platform_count": self.system_config.system_stats["platform_count"],
                    "data_processed": self.system_config.system_stats["data_processed"]
                }
        except Exception as e:
            logger.error(f"Failed to get device stats: {e}")
            return {}
    
    def add_data_record(self, record: PlatformDataRecord):
        """Add a data record"""
        try:
            self.data_records.append(record)
            self.system_config.system_stats["data_processed"] += 1
            logger.debug(f"Data record added for {record.platform} device {record.device_id}")
        except Exception as e:
            logger.error(f"Failed to add data record: {e}")
    
    def get_data_records(self, limit: int = 50) -> List[Dict]:
        """Get recent data records"""
        try:
            records = list(self.data_records)[-limit:] if limit > 0 else list(self.data_records)
            return [asdict(record) for record in records]
        except Exception as e:
            logger.error(f"Failed to get data records: {e}")
            return []

# Enhanced Data Security and Integrity Systems
class PasswordSecurityManager:
    """Multi-platform password security manager"""
    
    def __init__(self):
        self.password_configs = {}
        self.encryption_keys = {}
        self.password_lock = threading.RLock()
        self.security_levels = {
            "standard": {"min_length": 8, "require_special": False, "require_numbers": False},
            "enhanced": {"min_length": 12, "require_special": True, "require_numbers": True},
            "secure": {"min_length": 16, "require_special": True, "require_numbers": True, "require_uppercase": True},
            "maximum": {"min_length": 20, "require_special": True, "require_numbers": True, "require_uppercase": True, "require_lowercase": True}
        }
        self.active_security_level = "standard"
        self.security_toggle_state = {"active": False}
        self.password_stats = {
            "total_passwords": 0,
            "active_encryptions": 0,
            "security_level_changes": 0
        }
    
    def set_security_level(self, level: str) -> bool:
        """Set password security level"""
        try:
            with self.password_lock:
                if level in self.security_levels:
                    self.active_security_level = level
                    self.security_toggle_state["active"] = True
                    self.password_stats["security_level_changes"] += 1
                    logger.info(f"Password security level changed to: {level}")
                    return True
                return False
        except Exception as e:
            logger.error(f"Failed to set security level: {e}")
            return False
    
    def get_password_config(self, level: str) -> Dict:
        """Get configuration for specific security level"""
        return self.security_levels.get(level, self.security_levels["standard"])
    
    def generate_encryption_key(self, password: str) -> bytes:
        """Generate encryption key from password"""
        try:
            # Salt based on timestamp for uniqueness
            salt = hashlib.sha256(str(time.time()).encode()).digest()
            kdf = PBKDF2HMAC(
                algorithm=hashes.SHA256(),
                length=32,
                salt=salt,
                iterations=100000,
            )
            key = base64.urlsafe_b64encode(kdf.derive(password.encode()))
            return key
        except Exception as e:
            logger.error(f"Failed to generate encryption key: {e}")
            return None
    
    def encrypt_password(self, password: str, level: str = None) -> str:
        """Encrypt password with security level"""
        try:
            # Generate key based on current security level
            if level is None:
                level = self.active_security_level
            
            key = self.generate_encryption_key(password)
            if key is None:
                return password
            
            f = Fernet(key)
            encrypted_password = f.encrypt(password.encode())
            return base64.urlsafe_b64encode(encrypted_password).decode()
        except Exception as e:
            logger.error(f"Failed to encrypt password: {e}")
            return password
    
    def decrypt_password(self, encrypted_password: str, key: bytes) -> str:
        """Decrypt password with key"""
        try:
            f = Fernet(key)
            decrypted = f.decrypt(base64.urlsafe_b64decode(encrypted_password.encode()))
            return decrypted.decode()
        except Exception as e:
            logger.error(f"Failed to decrypt password: {e}")
            return encrypted_password
    
    def validate_password_strength(self, password: str, level: str = None) -> Dict:
        """Validate password strength against security level"""
        if level is None:
            level = self.active_security_level
            
        config = self.get_password_config(level)
        validation = {
            "password": password,
            "security_level": level,
            "valid": True,
            "score": 0,
            "checks": {
                "length": False,
                "special_chars": False,
                "numbers": False,
                "uppercase": False,
                "lowercase": False
            }
        }
        
        # Length check
        if len(password) >= config["min_length"]:
            validation["checks"]["length"] = True
            validation["score"] += 25
            
        # Special characters check
        if config["require_special"] and re.search(r"[!@#$%^&*()_+\-=\[\]{};':\"\\|,.<>\/?]", password):
            validation["checks"]["special_chars"] = True
            validation["score"] += 15
            
        # Numbers check
        if config["require_numbers"] and re.search(r"\d", password):
            validation["checks"]["numbers"] = True
            validation["score"] += 15
            
        # Uppercase check
        if config.get("require_uppercase", False) and re.search(r"[A-Z]", password):
            validation["checks"]["uppercase"] = True
            validation["score"] += 15
            
        # Lowercase check
        if config.get("require_lowercase", False) and re.search(r"[a-z]", password):
            validation["checks"]["lowercase"] = True
            validation["score"] += 15
            
        # Final check
        if validation["score"] >= 50:
            validation["valid"] = True
        else:
            validation["valid"] = False
            
        return validation

class DataIntegrityManager:
    """Enhanced data integrity manager"""
    
    def __init__(self):
        self.integrity_levels = {
            "normal": {"hash_algorithm": "md5", "validation_threshold": 0.8},
            "enhanced": {"hash_algorithm": "sha256", "validation_threshold": 0.9},
            "maximum": {"hash_algorithm": "sha512", "validation_threshold": 0.95}
        }
        self.active_integrity_level = "normal"
        self.data_validation_cache = {}
        self.cache_lock = threading.RLock()
        self.data_stats = {
            "validations_performed": 0,
            "integrity_violations": 0,
            "data_rehashed": 0
        }
    
    def set_integrity_level(self, level: str) -> bool:
        """Set data integrity level"""
        try:
            if level in self.integrity_levels:
                self.active_integrity_level = level
                logger.info(f"Data integrity level changed to: {level}")
                return True
            return False
        except Exception as e:
            logger.error(f"Failed to set data integrity level: {e}")
            return False
    
    def get_hash_algorithm(self) -> str:
        """Get current hash algorithm"""
        return self.integrity_levels[self.active_integrity_level]["hash_algorithm"]
    
    def calculate_data_hash(self, data: Any) -> str:
        """Calculate data hash for integrity verification"""
        try:
            str_data = str(data)
            algo = self.get_hash_algorithm()
            
            if algo == "sha512":
                hash_obj = hashlib.sha512()
            elif algo == "sha256":
                hash_obj = hashlib.sha256()
            else:
                hash_obj = hashlib.md5()
                
            hash_obj.update(str_data.encode('utf-8'))
            return hash_obj.hexdigest()
        except Exception as e:
            logger.error(f"Failed to calculate data hash: {e}")
            return hashlib.md5(str(data).encode()).hexdigest()
    
    def validate_data_integrity(self, data: Any, expected_hash: str) -> bool:
        """Validate data integrity against expected hash"""
        try:
            calculated_hash = self.calculate_data_hash(data)
            is_valid = calculated_hash == expected_hash
            
            with self.cache_lock:
                self.data_stats["validations_performed"] += 1
                if not is_valid:
                    self.data_stats["integrity_violations"] += 1
            
            logger.debug(f"Data integrity valid: {is_valid}")
            return is_valid
        except Exception as e:
            logger.error(f"Data validation failed: {e}")
            return False
    
    def create_data_signature(self, data: Any) -> Dict:
        """Create data signature for verification"""
        try:
            hash_val = self.calculate_data_hash(data)
            signature = {
                "data_hash": hash_val,
                "algorithm": self.get_hash_algorithm(),
                "timestamp": datetime.now().isoformat(),
                "integrity_level": self.active_integrity_level
            }
            return signature
        except Exception as e:
            logger.error(f"Failed to create data signature: {e}")
            return {}

class DataSanitizationEngine:
    """Advanced data sanitization engine"""
    
    def __init__(self, system_core):
        self.system_core = system_core
        self.sanitization_lock = threading.RLock()
        self.sanitization_stats = {
            "total_processed": 0,
            "sanitized_count": 0,
            "validation_errors": 0,
            "confidence_drops": 0
        }
        
    def sanitize_data(self, data: Dict, data_source: str = "unknown", platform: str = "unknown") -> PlatformDataRecord:
        """Sanitize data for specific platform"""
        try:
            record_id = f"SR_{hashlib.md5(str(time.time()).encode()).hexdigest()[:12]}"
            timestamp = datetime.now().isoformat()
            
            # Apply platform-specific sanitization
            sanitized_data = self._apply_platform_sanitization(data, platform)
            
            # Create integrity hash
            integrity_hash = hashlib.sha256(str(sanitized_data).encode()).hexdigest()
            
            # Calculate confidence score
            confidence_score = self._calculate_confidence_score(data, sanitized_data)
            
            # Validation
            validation_status = self._validate_sanitized_data(sanitized_data)
            
            # Create data record
            data_record = PlatformDataRecord(
                record_id=record_id,
                platform=platform,
                data_type="sanitized_data",
                data=sanitized_data,
                timestamp=timestamp,
                device_id=f"DEV_{platform}_{hashlib.md5(str(time.time()).encode()).hexdigest()[:10]}",
                integrity_hash=integrity_hash,
                security_level=self.system_core.security_config.security_level,
                platform_version=PlatformVersion.UNKNOWN.value,
                architecture=PlatformArchitecture.UNKNOWN.value
            )
            
            # Update statistics
            with self.sanitization_lock:
                self.sanitization_stats["total_processed"] += 1
                self.sanitization_stats["sanitized_count"] += 1
                if confidence_score < 0.8:
                    self.sanitization_stats["confidence_drops"] += 1
                    
            # Add to data records
            self.system_core.platform_manager.add_data_record(data_record)
            
            logger.debug(f"Data sanitized for {platform}: {record_id}")
            return data_record
            
        except Exception as e:
            logger.error(f"Data sanitization error: {e}")
            return None
    
    def _apply_platform_sanitization(self, data: Dict, platform: str) -> Dict:
        """Apply platform-specific sanitization rules"""
        if not data:
            return {}
            
        sanitized = copy.deepcopy(data)
        
        # Remove sensitive fields based on platform
        sensitive_fields = []
        if platform in [PlatformType.IOS.value, PlatformType.ANDROID.value]:
            sensitive_fields = [
                "password", "api_key", "secret", "token", "credential", "key",
                "ssn", "credit_card", "bank_account", "password_hash"
            ]
        else:
            sensitive_fields = [
                "password", "api_key", "secret", "token", "credential", "key",
                "ssn", "credit_card", "bank_account", "password_hash", "account_number"
            ]
            
        # Remove sensitive fields completely
        for field in sensitive_fields:
            sanitized.pop(field, None)
            
        # Normalize data types for different platforms
        sanitized = self._normalize_data_types(sanitized, platform)
        
        return sanitized
    
    def _normalize_data_types(self, data: Dict, platform: str) -> Dict:
        """Normalize data types for platform compatibility"""
        normalized = {}
        for key, value in data.items():
            try:
                if isinstance(value, str):
                    if value.lower() in ['true', 'false']:
                        normalized[key] = value.lower() == 'true'
                    elif self._is_numeric(value):
                        normalized[key] = float(value)
                    else:
                        # Remove control characters for iOS/Android compatibility
                        if platform in [PlatformType.IOS.value, PlatformType.ANDROID.value]:
                            normalized[key] = value.replace('\0', '').replace('\n', ' ').replace('\r', ' ')
                        else:
                            normalized[key] = value.replace('\0', '')
                else:
                    normalized[key] = value
            except Exception:
                normalized[key] = str(value).replace('\0', '')  # Convert problematic values
        return normalized
    
    def _is_numeric(self, value: str) -> bool:
        """Check if string represents a number"""
        try:
            float(value)
            return True
        except ValueError:
            return False
    
    def _calculate_confidence_score(self, original: Dict, sanitized: Dict) -> float:
        """Calculate confidence score for sanitized data"""
        # Check for data loss
        original_keys = set(original.keys())
        sanitized_keys = set(sanitized.keys())
        data_loss = len(original_keys - sanitized_keys) / len(original_keys) if original_keys else 0
        
        # Check for data modification
        modified_count = 0
        for key, value in original.items():
            if key in sanitized and sanitized[key] != value:
                modified_count += 1
        
        # Calculate confidence (more is better)
        confidence = 1.0 - (data_loss * 0.3 + modified_count * 0.2)
        return max(0.0, min(1.0, confidence))
    
    def _validate_sanitized_data(self, sanitized_data: Dict) -> str:
        """Validate sanitized data"""
        # Check for basic data structure validity
        if not isinstance(sanitized_data, dict):
            return "invalid_structure"
        return "valid"

