class PlatformManager:
    """Manager for multi-platform operations"""
    
    def __init__(self):
        self.system_config = SystemConfiguration()
        self.connected_devices = {}
        self.device_lock = threading.RLock()
        self.platform_configs = {}
        self.security_profiles = {}
        self.data_records = deque(maxlen=10000)
        self.init_platform_configs()
        
    def init_platform_configs(self):
        """Initialize platform configurations"""
        for platform_name, platform_info in self.system_config.platforms.items():
            config = PlatformConfiguration(
                platform=platform_name,
                supported_versions=[v.value for v in platform_info["versions"]],
                supported_architectures=[a.value for a in platform_info["architectures"]],
                security_level=platform_info["security_level"],
                default_settings=self._get_default_settings(platform_name),
                capabilities=self._get_capabilities(platform_name),
                last_updated=datetime.now().isoformat()
            )
            self.platform_configs[platform_name] = config
            
            # Initialize security profiles
            security_profile = PlatformSecurityProfile(
                platform=platform_name,
                security_level=platform_info["security_level"],
                encryption_required=True,
                authentication_required=True,
                data_compression=False,
                security_policies=[
                    "TLS 1.3 Encryption",
                    "256-bit AES",
                    "API Token Authentication",
                    "Session Management",
                    "Rate Limiting"
                ],
                compliance_status="compliant",
                threat_detections=[
                    {"type": "port_scan", "enabled": True},
                    {"type": "vulnerability_scan", "enabled": True},
                    {"type": "anomaly_detection", "enabled": True}
                ],
                last_updated=datetime.now().isoformat()
            )
            self.security_profiles[platform_name] = security_profile
    
