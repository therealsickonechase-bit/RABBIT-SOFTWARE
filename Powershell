# 1. Version ✅ (you ran this)
& 'C:\Program Files\Bitcoin\daemon\bitcoin-cli.exe' -version

# 2. Node status
& 'C:\Program Files\Bitcoin\daemon\bitcoin-cli.exe' getblockchaininfo

# 3. Current block height
& 'C:\Program Files\Bitcoin\daemon\bitcoin-cli.exe' getblockchaininfo | Select-String "blocks"

# 4. Test block fetch (latest block)
`$latest = & 'C:\Program Files\Bitcoin\daemon\bitcoin-cli.exe' getbestblockhash
& 'C:\Program Files\Bitcoin\daemon\bitcoin-cli.exe' getblock `$latest 0 | Select-String "tx"

# 5. Check TX index (needed for OP_RETURN scanning)
& 'C:\Program Files\Bitcoin\daemon\bitcoin-cli.exe' getindexinfo
