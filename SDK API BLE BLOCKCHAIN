pragma solidity ^0.8.20;

contract BleRegistry {
    struct BleInfo {
        address;
        bool allowed;           // simple on/off flag
    }

    mapping(bytes32 => BleInfo) public devices; // bleHash -> info

    event DeviceRegistered(bytes32 indexed bleHash, address indexed DevicePermissionSet(bytes32 indexed bleHash, bool allowed);

    // bleAddr should be the BLE MAC (e.g. "AA:BB:CC:DD:EE:FF") lowercased,
    // hashed off-chain with keccak256.
    function) external {
        BleInfo storage info = devices[bleHash];
        require(info.owner == address(0), "Already registered");
        info.owner = msg.sender;
        info.allowed = true;
        emit DeviceRegistered(bleHash, msg.sender);
        emit DevicePermissionSet(bleHash, true);
    }

    function setAllowed(bytes32 bleHash, bool allowed) external {
        BleInfo storage info = devices[bleHash];
        require(info.owner == msg.sender, "Not owner");
        info.allowed = allowed;
        emit DevicePermissionSet(bleHash, allowed);
    }

    function isAllowed(bytes32 bleHash) external view returns (bool) {
        return devices[bleHash].allowed;
    }
}

