import requests
import time

SERVER = "http://cloud-server:8000/ingest"

def send_event(event):
    try:
        requests.post(SERVER, json=event)
    except:
        print("offline queueing event")

while True:
    event = {
        "type": "mobile_sensor",
        "battery": 87,
        "timestamp": time.time()
    }

    send_event(event)
    time.sleep(5)


