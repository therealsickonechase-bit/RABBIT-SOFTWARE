# medical_blocknet_api.py
from fastapi import FastAPI, WebSocket, WebSocketDisconnect
from fastapi.responses import JSONResponse
import asyncio
import sqlite3
import hashlib
import json
import uvicorn
import subprocess
from typing import Dict, List, Optional
from dataclasses import dataclass
from p2pnetwork.node import Node
import shard_manager

app = FastAPI(title="MedicalBlockNet API", version="1.0")
BITCOIN_CLI = r'"C:\Program Files\Bitcoin\daemon\bitcoin-cli.exe"'

@dataclass
class MedicalBlock:
    height: int
    btc_hash: str
    shard_id: str
    owner_id: str
    medical_data_hash: str
    timestamp: int
    signature: str

class ShardNetwork(Node):
    def __init__(self, node_id: str, host: str, port: int):
        super().__init__(node_id, host, port)
        self.shards: Dict[str, List[MedicalBlock]] = {}
        self.owners: Dict[str, List[str]] = {}  # owner -> shard_ids
    
    def shard_lookup(self, shard_id: str) -> Optional[List[MedicalBlock]]:
        """Find shard across P2P network"""
        return self.shards.get(shard_id)
    
    def claim_shard(self, owner_id: str, shard_id: str) -> bool:
        """Owner reclaims shard identity"""
        if shard_id in self.shards:
            self.owners.setdefault(owner_id, []).append(shard_id)
            return True
        return False

# Global network instance
network = ShardNetwork("node_001", "0.0.0.0", 8001)
db = sqlite3.connect("medical_shards.db", check_same_thread=False)

def init_db():
    db.execute("""
        CREATE TABLE IF NOT EXISTS shards (
            shard_id TEXT PRIMARY KEY,
            owner_id TEXT,
            btc_height INTEGER,
            btc_hash TEXT,
            medical_hash TEXT,
            peers TEXT,
            reclaimed BOOLEAN DEFAULT 0
        )
    """)
    db.commit()

init_db()

# Bitcoin Core Integration
def bitcoin_scan_block(height: int) -> Dict:
    """Scan Bitcoin block for medical shards"""
    try:
        hash_ = subprocess.check_output([BITCOIN_CLI, "getblockhash", str(height)], text=True).strip()
        block = subprocess.check_output([BITCOIN_CLI, "getblock", hash_, "1"], text=True)
        block_json = json.loads(block)
        return {"height": height, "hash": hash_, "tx_count": len(block_json["tx"])}
    except:
        return {"error": "Bitcoin RPC failed"}

# === API ENDPOINTS ===
@app.get("/health")
async def health():
    return {"status": "alive", "peers": len(network.peers)}

@app.get("/scan/bitcoin/{height}")
async def scan_btc_block(height: int):
    """Scan Bitcoin block for medical data"""
    block = bitcoin_scan_block(height)
    shards = shard_manager.extract_shards(block)  # Custom shard extractor
    return {"block": block, "shards_found": len(shards)}

@app.post("/register/shard")
async def register_shard(shard: Dict):
    """Register medical shard with owner identity"""
    shard_id = hashlib.sha256(json.dumps(shard["data"]).encode()).hexdigest()[:16]
    
    db.execute("INSERT OR REPLACE INTO shards (shard_id, owner_id, btc_height, medical_hash) VALUES (?, ?, ?, ?)",
              (shard_id, shard["owner_id"], shard["btc_height"], shard["data_hash"]))
    db.commit()
    
    # Propagate to P2P network
    network.send_to_all({"type": "new_shard", "shard_id": shard_id, "owner": shard["owner_id"]})
    
    return {"shard_id": shard_id, "status": "registered"}

@app.get("/shard/{shard_id}")
async def get_shard(shard_id: str):
    """Lookup shard (searches local + P2P network)"""
    # Local DB first
    row = db.execute("SELECT * FROM shards WHERE shard_id=?", (shard_id,)).fetchone()
    if row:
        return {"found": True, "shard": dict(zip([c[0] for c in db.description], row))}
    
    # P2P network search
    result = network.shard_lookup(shard_id)
    if result:
        return {"found": True, "network": True, "shards": result}
    
    return {"found": False}

@app.post("/claim/shard/{shard_id}")
async def claim_shard(shard_id: str, owner_proof: Dict):
    """Owner reclaims shard identity"""
    if network.claim_shard(owner_proof["owner_id"], shard_id):
        db.execute("UPDATE shards SET reclaimed=1 WHERE shard_id=?", (shard_id,))
        db.commit()
        return {"status": "claimed"}
    return {"error": "shard_not_found"}

# === WEBSOCKET P2P NETWORK ===
connected_clients: List[WebSocket] = []

@app.websocket("/ws/network")
async def websocket_endpoint(websocket: WebSocket):
    await websocket.accept()
    connected_clients.append(websocket)
    try:
        while True:
            data = await websocket.receive_text()
            msg = json.loads(data)
            
            # Route P2P messages
            if msg["type"] == "shard_query":
                shards = network.shard_lookup(msg["shard_id"])
                await websocket.send_json({"type": "shard_response", "shards": shards})
            elif msg["type"] == "new_shard":
                network.shards[msg["shard_id"]] = msg["data"]
                
    except WebSocketDisconnect:
        connected_clients.remove(websocket)

# Auto-build network discovery
@app.on_event("startup")
async def startup():
    # Scan recent Bitcoin blocks for shards
    current_height = (subprocess.check_output([BITCOIN_CLI, "getblockchaininfo"], text=True) 
                     | json.loads).get("blocks", 0)
    
    asyncio.create_task(auto_discover_shards(current_height - 1000, current_height))

async def auto_discover_shards(start: int, end: int):
    """Continuously scan Bitcoin for lost medical shards"""
    for height in range(start, end):
        block = bitcoin_scan_block(height)
        shards = shard_manager.extract_shards(block)
        for shard in shards:
            network.send_to_all({"type": "new_shard", "shard_id": shard["id"], "btc_height": height})

if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=8000)
