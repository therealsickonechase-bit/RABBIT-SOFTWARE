class TokenEncoder:
    """
    Encodes biological/neural tokens into RF waveforms
    Each token type maps to specific frequency and waveform pattern
    """
   
    # Token types mapped to waveform patterns
    TOKEN_WAVEFORM_MAP = {
        'dopamine_level': 'WF_001',  # sine
        'serotonin_level': 'WF_004',  # triangle
        'cortisol_spike': 'WF_005',   # square (alert)
        'eeg_alpha': 'WF_001',        # sine
        'eeg_beta': 'WF_002',         # sawtooth
        'heart_rate': 'WF_004',       # triangle
        'stress_alert': 'WF_005',     # square
        'medical_data': 'WF_006',     # hybrid
        'encrypted_data': 'WF_003',   # jigsaw
        'bulk_neural': 'WF_007',      # spread spectrum
        'hidden_chaos': 'WF_008'      # chaos
    }
   
    def __init__(self):
        self.waveform_gen = WaveformGenerator()
        self.token_buffer = []
        self.encoding_history = []
       
        print(f"\n🔐 TOKEN ENCODER")
        print(f"   Token Types: {len(self.TOKEN_WAVEFORM_MAP)}")
   
    def encode_token(self, token_type: str, token_value: float, patient_id: str) -> Dict:
        """Encode a biological token into RF waveform"""
       
        # Get waveform pattern for token type
        pattern_id = self.TOKEN_WAVEFORM_MAP.get(token_type, 'WF_001')
        pattern = self.waveform_gen.patterns[pattern_id]
       
        # Normalize token value to 0-1 range for encoding
        normalized_value = min(1.0, max(0.0, token_value / 1.0))
       
        # Encode value into modulation depth
        modulation_depth = 0.3 + (normalized_value * 0.5)
       
        # Create token packet
        token_packet = {
            'token_id': hashlib.md5(f"{patient_id}_{token_type}_{time.time()}".encode()).hexdigest()[:16],
            'token_type': token_type,
            'token_value': token_value,
            'normalized_value': normalized_value,
            'waveform_pattern': pattern.waveform_type.value,
            'frequency_ghz': pattern.frequency_ghz,
            'modulation_depth': modulation_depth,
            'timestamp': time.time(),
            'patient_hash': hashlib.sha256(patient_id.encode()).hexdigest()[:16]
        }
       
        self.token_buffer.append(token_packet)
        self.encoding_history.append(token_packet)
       
        return token_packet
   
    def encode_batch(self, tokens: List[Tuple[str, float]], patient_id: str) -> List[Dict]:
        """Encode multiple tokens into batch transmission"""
        encoded = []
        for token_type, value in tokens:
            encoded.append(self.encode_token(token_type, value, patient_id))
        return encoded


