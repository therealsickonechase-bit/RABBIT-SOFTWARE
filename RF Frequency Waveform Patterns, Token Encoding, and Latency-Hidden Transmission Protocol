    def generate_waveform(self, pattern_id: str, duration_ns: int = 1000) -> Tuple[np.ndarray, np.ndarray]:
        """Generate waveform samples for given pattern"""
        pattern = self.patterns.get(pattern_id)
        if not pattern:
            return None, None
       
        t = np.linspace(0, duration_ns, int(duration_ns * 100))  # 100 samples per ns
        period = 1 / (pattern.frequency_ghz * 1e9)
       
        if pattern.waveform_type == WaveformType.SINE:
            signal = pattern.amplitude * np.sin(2 * np.pi * pattern.frequency_ghz * 1e9 * t + pattern.phase_offset)
        elif pattern.waveform_type == WaveformType.SAWTOOTH:
            signal = pattern.amplitude * signal.sawtooth(2 * np.pi * pattern.frequency_ghz * 1e9 * t + pattern.phase_offset, width=pattern.duty_cycle)
        elif pattern.waveform_type == WaveformType.TRIANGLE:
            signal = pattern.amplitude * signal.sawtooth(2 * np.pi * pattern.frequency_ghz * 1e9 * t + pattern.phase_offset, width=0.5)
        elif pattern.waveform_type == WaveformType.SQUARE:
            signal = pattern.amplitude * signal.square(2 * np.pi * pattern.frequency_ghz * 1e9 * t + pattern.phase_offset, duty=pattern.duty_cycle)
        elif pattern.waveform_type == WaveformType.HYBRID:
            # Hybrid of sine + sawtooth
            sine_part = 0.5 * np.sin(2 * np.pi * pattern.frequency_ghz * 1e9 * t)
            saw_part = 0.5 * signal.sawtooth(2 * np.pi * pattern.frequency_ghz * 1e9 * t * 0.5)
            signal = pattern.amplitude * (sine_part + saw_part)
        elif pattern.waveform_type == WaveformType.SPREAD_SPECTRUM:
            # DSSS - pseudo-random spreading
            code = np.random.choice([-1, 1], len(t))
            carrier = np.sin(2 * np.pi * pattern.frequency_ghz * 1e9 * t)
            signal = pattern.amplitude * carrier * code
        else:  # CHAOS - logistic map
            x = np.zeros(len(t))
            x[0] = 0.3
            for i in range(1, len(t)):
                x[i] = 3.8 * x[i-1] * (1 - x[i-1])
            signal = pattern.amplitude * (x - 0.5) * np.sin(2 * np.pi * pattern.frequency_ghz * 1e9 * t)
       
        return t, signal


