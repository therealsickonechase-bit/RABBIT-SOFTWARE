        print(f"   Patient Hash: {self.patient_hash}")
   
    def decode_waveform(self, received_signal: np.ndarray, frequency_ghz: float) -> Dict:
        """Decode received RF waveform back to token"""
       
        # Step 1: Identify waveform pattern
