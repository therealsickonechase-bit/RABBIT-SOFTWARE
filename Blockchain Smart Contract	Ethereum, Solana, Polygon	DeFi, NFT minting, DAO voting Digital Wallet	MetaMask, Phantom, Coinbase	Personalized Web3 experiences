        while current_wave:
            next_wave = []
            for node_id, emo, inten, hop in current_wave:
                if hop >= 3:  # Max 3 hops
                    continue
                
                node = self.nodes[node_id]
                
                for connected_id in self.emotional_mesh.get(node_id, []):
                    if connected_id not in visited:
                        visited.add(connected_id)
                        connected_node = self.nodes[connected_id]
                        
                        # Emotion propagates with attenuation
                        propagated_intensity = inten * 0.7
                        
                        # Update connected node's emotion
                        new_state = connected_node.update_emotion(
                            emo, propagated_intensity, EmotionalSource.SOCIAL_CONTAGION
                        )
                        
                        propagation_results.append({
                            'from': node_id,
                            'to': connected_id,
                            'emotion': emo.value,
                            'intensity': propagated_intensity,
                            'hops': hop + 1
                        })
                        
                        next_wave.append((connected_id, emo, propagated_intensity, hop + 1))
            
            current_wave = next_wave
        
        # Update hub's group emotion based on majority
        self._update_group_emotion()
        
        return {
            'source': source_node_id,
            'emotion': emotion.value,
            'nodes_reached': len(visited),
            'propagations': len(propagation_results),
            'final_group_emotion': self.group_emotion.value if self.group_emotion else None
        }
    
    def _update_group_emotion(self):
        """Aggregate individual node emotions into group emotion"""
        emotion_counts = defaultdict(int)
        for node in self.nodes.values():
            if node.current_emotion:
                emotion_counts[node.current_emotion.primary_emotion] += 1
        
        if emotion_counts:
            self.group_emotion = max(emotion_counts, key=emotion_counts.get)
            
            # Calculate group mood (positive/negative balance)
            positive_count = sum(1 for node in self.nodes.values() 
                               if node.current_emotion and 
                               node.current_emotion.valence == EmotionalValence.POSITIVE)
            self.group_mood = positive_count / len(self.nodes) if self.nodes else 0.5
    
