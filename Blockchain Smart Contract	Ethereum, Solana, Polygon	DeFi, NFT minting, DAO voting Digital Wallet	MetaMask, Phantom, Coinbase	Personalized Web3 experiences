class SelfLearningEmotionalNode:
    """
    Emotional node that learns autonomously from:
    - Personal experiences (environment + chemistry)
    - Researcher guidance (manipulations)
    - Self-correction (learning what works)
    """
    
    def __init__(self, node_id: str, learning_engine: PersonalEmotionalLearningEngine):
        self.node_id = node_id
        self.learning_engine = learning_engine
        self.current_emotion = Emotion.NEUTRAL
        self.current_intensity = 0.5
        
        # Self-learning parameters
        self.learning_rate = 0.1  # How fast it adapts
        self.exploration_rate = 0.2  # Willingness to try new patterns
        
        # Learned preferences (from years of data)
        self.preferred_environment = self._learn_preferences()
        
        print(f"\n🎯 SELF-LEARNING EMOTIONAL NODE: {node_id}")
        print(f"   Learning Rate: {self.learning_rate}")
        print(f"   Exploration Rate: {self.exploration_rate}")
    
    def _learn_preferences(self) -> Dict:
        """Learn environmental preferences from historical data"""
        cursor = self.learning_engine.learning_db.cursor()
        cursor.execute('SELECT environment_data FROM emotional_experiences LIMIT 100')
        
        environments = []
        for row in cursor.fetchall():
            env = pickle.loads(row[0])
            environments.append(env)
        
        if environments:
            return {
                'preferred_temp': np.mean([e.get('temperature', 22) for e in environments]),
                'preferred_noise': np.mean([e.get('ambient_noise_db', 40) for e in environments]),
                'preferred_light': np.mean([e.get('light_level_lux', 300) for e in environments]),
                'preferred_social': np.mean([e.get('social_proximity', 0) for e in environments])
            }
        return {}
    
    def process_experience(self, 
                           environment: Dict,
                           chemical_state: Dict,
                           researcher_manipulation: Optional[Dict] = None) -> Emotion:
        """
        Process an experience and learn from it
        Combines: environment (A) + internal state (B) + researcher guidance
        """
        # Determine which emotion this experience triggers
        if researcher_manipulation:
            # Researcher-guided learning
            target = Emotion(researcher_manipulation.get('target_emotion', 'calm'))
            triggered_emotion = target
            intensity = researcher_manipulation.get('intensity', 0.7)
            source = 'researcher_manipulation'
        else:
            # Natural experience-based learning
            triggered_emotion = self._predict_emotion_from_environment(environment, chemical_state)
            intensity = self._calculate_intensity(environment, chemical_state)
            source = 'natural_experience'
        
        # Record the experience in learning engine
        self.learning_engine.record_personal_experience(
            triggered_emotion, intensity, environment, chemical_state
        )
        
        self.current_emotion = triggered_emotion
        self.current_intensity = intensity
        
        # Update learning based on outcome
        self._update_learning(triggered_emotion, intensity)
        
        return triggered_emotion
    
    def _predict_emotion_from_environment(self, environment: Dict, chemical_state: Dict) -> Emotion:
        """Predict what emotion this environment/chemistry combination should trigger"""
        # Use learned patterns from years of data
        temp = environment.get('temperature', 22)
        noise = environment.get('ambient_noise_db', 40)
        social = environment.get('social_proximity', 0)
        
        # Apply learned preferences
        if social > 0.7:
            return Emotion.JOY
        elif noise > 70:
            return Emotion.ANGER
        elif temp > 28:
            return Emotion.FEAR if chemical_state.get('cortisol', 0.5) > 0.6 else Emotion.ANGER
        elif temp < 15:
            return Emotion.SADNESS
        else:
            return Emotion.CALM
    
    def _calculate_intensity(self, environment: Dict, chemical_state: Dict) -> float:
        """Calculate emotional intensity from environmental and chemical factors"""
        intensity = 0.5  # baseline
        
        # Chemical influence
        intensity += (chemical_state.get('norepinephrine', 0.5) - 0.5) * 0.5
        intensity += (chemical_state.get('cortisol', 0.5) - 0.5) * 0.3
        intensity += (chemical_state.get('dopamine', 0.5) - 0.5) * 0.4
        
        # Environmental influence
        noise = environment.get('ambient_noise_db', 40)
        intensity += min(0.3, (noise - 40) / 100)
        
        return np.clip(intensity, 0.1, 0.95)
    
    def _update_learning(self, emotion: Emotion, intensity: float):
        """Update self-learning parameters based on experience"""
        # Adjust learning based on emotional outcome
        if emotion in [Emotion.JOY, Emotion.CALM]:
            self.learning_rate *= 1.01  # Slightly increase learning from positive experiences
        else:
            self.learning_rate *= 0.99
    
    def get_status(self) -> Dict:
        """Get current node status"""
        return {
            'node_id': self.node_id,
            'current_emotion': self.current_emotion.value,
            'current_intensity': self.current_intensity,
            'learning_rate': self.learning_rate,
            'exploration_rate': self.exploration_rate,
            'learning_summary': self.learning_engine.get_learning_summary()
        }


