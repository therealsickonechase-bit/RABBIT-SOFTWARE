class ResearcherEmotionController:
    """
    Controller for researchers to manipulate emotional nodes
    Can guide the learning process toward desired outcomes
    """
    
    def __init__(self, researcher_id: str):
        self.researcher_id = researcher_id
        self.manipulation_log = []
        self.active_subjects: Dict[str, PersonalEmotionalLearningEngine] = {}
        
        # Desired outcome templates
        self.desired_outcomes = {
            'calm_focused': {'primary': Emotion.CALM, 'intensity': 0.7, 'secondary': Emotion.JOY},
            'happy_engaged': {'primary': Emotion.JOY, 'intensity': 0.8, 'secondary': Emotion.ANTICIPATION},
            'therapeutic_calm': {'primary': Emotion.CALM, 'intensity': 0.6, 'secondary': Emotion.TRUST},
            'performance_alert': {'primary': Emotion.ANTICIPATION, 'intensity': 0.7, 'secondary': Emotion.JOY},
        }
    
    def register_subject(self, subject_id: str, dna_sequence: str) -> PersonalEmotionalLearningEngine:
        """Register a subject for emotional manipulation research"""
        engine = PersonalEmotionalLearningEngine(subject_id, dna_sequence)
        self.active_subjects[subject_id] = engine
        return engine
    
    def apply_manipulation(self, 
                           subject_id: str, 
                           target_outcome: str,
                           method: str,
                           intensity: float,
                           duration_days: int = 7) -> Dict:
        """
        Apply emotional manipulation to achieve desired outcome
        Methods: chemical, environmental, rf_tuning, behavioral
        """
        if subject_id not in self.active_subjects:
            return {'error': 'Subject not registered'}
        
        if target_outcome not in self.desired_outcomes:
            return {'error': f'Unknown outcome: {target_outcome}'}
        
        engine = self.active_subjects[subject_id]
        outcome = self.desired_outcomes[target_outcome]
        
        manipulation_id = hashlib.sha3_256(
            f"{self.researcher_id}_{subject_id}_{time.time()}".encode()
        ).hexdigest()[:16]
        
        # Record manipulation
        manipulation = {
            'manipulation_id': manipulation_id,
            'researcher_id': self.researcher_id,
            'subject_id': subject_id,
            'target_outcome': target_outcome,
            'target_emotion': outcome['primary'].value,
            'method': method,
            'intensity': intensity,
            'duration_days': duration_days,
            'timestamp': time.time(),
            'protocol': self._generate_manipulation_protocol(method, outcome, intensity)
        }
        
        self.manipulation_log.append(manipulation)
        
        # Store in subject's database
        cursor = engine.learning_db.cursor()
        cursor.execute('''
            INSERT INTO manipulations (manipulation_id, researcher_id, target_emotion, 
                                       method, intensity, success, timestamp)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        ''', (manipulation_id, self.researcher_id, outcome['primary'].value,
              method, intensity, False, time.time()))
        engine.learning_db.commit()
        
        print(f"\n🔬 MANIPULATION APPLIED by {self.researcher_id}")
        print(f"   Subject: {subject_id}")
        print(f"   Target Outcome: {target_outcome}")
        print(f"   Method: {method}")
        print(f"   Intensity: {intensity}")
        print(f"   Duration: {duration_days} days")
        
        return manipulation
    
    def _generate_manipulation_protocol(self, method: str, outcome: Dict, intensity: float) -> Dict:
        """Generate detailed manipulation protocol"""
        protocols = {
            'chemical': {
                'target_chemicals': ['serotonin', 'dopamine'] if outcome['primary'] == Emotion.JOY else ['GABA'],
                'adjustment_delta': 0.2 * intensity,
                'administration': 'daily'
            },
            'environmental': {
                'target_temp': 22 if outcome['primary'] == Emotion.CALM else 24,
                'lighting': 'soft_warm' if outcome['primary'] == Emotion.CALM else 'bright',
                'sound': 'ambient' if outcome['primary'] == Emotion.CALM else 'upbeat'
            },
            'rf_tuning': {
                'frequency_offset': 0.001 if outcome['primary'] == Emotion.JOY else -0.001,
                'duration_minutes': 30,
                'timing': 'morning'
            },
            'behavioral': {
                'activities': ['meditation', 'breathing'] if outcome['primary'] == Emotion.CALM else ['exercise', 'social'],
                'frequency': 'daily',
                'duration_minutes': 20
            }
        }
        
        return protocols.get(method, {})
    
    def evaluate_manipulation_outcome(self, subject_id: str, manipulation_id: str) -> Dict:
        """Evaluate if manipulation achieved desired outcome"""
        if subject_id not in self.active_subjects:
            return {'error': 'Subject not found'}
        
        engine = self.active_subjects[subject_id]
        
        # Find manipulation record
        manipulation = None
        for m in self.manipulation_log:
            if m['manipulation_id'] == manipulation_id:
                manipulation = m
                break
        
        if not manipulation:
            return {'error': 'Manipulation not found'}
        
        # Get subject's current emotional profile for target emotion
        target_emotion = Emotion(manipulation['target_emotion'])
        personal_profile = engine.get_personal_emotional_profile(target_emotion)
        
        # Calculate success based on personal confidence and intensity
        success = personal_profile.get('personal_confidence', 0) > 0.6
        
        # Update manipulation record
        cursor = engine.learning_db.cursor()
        cursor.execute('''
            UPDATE manipulations SET success = ? WHERE manipulation_id = ?
        ''', (success, manipulation_id))
        engine.learning_db.commit()
        
        return {
            'manipulation_id': manipulation_id,
            'success': success,
            'current_confidence': personal_profile.get('personal_confidence', 0),
            'total_experiences': personal_profile.get('total_experiences', 0),
            'evaluation_time': time.time()
        }
    
    def run_long_term_study(self, 
                            subject_id: str, 
                            outcome: str,
                            duration_months: int = 6) -> Dict:
        """
        Run long-term emotional conditioning study
        Learns and reinforces desired emotional patterns over months
        """
        if subject_id not in self.active_subjects:
            return {'error': 'Subject not found'}
        
        engine = self.active_subjects[subject_id]
        
        study_id = hashlib.sha3_256(f"{self.researcher_id}_{subject_id}_{outcome}_{time.time()}".encode()).hexdigest()[:16]
        
        print(f"\n📊 LONG-TERM STUDY INITIATED")
        print(f"   Study ID: {study_id}")
        print(f"   Subject: {subject_id}")
        print(f"   Target Outcome: {outcome}")
        print(f"   Duration: {duration_months} months")
        print(f"   Protocol: Weekly manipulations + Daily recording")
        
        # Simulate study progression
        study_results = {
            'study_id': study_id,
            'subject_id': subject_id,
            'target_outcome': outcome,
            'duration_months': duration_months,
            'manipulations_applied': [],
            'emotional_evolution': []
        }
        
        for month in range(1, duration_months + 1):
            # Apply weekly manipulations
            for week in range(4):
                manipulation = self.apply_manipulation(
                    subject_id, outcome, 'mixed', 0.5 + (month * 0.05), 7
                )
                study_results['manipulations_applied'].append(manipulation['manipulation_id'])
            
            # Record emotional state
            profile = engine.get_personal_emotional_profile(Emotion(outcome.split('_')[0] if '_' in outcome else outcome))
            study_results['emotional_evolution'].append({
                'month': month,
                'confidence': profile.get('personal_confidence', 0),
                'experience_count': profile.get('total_experiences', 0)
            })
            
            print(f"   Month {month}: Confidence = {profile.get('personal_confidence', 0):.2%}")
        
        return study_results


