            'ear': ear,
            'resonance_hz': np.random.uniform(8000, 12000),
            'bandwidth_hz': np.random.uniform(2000, 5000),
            'sensitivity_db': np.random.uniform(-10, 10),
            'bone_conduction_enabled': True
        }
    
    def project_language_to_mind(self, language_text: str, 
                                   intensity: float = 0.7,
                                   bypass_ears: bool = False) -> Dict:
        """
        Project language directly into perception using RF
        Like a "projector" for thoughts/words
        The "broken mind" hears this as internal voice
        """
        # Convert language to RF modulation
        rf_encoding = self._encode_language_to_rf(language_text)
        
        # Calculate transmission frequency
        if bypass_ears:
            # Direct neural projection - bypass auditory system
            tx_freq = self.PERCEPTION_FREQUENCIES['direct_neural']
            carrier = np.mean(tx_freq)
            method = "direct_neural_projection"
        else:
            # Through ear canal
            tx_freq = self.PERCEPTION_FREQUENCIES['auditory_cortex']
            carrier = (self.left_ear_tuning['resonance_hz'] + 
                      self.right_ear_tuning['resonance_hz']) / 2
            method = "auditory_projection"
        
        # Calculate effective intensity
        effective_intensity = intensity * self.perception_threshold
        perceived_clarity = 1.0 - abs(carrier - np.mean(tx_freq)) / np.mean(tx_freq)
        
        projection = {
            'method': method,
            'language_text': language_text,
            'carrier_frequency_hz': carrier,
            'intensity': intensity,
            'perceived_clarity': perceived_clarity,
            'rf_encoding': rf_encoding[:100] + '...',
            'will_be_perceived_as': self._describe_perception(perceived_clarity, method),
            'timestamp': time.time()
        }
        
        self.active_language = projection
        
        print(f"\n📢 PROJECTING to {self.person_id}: '{language_text[:30]}...'")
        print(f"   Method: {method}")
        print(f"   Carrier: {carrier:.0f} Hz")
        print(f"   Clarity: {perceived_clarity:.2%}")
        
        return projection
    
    def _encode_language_to_rf(self, text: str) -> str:
        """Encode language as RF modulation pattern"""
        # Simulate RF encoding
        return ''.join(format(ord(c), '08b') for c in text[:20])
    
    def _describe_perception(self, clarity: float, method: str) -> str:
        """Describe how the projection will be perceived"""
        if clarity > 0.8:
            return "Crystal clear internal voice"
        elif clarity > 0.5:
            return "Muffled but understandable"
        elif clarity > 0.3:
            return "Whisper at edge of perception"
        else:
            return "Subconscious suggestion only"
    
    def tune_to_frequency(self, target_freq_hz: float, ear: str = 'both') -> Dict:
        """Tune ears to specific frequency for better reception"""
        result = {}
        
        if ear in ['left', 'both']:
            self.left_ear_tuning['resonance_hz'] = target_freq_hz
            result['left_ear'] = f"Tuned to {target_freq_hz:.0f} Hz"
        
        if ear in ['right', 'both']:
            self.right_ear_tuning['resonance_hz'] = target_freq_hz
            result['right_ear'] = f"Tuned to {target_freq_hz:.0f} Hz"
        
        print(f"\n🎵 Tuned {ear} ear to {target_freq_hz:.0f} Hz")
        return result


