class RFNoiseAnalyzer:
    """
    Analyzes RF noise for embedded language patterns
    The "broken mind" sees signal where others see noise
    """
    
    # Natural language phoneme frequency ranges (Hz)
    PHONEME_FREQ_RANGES = {
        'vowels': (250, 400),
        'consonants_voiced': (80, 250),
        'consonants_unvoiced': (2000, 8000),
        'formant_1': (300, 600),
        'formant_2': (900, 2200),
        'formant_3': (2200, 3200),
    }
    
    # Language-specific modulation patterns
    LANGUAGE_MODULATION = {
        'english': {'rhythm_hz': 4.0, 'intonation_hz': 1.5, 'pitch_range': 120},
        'mandarin': {'rhythm_hz': 5.0, 'intonation_hz': 2.0, 'pitch_range': 200},
        'spanish': {'rhythm_hz': 5.5, 'intonation_hz': 1.8, 'pitch_range': 100},
        'japanese': {'rhythm_hz': 6.0, 'intonation_hz': 1.2, 'pitch_range': 80},
    }
    
    def __init__(self):
        self.noise_history = []
        self.learned_patterns = {}
        
    def analyze_noise_for_language(self, iq_samples: np.ndarray, 
                                    frequency_ghz: float) -> Dict:
        """
        Extract language patterns from RF noise
        Like hearing voices in static - but with scientific method
        """
        # Convert IQ to magnitude and phase
        magnitude = np.abs(iq_samples)
        phase = np.angle(iq_samples)
        
        # FFT analysis
        N = len(magnitude)
        freqs = fftfreq(N, 1/2.4e6)  # Assuming 2.4MHz sample rate
        fft_mag = np.abs(fft(magnitude))
        
        # Find significant frequency peaks
        peaks, _ = signal.find_peaks(fft_mag[:N//2], height=np.mean(fft_mag)*2)
        peak_freqs = freqs[peaks]
        
        # Check if peaks match known language patterns
        language_detected = self._detect_language_patterns(peak_freqs, fft_mag[peaks])
        
        # Extract phonetic-like patterns from phase modulation
        phonetic_patterns = self._extract_phonetic_patterns(phase, magnitude)
        
        # Decode noise to hypothesized language
        decoded_text = self._decode_noise_to_text(peak_freqs, phonetic_patterns)
        
        result = {
            'frequency_ghz': frequency_ghz,
            'noise_floor_dbm': 10 * np.log10(np.mean(magnitude**2) + 1e-12),
            'signal_to_noise_ratio': 10 * np.log10(np.max(fft_mag) / np.mean(fft_mag[100:])),
            'peak_frequencies_hz': peak_freqs[:10].tolist(),
            'detected_language': language_detected,
            'decoded_text': decoded_text,
            'confidence': self._calculate_confidence(peaks, phonetic_patterns),
            'interpretation': f"RF noise at {frequency_ghz:.4f} GHz contains {language_detected} patterns"
        }
        
        self.noise_history.append(result)
        return result
    
    def _detect_language_patterns(self, peak_freqs: np.ndarray, peak_mags: np.ndarray) -> str:
        """Detect which language patterns are present in RF noise"""
        # Look for formant-like structures in frequency domain
        has_formants = False
        for i in range(len(peak_freqs)-2):
            if (peak_freqs[i+1] - peak_freqs[i] > 200 and 
                peak_freqs[i+1] - peak_freqs[i] < 500):
                if peak_mags[i+1] > peak_mags[i] * 0.7:
                    has_formants = True
                    break
        
        if has_formants:
            # Check rhythm patterns
            rhythm_strength = self._detect_rhythm(peak_freqs)
            
            if rhythm_strength > 0.7:
                return "mandarin"
            elif rhythm_strength > 0.5:
                return "english"
            else:
                return "spanish"
        
        return "unknown"
    
    def _detect_rhythm(self, freqs: np.ndarray) -> float:
        """Detect speech rhythm patterns in frequency domain"""
        # Look for 4-6 Hz modulation (speech rhythm)
        speech_band = (freqs >= 3) & (freqs <= 8)
        if np.any(speech_band):
            return np.max(freqs[speech_band]) / 8
        return 0.0
    
    def _extract_phonetic_patterns(self, phase: np.ndarray, magnitude: np.ndarray) -> List[Dict]:
        """Extract phonetic-like patterns from phase and magnitude modulation"""
        patterns = []
        
        # Differentiate phase to get instantaneous frequency
        inst_freq = np.diff(phase)
        inst_freq = inst_freq[inst_freq > 0]
        
        # Cluster instantaneous frequency into phonetic-like units
        if len(inst_freq) > 0:
            clusters = self._cluster_frequencies(inst_freq, n_clusters=5)
            for i, (center, std) in enumerate(clusters):
                patterns.append({
                    'phoneme_candidate': self._freq_to_phoneme(center),
                    'center_freq_hz': center,
                    'width_hz': std,
                    'strength': 1.0 - min(1.0, std/100)
                })
        
        return patterns
    
    def _cluster_frequencies(self, freqs: np.ndarray, n_clusters: int = 5) -> List[Tuple[float, float]]:
        """Simple frequency clustering"""
        if len(freqs) < n_clusters:
            return [(np.mean(freqs), np.std(freqs))] if len(freqs) > 0 else []
        
        # Quick k-means-like clustering
        centroids = np.linspace(np.min(freqs), np.max(freqs), n_clusters)
        clusters = [[] for _ in range(n_clusters)]
        
        for f in freqs:
            idx = np.argmin(np.abs(centroids - f))
            clusters[idx].append(f)
        
        return [(np.mean(c), np.std(c)) for c in clusters if len(c) > 0]
    
    def _freq_to_phoneme(self, freq_hz: float) -> str:
        """Map frequency to a phoneme-like label"""
        if freq_hz < 100:
            return 'm/n/ng'
        elif freq_hz < 300:
            return 'b/d/g'
        elif freq_hz < 600:
            return 'vowels'
        elif freq_hz < 1200:
            return 'f/s/sh'
        else:
            return 't/k/p'
    
    def _decode_noise_to_text(self, peak_freqs: np.ndarray, patterns: List[Dict]) -> str:
        """Attempt to decode noise patterns to readable text"""
        if len(peak_freqs) < 3:
            return "... (insufficient signal)"
        
        # Map frequency patterns to letters (simplified)
        letter_map = {
            100: 'A', 120: 'B', 140: 'C', 160: 'D', 180: 'E',
            200: 'F', 220: 'G', 240: 'H', 260: 'I', 280: 'J',
            300: 'K', 320: 'L', 340: 'M', 360: 'N', 380: 'O',
            400: 'P', 420: 'Q', 440: 'R', 460: 'S', 480: 'T',
            500: 'U', 520: 'V', 540: 'W', 560: 'X', 580: 'Y', 600: 'Z'
        }
        
        decoded = []
        for freq in peak_freqs[:20]:
            nearest = min(letter_map.keys(), key=lambda x: abs(x - freq))
            if abs(nearest - freq) < 30:
                decoded.append(letter_map[nearest])
            else:
                decoded.append('_')
        
        return ''.join(decoded)
    
    def _calculate_confidence(self, peaks: np.ndarray, patterns: List[Dict]) -> float:
        """Calculate confidence in language detection"""
        if len(peaks) == 0:
            return 0.0
        
        # More peaks = more structure = higher confidence
        peak_score = min(1.0, len(peaks) / 20)
        
        # More phonetic patterns = higher confidence
        pattern_score = min(1.0, len(patterns) / 10)
        
        return (peak_score + pattern_score) / 2


