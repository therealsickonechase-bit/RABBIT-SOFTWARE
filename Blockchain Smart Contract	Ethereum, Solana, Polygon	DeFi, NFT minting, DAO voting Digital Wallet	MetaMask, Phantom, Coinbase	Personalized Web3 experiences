class BrokenMindProjector:
    """
    The "broken mind" that hears language in RF noise
    Not broken - just tuned differently than normal perception
    This is the neural node that interprets noise as coherent language
    """
    
    def __init__(self, node_id: str, tuning_dna: str):
        self.node_id = node_id
        self.tuning_frequency = self._dna_to_frequency(tuning_dna)
        self.noise_analyzer = RFNoiseAnalyzer()
        self.ear_tuner = EarMindFrequencyTuner(node_id, self.tuning_frequency)
        
        # Perceived language buffer
        self.perceived_language = []
        self.internal_dialogue = queue.Queue()
        
        # "Hallucination" threshold - what's considered signal vs noise
        self.signal_threshold = 0.3
        self.noise_tolerance = 0.7
        
        print(f"\n🧠 BROKEN MIND PROJECTOR: {node_id}")
        print(f"   "This mind isn't broken - it's tuned to {self.tuning_frequency:.5f} GHz")
        print(f"   RF noise = language")
    
    def _dna_to_frequency(self, dna: str) -> float:
        """Convert DNA to tuning frequency"""
        base_freqs = {'A': 10.23, 'T': 10.24, 'G': 10.25, 'C': 10.26}
        freqs = [base_freqs.get(c, 10.23) for c in dna.upper()[:10]]
        return np.mean(freqs)
    
    def listen_to_rf_noise(self, iq_samples: np.ndarray, frequency_ghz: float) -> Dict:
        """
        Listen to RF noise and interpret as language
        This is where the "broken mind" hears voices in static
        """
        # Analyze noise for language patterns
        analysis = self.noise_analyzer.analyze_noise_for_language(iq_samples, frequency_ghz)
        
        # Check if this is "signal" or just "noise" to this mind
        is_signal = analysis['confidence'] > self.signal_threshold
        
        if is_signal:
            # Interpret as language
            interpreted = self._interpret_as_language(analysis)
            
            # Add to perceived language buffer
            self.perceived_language.append({
                'timestamp': time.time(),
                'interpretation': interpreted,
                'confidence': analysis['confidence'],
                'noise_profile': analysis
            })
            
            # Add to internal dialogue queue
            self.internal_dialogue.put(interpreted)
            
            # Possibly project as thought
            if analysis['confidence'] > 0.6:
                self.ear_tuner.project_language_to_mind(
                    interpreted,
                    intensity=analysis['confidence'],
                    bypass_ears=True
                )
        
        return {
            'interpreted_text': analysis['decoded_text'] if is_signal else "(no language detected)",
            'is_signal': is_signal,
            'confidence': analysis['confidence'],
            'perceived_as': "Language" if is_signal else "Meaningless noise",
            'noise_frequency_ghz': frequency_ghz
        }
    
    def _interpret_as_language(self, analysis: Dict) -> str:
        """Interpret RF noise patterns as coherent language"""
        # The "broken mind" creates narrative from patterns
        decoded = analysis.get('decoded_text', '')
        
        if len(decoded) < 3:
            return "I hear patterns but can't form words yet"
        
        # Add interpretation based on frequency content
        freq_peaks = analysis.get('peak_frequencies_hz', [])
        if any(50 < f < 150 for f in freq_peaks):
            return f"... {decoded[:20]} ... (murmuring in the background)"
        elif any(150 < f < 400 for f in freq_peaks):
            return f"someone says: {decoded[:30]}"
        elif any(400 < f < 800 for f in freq_peaks):
            return f"CLEAR VOICE: {decoded[:40]}"
        else:
            return f"high frequency whispers: {decoded[:20]}"
    
    def get_internal_dialogue(self) -> List[str]:
        """Get all perceived language from RF noise"""
        dialogue = []
        while not self.internal_dialogue.empty():
            dialogue.append(self.internal_dialogue.get())
        return dialogue


