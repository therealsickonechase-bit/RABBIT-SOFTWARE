        ).hexdigest()[:16]
        
        # Store in database
        cursor = self.learning_db.cursor()
        cursor.execute('''
            INSERT INTO emotional_experiences (experience_id, timestamp, emotion, intensity, 
                                               source, environment_data, chemical_state, learned_response)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
        ''', (
            experience_id, time.time(), emotion.value, intensity,
            'personal_experience', pickle.dumps(environment), 
            pickle.dumps(chemical_state), pickle.dumps({})
        ))
        self.learning_db.commit()
        
        # Update learned patterns
        self._update_learned_patterns(emotion, intensity, environment, chemical_state)
        
        self.total_experiences += 1
        self.learning_history.append({
            'experience_id': experience_id,
            'emotion': emotion.value,
            'intensity': intensity,
            'timestamp': time.time()
        })
        
        print(f"\n📝 Personal Experience Recorded: {emotion.value} (intensity: {intensity:.2f})")
        print(f"   Total experiences: {self.total_experiences}")
        
        return experience_id
    
    def _update_learned_patterns(self, 
                                  emotion: Emotion, 
                                  intensity: float,
                                  environment: Dict,
                                  chemical_state: Dict):
        """Update personal patterns based on new experience"""
        
        # Update chemical response patterns
        for chem, level in chemical_state.items():
            key = f"{emotion.value}_{chem}"
            current = self.chemical_response_patterns[key]
            # Exponential moving average (learns over time)
            new_value = current * 0.9 + level * 0.1
            self.chemical_response_patterns[key] = new_value
        
        # Update environment patterns
        env_type = self._classify_environment(environment)
        key = f"{env_type}_{emotion.value}"
        current_prob = self.environment_patterns[key]
        new_prob = current_prob * 0.95 + 0.05  # Slowly increases probability
        self.environment_patterns[key] = new_prob
    
    def _classify_environment(self, environment: Dict) -> str:
        """Classify environment type from sensor data"""
        temp = environment.get('temperature', 22)
        noise = environment.get('ambient_noise_db', 40)
        light = environment.get('light_level_lux', 300)
        social = environment.get('social_proximity', 0)
        
        if social > 0.7:
            return 'social_gathering'
        elif noise > 70:
            return 'noisy_environment'
        elif temp > 28:
            return 'hot_environment'
        elif temp < 15:
            return 'cold_environment'
        elif light < 100:
            return 'dim_environment'
        else:
            return 'neutral_environment'
    
    def get_personal_emotional_profile(self, emotion: Emotion) -> Dict:
        """
        Get PERSONALIZED emotional profile based on years of learning
        This is different from the public baseline!
        """
        base_profile = self.emotional_profiles.get(emotion, {})
        
        # Modify based on learned patterns
        personalized = base_profile.copy()
        
        # Adjust chemical signatures based on personal history
        for chem in ['dopamine', 'serotonin', 'cortisol']:
            learned_key = f"{emotion.value}_{chem}"
            if learned_key in self.chemical_response_patterns:
                personalized['chemical_signature'][chem] = self.chemical_response_patterns[learned_key]
        
        # Add personal confidence (higher with more experience)
        experience_count = len([e for e in self.learning_history if e['emotion'] == emotion.value])
        personalized['personal_confidence'] = min(0.95, 0.5 + (experience_count / 1000))
        personalized['total_experiences'] = experience_count
        personalized['learning_source'] = 'years_of_personal_experience'
        
        return personalized
    
    def get_learning_summary(self) -> Dict:
        """Get summary of years of emotional learning"""
        cursor = self.learning_db.cursor()
        cursor.execute('SELECT emotion, COUNT(*) FROM emotional_experiences GROUP BY emotion')
        emotion_counts = dict(cursor.fetchall())
        
        cursor.execute('SELECT COUNT(*) FROM emotional_experiences')
        total = cursor.fetchone()[0]
        
        return {
            'person_id': self.person_id,
            'total_lifetime_experiences': total,
            'emotion_counts': emotion_counts,
            'learned_chemical_patterns': dict(self.chemical_response_patterns),
            'environmental_conditioning': dict(self.environment_patterns),
            'public_baseline_used': True,
            'personalization_level': min(1.0, total / 1000)
        }


