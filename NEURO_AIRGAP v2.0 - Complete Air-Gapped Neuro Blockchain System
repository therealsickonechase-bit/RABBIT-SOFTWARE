# ============== SECTION 1: CRYPTOGRAPHY (AIR-GAPPED) ==============

class OfflineCryptoSuite:
    """Complete offline cryptographic suite - No network required"""
    
    # Genesis block hash (hardcoded, verifiable)
    GENESIS_HASH = "0" * 64
    MASTER_SALT = b"neuro_airgap_v2_master_salt_2024"
    
    def __init__(self, patient_id: str = None):
        self.patient_id = patient_id or self._generate_patient_id()
        self.genesis_time = time.time()
        
        # Generate ECDSA keypair (SECP256k1 - Bitcoin standard)
        self.signing_key = SigningKey.generate(curve=SECP256k1)
        self.verify_key = self.signing_key.get_verifying_key()
        
        # Derive AES key from patient ID (deterministic)
        self.aes_key = HKDF(
            algorithm=hashes.SHA3_256(),
            length=32,
            salt=self.MASTER_SALT,
            info=f"patient_{self.patient_id}".encode()
        ).derive(self.patient_id.encode() + str(self.genesis_time).encode())
        
        self.aes_cipher = AESGCM(self.aes_key)
        
        # Initialize ledger
        self.ledger_path = "patient_ledger.jsonl"
        self.blocks = []
        self.block_hashes = set()
        
        print(f"🔐 Offline Crypto Suite Initialized")
        print(f"   Patient ID: {self.patient_id[:16]}...")
        print(f"   Public Key: {self.verify_key.to_string().hex()[:16]}...")
    
    def _generate_patient_id(self) -> str:
        """Generate deterministic patient ID from hardware"""
        # Use system time + random for unique ID
        return hashlib.sha3_256(f"{time.time()}_{os.urandom(16)}".encode()).hexdigest()[:32]
    
    def sha256_airgap(self, data: Any) -> str:
        """SHA256 hash - Air-gapped calculation"""
        if isinstance(data, dict):
            data = json.dumps(data, sort_keys=True).encode()
        elif isinstance(data, str):
            data = data.encode()
        return hashlib.sha256(data).hexdigest()
    
    def sha3_256(self, data: Any) -> str:
        """SHA3-256 for quantum resistance"""
        if isinstance(data, dict):
            data = json.dumps(data, sort_keys=True).encode()
        elif isinstance(data, str):
            data = data.encode()
        return hashlib.sha3_256(data).hexdigest()
    
    def blake2b(self, data: Any) -> str:
        """BLAKE2b for high performance"""
        if isinstance(data, dict):
            data = json.dumps(data, sort_keys=True).encode()
        elif isinstance(data, str):
            data = data.encode()
        return hashlib.blake2b(data, digest_size=32).hexdigest()
    
    def sign_block(self, block: Dict) -> Dict:
        """Sign block with ECDSA"""
        block_copy = {k: v for k, v in block.items() if k not in ['signature', 'hash']}
        block_hash = self.sha256_airgap(block_copy)
        signature = self.signing_key.sign(block_hash.encode())
        block['signature'] = signature.hex()
        block['public_key'] = self.verify_key.to_string().hex()
        return block
    
    def verify_block(self, block: Dict) -> bool:
        """Verify block signature"""
        signature = bytes.fromhex(block['signature'])
        public_key = bytes.fromhex(block['public_key'])
        verify_key = VerifyingKey.from_string(public_key, curve=SECP256k1)
        
        block_copy = {k: v for k, v in block.items() 
                     if k not in ['signature', 'public_key', 'hash']}
        block_hash = self.sha256_airgap(block_copy)
        
        try:
            return verify_key.verify(signature, block_hash.encode())
        except:
            return False
    
    def encrypt_patient_data(self, data: Dict) -> Dict:
        """AES-GCM encryption for sensitive patient data"""
        nonce = os.urandom(12)
        plaintext = json.dumps(data).encode()
        ciphertext = self.aes_cipher.encrypt(nonce, plaintext, None)
        
        return {
            'nonce': nonce.hex(),
            'ciphertext': ciphertext.hex(),
            'tag': ciphertext[-16:].hex()
        }
    
    def decrypt_patient_data(self, encrypted: Dict) -> Dict:
        """Decrypt patient data"""
        nonce = bytes.fromhex(encrypted['nonce'])
        ciphertext = bytes.fromhex(encrypted['ciphertext'])
        plaintext = self.aes_cipher.decrypt(nonce, ciphertext, None)
        return json.loads(plaintext)
    
    def create_genesis_block(self, dna_hash: str) -> Dict:
        """Create the genesis block of the patient chain"""
        genesis = {
            'index': 0,
            'timestamp': self.genesis_time,
            'patient_id': self.patient_id,
            'dna_hash': dna_hash,
            'prev_hash': self.GENESIS_HASH,
            'nonce': 0,
            'data': {'type': 'GENESIS', 'version': '2.0'}
        }
        
        genesis_hash = self.sha256_airgap(genesis)
        genesis['hash'] = genesis_hash
        genesis = self.sign_block(genesis)
        
        return genesis
    
    def create_session_block(self, 
                            session_num: int,
                            dna_pattern: str,
                            power_mt: float,
                            eeg_response: Dict,
                            node_tuning: Dict,
                            prev_hash: str) -> Dict:
        """Create a new session block in the chain"""
        block = {
            'index': session_num,
            'timestamp': time.time(),
            'patient_id': self.patient_id,
            'session_data': {
                'dna_pattern': dna_pattern,
                'power_mt': power_mt,
                'eeg': eeg_response,
                'node_tuning': node_tuning
            },
            'prev_hash': prev_hash,
            'nonce': self._proof_of_work(prev_hash, session_num)
        }
        
        block['hash'] = self.sha256_airgap(block)
        block = self.sign_block(block)
        
        return block
    
    def _proof_of_work(self, prev_hash: str, index: int, difficulty: int = 4) -> int:
        """Simple proof of work for chain integrity"""
        target = '0' * difficulty
        nonce = 0
        
        while True:
            data = f"{prev_hash}{index}{nonce}".encode()
            hash_result = hashlib.sha256(data).hexdigest()
            if hash_result.startswith(target):
                return nonce
            nonce += 1
    
    def verify_chain(self, ledger_path: str = None) -> Dict:
        """Complete chain verification"""
        path = ledger_path or self.ledger_path
        
        if not os.path.exists(path):
            return {'valid': False, 'error': 'Ledger not found'}
        
        blocks = []
        with open(path, 'r') as f:
            for line in f:
                if line.strip():
                    blocks.append(json.loads(line))
        
        if not blocks:
            return {'valid': False, 'error': 'Empty ledger'}
        
        valid_count = 0
        ecdsa_valid = 0
        chain_valid = True
        prev_hash = self.GENESIS_HASH
        
        for i, block in enumerate(blocks):
            # Verify block hash
            block_copy = {k: v for k, v in block.items() 
                         if k not in ['hash', 'signature', 'public_key']}
            computed_hash = self.sha256_airgap(block_copy)
            
            if computed_hash == block.get('hash', ''):
                valid_count += 1
            
            # Verify ECDSA signature
            if self.verify_block(block):
                ecdsa_valid += 1
            
            # Verify chain linkage
            if block.get('prev_hash', '') != prev_hash:
                chain_valid = False
            
            prev_hash = block.get('hash', '')
        
        return {
            'total_blocks': len(blocks),
            'sha256_valid': valid_count,
            'ecdsa_valid': ecdsa_valid,
            'chain_valid': chain_valid,
            'integrity_score': valid_count / len(blocks) if blocks else 0
        }
    
    def export_verification_proof(self) -> Dict:
        """Export verification proof for external audit"""
        return {
            'patient_id': self.patient_id,
            'genesis_time': self.genesis_time,
            'public_key': self.verify_key.to_string().hex(),
            'genesis_hash': self.GENESIS_HASH,
            'verification_timestamp': time.time()
        }


