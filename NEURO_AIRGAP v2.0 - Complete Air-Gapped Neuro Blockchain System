        # 60 months = 5 years
        protocol_month = ((month - 1) % len(self.PROTOCOL_MATRIX)) + 1
        protocol = self.PROTOCOL_MATRIX[protocol_month]
        
        return protocol['pattern'], protocol['power']
    
