    def _calculate_resonance(self) -> float:
        """Calculate DNA resonance frequency"""
        freqs = [self.BASE_RESONANCE.get(c, 15.5e12) for c in self.dna_sequence]
        return np.mean(freqs)
    
    def _generate_vectors(self) -> Dict:
        """Generate stimulation vectors"""
        vectors = {}
        
        for month, protocol in self.PROTOCOL_MATRIX.items():
            # DNA-modulated vector
            vector = {
                'pattern': protocol['pattern'],
                'power_mt': protocol['power'],
                'frequency_hz': protocol['frequency'],
                'resonance_shift': self.resonance_ghz * (1 + (protocol['power'] - 1.5) * 0.1),
                'dna_modulation': hashlib.sha256(
                    f"{self.dna_sequence}_{protocol['pattern']}".encode()
                ).hexdigest()[:8]
            }
            vectors[month] = vector
        
        return vectors
    
    def get_stimulus_vector(self, month: int) -> Tuple[str, float]:
