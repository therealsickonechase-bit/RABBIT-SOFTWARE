            self.model_weights['theta_sensitivity'] *= 1.01
            self.model_weights['dna_affinity'] += 0.01
        else:
            self.model_weights['alpha_sensitivity'] *= 0.98
            self.model_weights['theta_sensitivity'] *= 0.99
        
        # Normalize weights
        total = sum(self.model_weights.values())
        for k in self.model_weights:
            self.model_weights[k] /= total
        
        # Save state
        self._save_state()
    
    def predict_optimal_pattern(self, day_of_treatment: int) -> str:
        """
        Predict optimal stimulation pattern based on history
        """
        if not self.biological_responses:
            # Default progression
            patterns = ['1010', '1100', '1110', '1111', '1011']
            return patterns[day_of_treatment % len(patterns)]
        
        # Use recent successes to guide pattern selection
        recent_successes = [r for r in self.biological_responses[-10:] if r['success']]
        
        if len(recent_successes) >= 3:
            # Pattern modulation based on efficacy
            efficacy = np.mean([r['updrs_change'] for r in recent_successes])
            if efficacy < -0.5:  # Good response
                return '1111'  # Maximum stimulation
            elif efficacy < -0.2:
                return '1110'
            else:
                return '1100'
        
        return '1010'
    
    def generate_training_token(self) -> str:
        """
        Generate training token for model fine-tuning
        Deterministic based on patient history
        """
        token_material = {
            'pattern_count': len(self.personal_patterns),
            'response_count': len(self.biological_responses),
            'avg_efficacy': np.mean([r['updrs_change'] for r in self.biological_responses]) if self.biological_responses else 0,
            'weights': self.model_weights,
            'timestamp': int(time.time() / 86400)  # Daily rotation
        }
        
        return hashlib.blake2b(
            json.dumps(token_material, sort_keys=True).encode(),
            digest_size=32
        ).hexdigest()
    
    def _save_state(self):
        """Save learning state to disk"""
        state = {
            'personal_patterns': self.personal_patterns,
            'biological_responses': self.biological_responses[-1000:],  # Keep last 1000
            'efficacy_history': self.efficacy_history,
            'model_weights': self.model_weights,
            'timestamp': time.time()
        }
        
        with open('llm/patient_state.json', 'w') as f:
            json.dump(state, f)
    
    def _load_state(self):
        """Load saved learning state"""
        try:
            with open('llm/patient_state.json', 'r') as f:
                state = json.load(f)
                self.personal_patterns = state.get('personal_patterns', [])
                self.biological_responses = state.get('biological_responses', [])
                self.efficacy_history = state.get('efficacy_history', [])
                self.model_weights = state.get('model_weights', self.model_weights)
        except:
            pass
    
    def get_insights(self) -> Dict:
        """Generate insights from learning history"""
        if not self.biological_responses:
            return {'status': 'Insufficient data'}
        
        recent = self.biological_responses[-30:]
        success_rate = sum(1 for r in recent if r['success']) / len(recent) if recent else 0
        
        return {
            'total_sessions': len(self.biological_responses),
            'recent_success_rate': success_rate,
            'avg_updrs_change': np.mean([r['updrs_change'] for r in recent]),
            'learned_patterns': len(set(self.personal_patterns)),
            'model_weights': self.model_weights,
            'training_token': self.generate_training_token()[:16]
        }


