def scan_shard(shard: dict) -> float:
    """Threat score shard (0-1)"""
    score = 0.0
    suspicious_keywords = ["malware", "ransomware", "phish"]
    for kw in suspicious_keywords:
        if kw in str(shard).lower():
            score += 0.3
    return min(score, 1.0)

