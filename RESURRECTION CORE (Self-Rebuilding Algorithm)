BITCOIN_CLI = r'"C:\Program Files\Bitcoin\daemon\bitcoin-cli.exe"'
db = sqlite3.connect("resurrection_shards.db", check_same_thread=False)

@dataclass
class ResurrectionShard:
    shard_id: str
    original_hash: str      # Original API state hash
    owner_identity: str
    data_fragment: bytes
    bounty_reward: float    # BTC bounty
    recovery_status: str    # "lost", "recovered", "rebuilt"

class ResurrectionEngine:
    def __init__(self):
        self.shards: Dict[str, ResurrectionShard] = {}
        self.original_state_hash = None
        self.recovery_threshold = 0.8  # 80% shards needed
        self.init_resurrection_db()
    
    def init_resurrection_db(self):
        db.execute("""
            CREATE TABLE IF NOT EXISTS resurrection_shards (
                shard_id TEXT PRIMARY KEY,
                original_hash TEXT,
                owner_identity TEXT,
                fragment BLOB,
                bounty_btc REAL,
                status TEXT,
                recovered_by TEXT,
                timestamp DATETIME DEFAULT CURRENT_TIMESTAMP
            )
        """)
        db.commit()
    
    async def detect_flatline(self) -> bool:
        """Detect if network/API is stolen/flatlined"""
        # Check core files missing/corrupted
        import os
        core_files = ["medical_blocknet_secure.py", "shard_manager.py"]
        missing = sum(1 for f in core_files if not os.path.exists(f))
        
        # Check state hash mismatch
        current_hash = self.compute_current_state_hash()
        return missing > 0 or current_hash != self.original_state_hash
    
    def compute_current_state_hash(self) -> str:
        """Hash of current API/network state"""
        state = {
            "files": {f: hashlib.sha256(open(f,"rb").read()).hexdigest() 
                     for f in os.listdir(".") if f.endswith(".py")},
            "db_hash": hashlib.sha256(open("resurrection_shards.db","rb").read()).hexdigest()
        }
        return hashlib.sha256(json.dumps(state, sort_keys=True).encode()).hexdigest()
    
    async def auto_resurrect(self):
        """AUTO-REBUILD from shards if flatlined"""
        if not await self.detect_flatline():
            print("✅ Network healthy - no resurrection needed")
            return False
        
        print("💀 FLATLINE DETECTED - INITIATING RESURRECTION...")
        
        # Phase 1: Collect shards via bug bounty + P2P
        recovered_shards = await self.recover_shards()
        
        recovery_rate = len(recovered_shards) / self.get_total_shards()
        print(f"📊 Recovery: {recovery_rate:.1%} ({len(recovered_shards)}/{self.get_total_shards()})")
        
        if recovery_rate >= self.recovery_threshold:
            # Phase 2: Rebuild original state
            await self.rebuild_from_shards(recovered_shards)
            # Phase 3: Pay bounties
            await self.pay_bug_bounties(recovered_shards)
            print("🎉 RESURRECTION COMPLETE - Network rebuilt!")
            return True
        else:
            print("⚠️  Insufficient shards - bounty program active")
            return False
    
    async def recover_shards(self) -> List[ResurrectionShard]:
        """Recover shards via bug bounty + P2P"""
        shards = []
        
        # Bug bounty recovery
        bounty_shards = bugbounty_manager.query_bounties(self.original_state_hash)
        shards.extend(bounty_shards)
        
        # P2P network recovery
        p2p_shards = await self.query_p2p_shards()
        shards.extend(p2p_shards)
        
        # Local shard recovery
        local_shards = self.load_local_shards()
        shards.extend(local_shards)
        
        return shards
    
    async def rebuild_from_shards(self, shards: List[ResurrectionShard]):
        """Rebuild original API/network from shard fragments"""
        # Reconstruct original state
        reconstructed_data = self.merge_shard_fragments(shards)
        
        # Rewrite core files
        self.restore_core_files(reconstructed_data)
        
        # Restart services
        subprocess.Popen(["python", "medical_blocknet_secure.py"])
        
        # Update state hash
        self.original_state_hash = self.compute_current_state_hash()
    
    def merge_shard_fragments(self, shards: List[ResurrectionShard]) -> bytes:
        """Merkle-tree shard reconstruction"""
        # Sort by shard_id, reconstruct original data
        sorted_shards = sorted(shards, key=lambda s: s.shard_id)
        return b''.join(s.data_fragment for s in sorted_shards)
    
    def restore_core_files(self, data: bytes):
        """Overwrite stolen/corrupted files"""
        files = {
            "medical_blocknet_secure.py": data[:50000],
            "shard_manager.py": data[50000:80000],
            # ... etc
        }
        for filename, content in files.items():
            with open(filename, "wb") as f:
                f.write(content)
    
    async def pay_bug_bounties(self, shards: List[ResurrectionShard]):
        """Pay BTC bounties to recoverers"""
        for shard in shards:
            if shard.recovery_status == "recovered":
                bounty_tx = self.create_bounty_payment(shard.recovered_by, shard.bounty_reward)
                print(f"💰 Bounty paid: {shard.bounty_reward} BTC to {shard.recovered_by}")

