def sha256_hash(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()

def aes_encrypt(plain: bytes, key: bytes) -> Tuple[bytes, bytes]:
    nonce = os.urandom(12)
    cipher = AESGCM(key)
    ct = cipher.encrypt(nonce, plain, None)
    return ct, nonce

def aes_decrypt(ct: bytes, nonce: bytes, key: bytes) -> bytes:
    cipher = AESGCM(key)
    return cipher.decrypt(nonce, ct, None)

def fingerprint_to_frequency(fingerprint_hex: str, age: int) -> float:
    ikm = bytes.fromhex(fingerprint_hex)
    salt = struct.pack(">I", age)
    hkdf = HKDF(algorithm=hashes.SHA256(), length=4, salt=salt, info=b"RF_FREQ")
    rand32 = int.from_bytes(hkdf.derive(ikm), byteorder='big')
    offset = (rand32 / (2**32)) * BANDWIDTH_GHZ
    return BASE_FREQ_GHZ + offset

