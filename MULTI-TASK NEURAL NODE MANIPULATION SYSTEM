class MultiTaskController:
    """
    High-level controller for orchestrating multiple simultaneous tasks
    Allows nodes to run image generation AND chemical changes concurrently
    """
    
    def __init__(self):
        self.cluster = NeuralNodeCluster(grid_size=(8, 8))  # 64 nodes
        self.superposition = WaveSuperpositionEngine()
        self.global_task_log = []
        
        print("\n" + "="*60)
        print("🎮 MULTI-TASK CONTROLLER ACTIVE")
        print("   Nodes can run: Image Generation + Chemical Changes + Memory Formation")
        print("   All simultaneously on the same nodes!")
        print("="*60)
    
    def run_desired_image_with_chemicals(self, 
                                         desired_image: str,
                                         target_chemicals: List[str],
                                         intensity: float = 1.0) -> Dict:
        """
        Main function: Generate desired image AND induce chemical changes
        Both happen simultaneously on the node network
        """
        print(f"\n{'='*60}")
        print(f"🎯 TASK: Generate '{desired_image}' WITH Chemical Changes")
        print(f"   Chemicals: {target_chemicals}")
        print(f"   Intensity: {intensity}")
        print(f"{'='*60}")
        
        # Run simultaneous operations
        result = self.cluster.simultaneous_image_and_chemical(
            image_description=desired_image,
            chemical_targets=target_chemicals
        )
        
        # Get final cluster state
        cluster_state = self.cluster.get_cluster_status()
        
        # Combine outputs through wave superposition
        if result['results']:
            image_results = [r for r in result['results'] if r['type'] == 'image']
            chemical_results = [r for r in result['results'] if r['type'] == 'chemical']
            
            # Extract chemical states from all nodes
            all_chemical_states = {}
            for node in self.cluster.nodes.values():
                for chem, conc in node.chemical_state.items():
                    all_chemical_states[chem] = all_chemical_states.get(chem, 0) + conc
            
            # Log to global task log
            self.global_task_log.append({
                'timestamp': time.time(),
                'desired_image': desired_image,
                'target_chemicals': target_chemicals,
                'intensity': intensity,
                'image_tasks_completed': len(image_results),
                'chemical_tasks_completed': len(chemical_results),
                'resulting_chemical_states': all_chemical_states,
                'cluster_state': cluster_state
            })
            
            return {
                'success': True,
                'desired_image': desired_image,
                'chemical_changes': all_chemical_states,
                'image_count': len(image_results),
                'chemical_count': len(chemical_results),
                'cluster_activation': cluster_state['avg_activation'],
                'execution_time': time.time()
            }
        
        return {'success': False, 'error': 'No tasks completed'}
    
    def parallel_image_generation_batch(self, images: List[str]) -> Dict:
        """
        Generate multiple images in parallel across different nodes
        """
        print(f"\n🖼️ Parallel Image Generation Batch: {len(images)} images")
        
        task_ids = self.cluster.parallel_image_generation(len(images))
        
        return {
            'total_images': len(images),
            'task_ids': task_ids,
            'nodes_used': len(self.cluster.nodes),
            'parallel_execution': True
        }
    
    def parallel_chemical_modulation_batch(self, chemicals: List[str]) -> Dict:
        """
        Induce multiple chemical changes in parallel
        """
        print(f"\n🧪 Parallel Chemical Modulation: {len(chemicals)} chemicals")
        
        task_ids = self.cluster.parallel_chemical_modulation(chemicals)
        
        # Get resulting chemical states
        final_states = {}
        for node in self.cluster.nodes.values():
            for chem, conc in node.chemical_state.items():
                final_states[chem] = final_states.get(chem, 0) + conc
        
        return {
            'chemicals_modulated': chemicals,
            'task_ids': task_ids,
            'final_concentrations': final_states,
            'nodes_used': len(self.cluster.nodes)
        }
    
    def continuous_monitoring(self, duration_seconds: int = 30):
        """
        Run continuous operations: generate images while monitoring chemistry
        """
        print(f"\n🔍 Continuous Multi-Task Monitoring ({duration_seconds}s)")
        print("   Generating images AND monitoring chemical changes simultaneously")
        
        start_time = time.time()
        operations = []
        
        # Sample images and chemical targets
        images = [
            "peaceful mountain landscape",
            "neural network visualization",
            "vibrant abstract art",
            "calm ocean waves",
            "forest with glowing neurons"
        ]
        
        chemical_sets = [
            ['dopamine', 'serotonin'],
            ['GABA', 'glutamate'],
            ['acetylcholine', 'dopamine'],
            ['serotonin', 'norepinephrine'],
            ['dopamine', 'GABA', 'serotonin']
        ]
        
        operation_count = 0
        while time.time() - start_time < duration_seconds:
            # Select random image and chemicals
            image = images[operation_count % len(images)]
            chemicals = chemical_sets[operation_count % len(chemical_sets)]
            
            # Run simultaneous operation
            result = self.run_desired_image_with_chemicals(image, chemicals, intensity=0.7)
            operations.append(result)
            
            operation_count += 1
            print(f"   [{operation_count}] Generated '{image}' with {chemicals}")
            
            time.sleep(5)  # Wait between operations
        
        print(f"\n✅ Continuous Monitoring Complete")
        print(f"   Total Operations: {len(operations)}")
        print(f"   Successful: {sum(1 for o in operations if o.get('success'))}")
        
        return operations
    
    def get_system_status(self) -> Dict:
        """Get complete system status"""
        cluster_status = self.cluster.get_cluster_status()
        
        return {
            'total_nodes': cluster_status['total_nodes'],
            'current_active_tasks': cluster_status['active_tasks'],
            'avg_node_activation': cluster_status['avg_activation'],
            'total_memories_stored': cluster_status['total_memories'],
            'operations_logged': len(self.global_task_log),
            'recent_operations': self.global_task_log[-5:] if self.global_task_log else []
        }


