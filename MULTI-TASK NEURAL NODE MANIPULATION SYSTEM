class NeuralNodeCluster:
    """
    Cluster of nodes working in parallel on multiple tasks
    Supports simultaneous image generation and chemical changes
    """
    
    def __init__(self, grid_size: Tuple[int, int] = (5, 5)):
        self.nodes: Dict[str, MultiTaskNeuralNode] = {}
        self.node_grid = [[None for _ in range(grid_size[1])] for _ in range(grid_size[0])]
        
        # Brain region mapping for node placement
        self.regions = ['visual_cortex', 'prefrontal_cortex', 'motor_cortex', 
                       'hippocampus', 'thalamus', 'hypothalamus', 'amygdala']
        
        self._create_cluster(grid_size)
        
        print(f"\n🌐 Neural Node Cluster Created")
        print(f"   Grid: {grid_size[0]}x{grid_size[1]} = {grid_size[0]*grid_size[1]} nodes")
        print(f"   Max Parallel Tasks: {grid_size[0]*grid_size[1] * 10}")
    
    def _create_cluster(self, grid_size: Tuple[int, int]):
        """Create the node cluster"""
        node_id = 0
        for i in range(grid_size[0]):
            for j in range(grid_size[1]):
                region = self.regions[(i * j) % len(self.regions)]
                x = i * 10  # mm
                y = j * 10  # mm
                z = 50      # mm depth
                
                node = MultiTaskNeuralNode(f"N_{node_id:04d}", (x, y, z), region, max_concurrent_tasks=10)
                self.nodes[node.node_id] = node
                self.node_grid[i][j] = node
                node_id += 1
    
    def parallel_image_generation(self, num_images: int = 5) -> List[str]:
        """
        Generate multiple images simultaneously across different nodes
        Each node generates a different part/aspect of the image
        """
        print(f"\n🎨 Parallel Image Generation: {num_images} images")
        
        task_ids = []
        
        # Distribute image generation tasks across nodes
        for img_idx in range(num_images):
            # Select node based on image region
            node_list = list(self.nodes.values())
            node = node_list[img_idx % len(node_list)]
            
            # Parameters for image generation
            params = {
                'neural_pattern': np.random.rand(64, 64),
                'image_style': ['abstract', 'realistic', 'dreamlike'][img_idx % 3],
                'resolution': (512, 512),
                'color_space': 'RGB'
            }
            
            task_id = node.add_task(
                task_type=TaskType.IMAGE_GENERATION,
                parameters=params,
                priority=8,
                duration=2.0
            )
            task_ids.append(task_id)
        
        return task_ids
    
    def parallel_chemical_modulation(self, chemicals: List[str]) -> List[str]:
        """
        Simultaneously modulate multiple neurotransmitters across nodes
        Each node targets a specific chemical change
        """
        print(f"\n🧪 Parallel Chemical Modulation: {chemicals}")
        
        task_ids = []
        
        for chem_idx, chemical in enumerate(chemicals):
            # Find node tuned to this chemical's frequency
            target_freq = {
                'dopamine': 10.23,
                'serotonin': 10.24,
                'acetylcholine': 10.25,
                'GABA': 10.26,
                'glutamate': 10.27
            }.get(chemical, 10.23)
            
            # Find node with matching frequency
            selected_node = None
            for node in self.nodes.values():
                if abs(node.frequency_allocation.get('chemical', 10.23) - target_freq) < 0.01:
                    selected_node = node
                    break
            
            if not selected_node:
                selected_node = list(self.nodes.values())[chem_idx % len(self.nodes)]
            
            params = {
                'neurotransmitter': chemical,
                'concentration_change': np.random.uniform(0.05, 0.2),
                'duration_sec': 5.0,
                'modulation_type': 'increase' if chem_idx % 2 == 0 else 'decrease'
            }
            
            task_id = selected_node.add_task(
                task_type=TaskType.CHEMICAL_MODULATION,
                parameters=params,
                priority=9,  # High priority for chemical changes
                duration=5.0
            )
            task_ids.append(task_id)
        
        return task_ids
    
    def simultaneous_image_and_chemical(self, 
                                        image_description: str,
                                        chemical_targets: List[str]) -> Dict:
        """
        Run image generation AND chemical changes SIMULTANEOUSLY
        This is the key function - multiple tasks at the same time
        """
        print(f"\n⚡ SIMULTANEOUS OPERATIONS")
        print(f"   Image Generation: {image_description}")
        print(f"   Chemical Targets: {chemical_targets}")
        
        all_task_ids = []
        
        # Start image generation tasks
        image_nodes = list(self.nodes.values())[:5]  # First 5 nodes for images
        for i, node in enumerate(image_nodes):
            params = {
                'neural_pattern': self._text_to_pattern(f"{image_description}_{i}"),
                'image_style': 'neural_art',
                'target_region': node.region
            }
            task_id = node.add_task(
                task_type=TaskType.IMAGE_GENERATION,
                parameters=params,
                priority=7,
                duration=2.0
            )
            all_task_ids.append(('image', node.node_id, task_id))
        
        # Start chemical modulation tasks (SIMULTANEOUS)
        chemical_nodes = list(self.nodes.values())[5:5+len(chemical_targets)]
        for i, (node, chemical) in enumerate(zip(chemical_nodes, chemical_targets)):
            params = {
                'neurotransmitter': chemical,
                'concentration_change': 0.15,
                'duration_sec': 3.0
            }
            task_id = node.add_task(
                task_type=TaskType.CHEMICAL_MODULATION,
                parameters=params,
                priority=9,  # Higher priority than image
                duration=3.0
            )
            all_task_ids.append(('chemical', node.node_id, task_id))
        
        # Wait for tasks to complete (simulated)
        time.sleep(2.0)
        
        # Collect results
        results = []
        for task_type, node_id, task_id in all_task_ids:
            node = self.nodes[node_id]
            result = node.get_task_result(task_id)
            if result:
                results.append({
                    'type': task_type,
                    'node': node_id,
                    'result': result
                })
        
        return {
            'total_tasks': len(all_task_ids),
            'image_tasks': len([r for r in results if r['type'] == 'image']),
            'chemical_tasks': len([r for r in results if r['type'] == 'chemical']),
            'results': results,
            'simultaneous_execution': True,
            'timestamp': time.time()
        }
    
    def _text_to_pattern(self, text: str) -> np.ndarray:
        """Convert text description to neural pattern"""
        hash_val = hashlib.sha256(text.encode()).hexdigest()
        pattern = np.zeros((64, 64))
        for i, c in enumerate(hash_val[:64]):
            pattern[i % 64, i % 64] = int(c, 16) / 15.0
        return pattern
    
    def get_cluster_status(self) -> Dict:
        """Get status of entire cluster"""
        node_statuses = [node.get_status() for node in self.nodes.values()]
        
        return {
            'total_nodes': len(self.nodes),
            'active_tasks': sum(s['active_tasks'] for s in node_statuses),
            'avg_activation': np.mean([s['activation'] for s in node_statuses]),
            'total_chemical_states': len([s['chemical_state'] for s in node_statuses if s['chemical_state']]),
            'total_memories': sum(s['memory_count'] for s in node_statuses),
            'nodes': node_statuses[:5]  # First 5 nodes for preview
        }


