class TaskType(Enum):
    IMAGE_GENERATION = "image_generation"
    CHEMICAL_MODULATION = "chemical_modulation"
    MEMORY_ENCODING = "memory_encoding"
    RF_SIGNALING = "rf_signaling"
    NEURAL_STIMULATION = "neural_stimulation"
    BIOMARKER_DETECTION = "biomarker_detection"


@dataclass
class NodeTask:
    """A task running on a neural node"""
    task_id: str
    task_type: TaskType
    priority: int  # 1-10, higher = more important
    parameters: Dict
    start_time: float
    duration: float
    current_progress: float
    output_buffer: List[Any]
    rf_frequency: float
    
class MultiTaskNeuralNode:
    """
    Neural node capable of running multiple simultaneous tasks
    Uses parallel processing and frequency multiplexing
    """
    
    # Base RF frequency (GHz)
    BASE_FREQ = 10.23
    FREQ_BANDWIDTH = 0.01  # 10 MHz per channel
    
    def __init__(self, node_id: str, position: Tuple[float, float, float], 
                 region: str, max_concurrent_tasks: int = 10):
        self.node_id = node_id
        self.position = position
        self.region = region
        self.max_concurrent_tasks = max_concurrent_tasks
        
        # Task management
        self.active_tasks: Dict[str, NodeTask] = {}
        self.task_queue = queue.PriorityQueue()
        self.task_history = []
        
        # Frequency allocation for different tasks
        self.frequency_allocation = {}
        self.next_freq_offset = 0.0
        
        # Node state
        self.activation_state = 0.0
        self.chemical_state = {}  # neurotransmitter/receptor states
        self.memory_traces = []
        
        # Parallel processing threads
        self.running = True
        self.task_threads = []
        self._init_threads()
        
        print(f"🧠 Multi-Task Node {node_id} Ready")
        print(f"   Region: {region}")
        print(f"   Max Concurrent Tasks: {max_concurrent_tasks}")
    
    def _init_threads(self):
        """Initialize parallel processing threads"""
        for i in range(self.max_concurrent_tasks):
            thread = threading.Thread(target=self._task_worker, args=(i,), daemon=True)
            thread.start()
            self.task_threads.append(thread)
    
    def _task_worker(self, worker_id: int):
        """Worker thread that executes tasks"""
        while self.running:
            try:
                # Get highest priority task
                priority, task = self.task_queue.get(timeout=0.1)
                
                # Execute task
                result = self._execute_task(task)
                
                # Store result
                task.output_buffer.append(result)
                task.current_progress = 1.0
                
                # Archive task
                self.task_history.append({
                    'task': task.task_id,
                    'type': task.task_type.value,
                    'result': result,
                    'completion_time': time.time()
                })
                
            except queue.Empty:
                continue
    
    def _execute_task(self, task: NodeTask) -> Dict:
        """Execute a specific task on this node"""
        
        if task.task_type == TaskType.IMAGE_GENERATION:
            return self._generate_image(task.parameters)
        
        elif task.task_type == TaskType.CHEMICAL_MODULATION:
            return self._modulate_chemistry(task.parameters)
        
        elif task.task_type == TaskType.MEMORY_ENCODING:
            return self._encode_memory(task.parameters)
        
        elif task.task_type == TaskType.RF_SIGNALING:
            return self._transmit_rf(task.parameters)
        
        elif task.task_type == TaskType.NEURAL_STIMULATION:
            return self._stimulate_neurons(task.parameters)
        
        elif task.task_type == TaskType.BIOMARKER_DETECTION:
            return self._detect_biomarkers(task.parameters)
        
        return {'error': f'Unknown task type: {task.task_type}'}
    
    def _generate_image(self, params: Dict) -> Dict:
        """Generate image from neural pattern"""
        pattern = params.get('neural_pattern', np.random.rand(64, 64))
        
        # Simulate image generation from neural activity
        image = np.random.randint(0, 255, (256, 256, 3), dtype=np.uint8)
        
        # Apply neural modulation
        modulation = np.mean(pattern) * 255
        image = (image * (modulation / 255)).clip(0, 255).astype(np.uint8)
        
        return {
            'task_type': 'image_generation',
            'image_shape': image.shape,
            'intensity': float(modulation),
            'hash': hashlib.md5(image.tobytes()).hexdigest()[:16]
        }
    
    def _modulate_chemistry(self, params: Dict) -> Dict:
        """
        Induce chemical changes via RF resonance
        Each neurotransmitter has specific resonance frequency
        """
        neurotransmitter = params.get('neurotransmitter', 'dopamine')
        concentration_change = params.get('concentration_change', 0.1)
        
        # RF frequencies for neurotransmitter modulation (GHz)
        neurotransmitter_freqs = {
            'dopamine': 10.23,
            'serotonin': 10.24,
            'acetylcholine': 10.25,
            'GABA': 10.26,
            'glutamate': 10.27,
            'norepinephrine': 10.28
        }
        
        # Check if node is tuned to this frequency
        target_freq = neurotransmitter_freqs.get(neurotransmitter, 10.23)
        current_freq = self.frequency_allocation.get('chemical', self.BASE_FREQ)
        
        if abs(current_freq - target_freq) < 0.01:
            # Node can modulate this neurotransmitter
            self.chemical_state[neurotransmitter] = self.chemical_state.get(neurotransmitter, 0) + concentration_change
            
            return {
                'task_type': 'chemical_modulation',
                'neurotransmitter': neurotransmitter,
                'concentration_delta': concentration_change,
                'new_concentration': self.chemical_state[neurotransmitter],
                'resonance_match': True,
                'rf_frequency_ghz': target_freq
            }
        else:
            return {
                'task_type': 'chemical_modulation',
                'neurotransmitter': neurotransmitter,
                'success': False,
                'error': f'Node tuned to {current_freq:.4f} GHz, need {target_freq:.4f} GHz',
                'rf_frequency_ghz': current_freq
            }
    
    def _encode_memory(self, params: Dict) -> Dict:
        """Encode a memory trace"""
        memory_pattern = params.get('memory_pattern', np.random.rand(100))
        strength = params.get('strength', 0.7)
        
        memory_id = hashlib.sha256(memory_pattern.tobytes()).hexdigest()[:16]
        
        self.memory_traces.append({
            'memory_id': memory_id,
            'pattern_hash': memory_id,
            'strength': strength,
            'timestamp': time.time()
        })
        
        return {
            'task_type': 'memory_encoding',
            'memory_id': memory_id,
            'strength': strength,
            'trace_count': len(self.memory_traces)
        }
    
    def _transmit_rf(self, params: Dict) -> Dict:
        """Transmit RF signal to other nodes"""
        signal = params.get('signal', [])
        target_nodes = params.get('target_nodes', [])
        
        return {
            'task_type': 'rf_signaling',
            'signal_length': len(signal),
            'target_count': len(target_nodes),
            'transmitted': True,
            'frequency_ghz': self.frequency_allocation.get('rf', self.BASE_FREQ)
        }
    
    def _stimulate_neurons(self, params: Dict) -> Dict:
        """Apply neural stimulation"""
        intensity = params.get('intensity', 0.5)
        duration_ms = params.get('duration_ms', 100)
        
        # Update activation state
        self.activation_state = min(1.0, self.activation_state + intensity * 0.1)
        
        return {
            'task_type': 'neural_stimulation',
            'intensity': intensity,
            'duration_ms': duration_ms,
            'new_activation': self.activation_state
        }
    
    def _detect_biomarkers(self, params: Dict) -> Dict:
        """Detect molecular biomarkers"""
        biomarkers = {
            'alpha_synuclein': np.random.uniform(0, 10),
            'tau_protein': np.random.uniform(0, 20),
            'amyloid_beta': np.random.uniform(0, 15),
            'bdnf': np.random.uniform(0, 5)
        }
        
        return {
            'task_type': 'biomarker_detection',
            'biomarkers': biomarkers,
            'abnormal_flags': {k: v > 8 for k, v in biomarkers.items()}
        }
    
    def add_task(self, task_type: TaskType, parameters: Dict, 
                 priority: int = 5, duration: float = 1.0) -> str:
        """Add a new task to this node's queue"""
        task_id = hashlib.sha256(f"{self.node_id}_{task_type.value}_{time.time()}".encode()).hexdigest()[:16]
        
        # Allocate frequency for this task
        freq_offset = self.next_freq_offset
        self.next_freq_offset += self.FREQ_BANDWIDTH
        rf_frequency = self.BASE_FREQ + freq_offset
        
        task = NodeTask(
            task_id=task_id,
            task_type=task_type,
            priority=priority,
            parameters=parameters,
            start_time=time.time(),
            duration=duration,
            current_progress=0.0,
            output_buffer=[],
            rf_frequency=rf_frequency
        )
        
        # Store frequency allocation
        self.frequency_allocation[task_id] = rf_frequency
        
        # Add to queue (negative for max-heap behavior)
        self.task_queue.put((-priority, task))
        
        print(f"   📋 Task Added: {task_type.value} (ID: {task_id[:8]}) @ {rf_frequency:.4f} GHz")
        
        return task_id
    
    def get_task_result(self, task_id: str) -> Optional[Dict]:
        """Get result of completed task"""
        for task in self.task_history:
            if task['task'] == task_id:
                return task['result']
        return None
    
    def get_status(self) -> Dict:
        """Get node status"""
        return {
            'node_id': self.node_id,
            'region': self.region,
            'active_tasks': len(self.active_tasks),
            'queue_size': self.task_queue.qsize(),
            'activation': self.activation_state,
            'chemical_state': self.chemical_state,
            'memory_count': len(self.memory_traces),
            'frequency_allocation': self.frequency_allocation
        }


