driver = GraphDatabase.driver("bolt://neo4j:7687")

def link(a, b):
    with driver.session() as s:
        s.run("MERGE (a:Node {id:$a}) MERGE (b:Node {id:$b}) MERGE (a)-[:LINK]->(b)", a=a, b=b)


