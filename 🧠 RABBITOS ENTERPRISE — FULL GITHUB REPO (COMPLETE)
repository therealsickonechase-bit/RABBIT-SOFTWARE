```python id="orchestrator"
from fastapi import FastAPI
from pydantic import BaseModel

app = FastAPI()

class Task(BaseModel):
    prompt: str
    priority: str = "normal"

class Router:
    def route(self, task):
        if task.priority == "realtime":
            return {"route": "edge"}
        if len(task.prompt) > 2000:
            return {"route": "batch-cluster"}
        return {"route": "llm-fleet"}

router = Router()

@app.post("/route")
def route(task: Task):
    return router.route(task)


