🚀 1. BOOTSTRAP SCRIPT (ONE COMMAND ENTRY)

#!/bin/bash

set -e

echo "🚀 RabbitOS Enterprise Bootstrapping..."

CLOUD=${1:-aws}

if [ "$CLOUD" == "aws" ]; then
  echo "☁️ Deploying AWS Infrastructure..."

  cd terraform/aws
  terraform init
  terraform apply -auto-approve

  echo "☸️ Configuring Kubernetes..."
  aws eks update-kubeconfig --name rabbitos-prod

  cd ../../scripts
  chmod +x *.sh

  ./install_helm.sh
  ./deploy_k8s.sh
  ./configure_dns.sh
  ./verify.sh

  echo "✅ RabbitOS Enterprise LIVE"
fi


