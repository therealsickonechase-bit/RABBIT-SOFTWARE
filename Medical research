# 📊 Perfect! Node is healthy. Here's your **Medical Block Hunter Dashboard**:

# Save as MedicalHunter-Dashboard.ps1
Clear-Host
$CLI = "bitcoin-cli"

Write-Host "🩺 MEDICAL RESEARCH BLOCK HUNTER DASHBOARD" -ForegroundColor Cyan
Write-Host "=" * 60

# NODE STATUS
$chainInfo = $CLI getblockchaininfo | ConvertFrom-Json
$netInfo = $CLI getnetworkinfo | ConvertFrom-Json

Write-Host "`n🔗 NODE STATUS:" -ForegroundColor Green
Write-Host "  Height: $($chainInfo.blocks) | Headers: $($chainInfo.headers)"
Write-Host "  Chain: $($chainInfo.chain) | TX Index: $($chainInfo.txindex ?? '❌ DISABLED')"
Write-Host "  Network: $($netInfo.networks[0].name) | Peers: $($netInfo.connections)"

# QUICK SCAN CONFIG
$scanDepth = 500  # Last N blocks
$txSample = 10    # TX per block
$currentHeight = $chainInfo.blocks

Write-Host "`n🧬 SCAN CONFIG:" -ForegroundColor Yellow
Write-Host "  Range: $($currentHeight - $scanDepth) → $currentHeight"
Write-Host "  TX Sample: $txSample per block"
Write-Host "  Keywords: clinical,trial,genomic,research,nih,fda,pubmed,dna"

# 🚀 LIVE SCAN (Press Ctrl+C to stop)
Write-Host "`n🎯 STARTING SCAN... (Ctrl+C to stop)" -ForegroundColor Red
$hits = @()
$startTime = Get-Date

# SCAN ENGINE
1..$scanDepth | ForEach-Object {
    $height = $currentHeight - $_
    $progress = [math]::Round((($_ / $scanDepth) * 100), 1)
    Write-Progress -Activity "Scanning Blocks" -Status "Block $height ($progress%)" -PercentComplete $progress
    
    try {
        $hash = $CLI getblockhash $height
        $block = $CLI getblock $hash 1 | ConvertFrom-Json
        
        0..($txSample-1) | ForEach-Object {
            if ($_ -lt $block.tx.Count) {
                $txid = $block.tx[$_]
                try {
                    $tx = $CLI getrawtransaction $txid 1 | ConvertFrom-Json
                    $tx.vout | ForEach-Object {
                        if ($_.scriptPubKey.asm -match "OP_RETURN") {
                            $asm = $_.scriptPubKey.asm.ToLower()
                            $keywords = @("clinical","trial","genomic","research","nih","fda","pubmed","patient","dna","mri")
                            $score = ($keywords | Where-Object { $asm -match $_ }).Count
                            
                            if ($score -gt 0) {
                                $hits += [PSCustomObject]@{
                                    Height = $height
                                    BlockHash = $hash.Substring(0,16)+"..."
                                    TxID = $txid.Substring(0,16)+"..."
                                    Score = $score
                                    OP_RETURN = $_.scriptPubKey.asm.Substring(0,60)+"..."
                                    Value = "{0:N8}" -f $_.value
                                }
                                Write-Host "🎯 HIT! Block $height Tx:$txid Score:$score" -ForegroundColor Red
                            }
                        }
                    }
                } catch {}
            }
        }
    } catch {}
}

# RESULTS
$endTime = Get-Date
$duration = ($endTime - $startTime).TotalSeconds

Write-Host "`n📈 SCAN COMPLETE!" -ForegroundColor Green
Write-Host "⏱️  Duration: $($duration.ToString('F1'))s | Blocks: $scanDepth | Hits: $($hits.Count)"

if ($hits.Count -gt 0) {
    Write-Host "`n🎯 MEDICAL RESEARCH BLOCKS:" -ForegroundColor Red
    $hits | Sort-Object Score -Descending | Format-Table -AutoSize
    
    # Export
    $filename = "medical_hits_$(Get-Date -f 'yyyyMMdd_HHmmss').csv"
    $hits | Export-Csv $filename -NoTypeInformation
    Write-Host "💾 Exported to: $filename" -ForegroundColor Yellow
} else {
    Write-Host "❌ No medical research blocks found in range" -ForegroundColor Yellow
}
