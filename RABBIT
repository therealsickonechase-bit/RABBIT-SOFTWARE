@dataclass
class RepositoryManager:
    """Repository management system"""
    repos: Dict[str, RepositoryConfig]
    repo_lock: threading.RLock
    
    def __init__(self):
        self.repos = {}
        self.repo_lock = threading.RLock()
        
    def create_repository(self, repo_name: str, repo_type: str, remote_url: str, 
                         local_path: str, branch: str = "main") -> RepositoryConfig:
        """Create a new repository"""
        try:
            repo_id = f"REPO_{hashlib.md5(str(time.time()).encode()).hexdigest()[:10]}"
            repo_config = RepositoryConfig(
                repo_id=repo_id,
                repo_name=repo_name,
                repo_type=repo_type,
                remote_url=remote_url,
                local_path=local_path,
                branch=branch,
                last_sync=datetime.now().isoformat(),
                status="active",
                access_level="private",
                security_protocols=["ssh", "https", "git"],
                collaboration_members=["RABBIT_DEV"],
                last_commit={
                    "commit_id": "master",
                    "timestamp": datetime.now().isoformat(),
                    "message": "Initial commit"
                },
                dependencies={}
            )
            
            with self.repo_lock:
                self.repos[repo_name] = repo_config
            
            logger.info(f"Created repository: {repo_name}")
            return repo_config
            
        except Exception as e:
            logger.error(f"Failed to create repository {repo_name}: {e}")
            return None
    
    def delete_repository(self, repo_name: str) -> bool:
        """Delete a repository"""
        try:
            with self.repo_lock:
                if repo_name in self.repos:
                    # Remove local files
                    if os.path.exists(self.repos[repo_name].local_path):
                        shutil.rmtree(self.repos[repo_name].local_path)
                    del self.repos[repo_name]
            
            logger.info(f"Deleted repository: {repo_name}")
            return True
            
        except Exception as e:
            logger.error(f"Failed to delete repository {repo_name}: {e}")
            return False
    
    def sync_repository(self, repo_name: str) -> Dict:
        """Sync repository with remote"""
        try:
            with self.repo_lock:
                if repo_name not in self.repos:
                    return {"status": "error", "message": "Repository not found"}
                
                repo = self.repos[repo_name]
                
                # Simulate sync process
                try:
                    if not os.path.exists(repo.local_path):
                        os.makedirs(repo.local_path)
                    
                    # For demo purposes, we'll just update metadata
                    repo.last_sync = datetime.now().isoformat()
                    repo.status = "synced"
                    
                    return {
                        "status": "success",
                        "repo": repo_name,
                        "last_sync": repo.last_sync,
                        "message": "Repository synced successfully"
                    }
                    
                except Exception as sync_error:
                    repo.status = "sync_error"
                    return {
                        "status": "error",
                        "repo": repo_name,
                        "message": f"Sync failed: {str(sync_error)}"
                    }
                    
        except Exception as e:
            logger.error(f"Repository sync failed for {repo_name}: {e}")
            return {"status": "error", "message": str(e)}
    
    def get_repository_info(self, repo_name: str) -> Optional[Dict]:
        """Get repository information"""
        try:
            with self.repo_lock:
                if repo_name in self.repos:
                    return {"repo": asdict(self.repos[repo_name])}
                return None
        except Exception as e:
            logger.error(f"Failed to get repository info for {repo_name}: {e}")
            return None
    
    def list_repositories(self) -> List[Dict]:
        """List all repositories"""
        try:
            with self.repo_lock:
                return [{"repo": asdict(repo)} for repo in self.repos.values()]
        except Exception as e:
            logger.error(f"Failed to list repositories: {e}")
            return []

# Enhanced Bootstrap and Communication System
class RABBITBootSystem:
    """Complete RABBIT system with repository management"""
    
    def __init__(self):
        self.system_components = {}
        self.root_config = {}
        self.repo_manager = RepositoryManager()
        self.boot_processes = deque(maxlen=1000)
        self.system_status = {
            "initialized": False,
            "booted": False,
            "health": "unknown"
        }
        self.boot_lock = threading.RLock()
        self.boot_history = deque(maxlen=500)
        self._initialize_system()
    
    def _initialize_system(self):
        """Initialize the boot system and root configuration"""
        try:
            # Create system directory structure
            self.system_root = "./rabbit_system"
            os.makedirs(self.system_root, exist_ok=True)
            os.makedirs(os.path.join(self.system_root, "boot"), exist_ok=True)
            os.makedirs(os.path.join(self.system_root, "components"), exist_ok=True)
            os.makedirs(os.path.join(self.system_root, "repos"), exist_ok=True)
            os.makedirs(os.path.join(self.system_root, "logs"), exist_ok=True)
            
            # Set up basic root configuration
            self.root_config = {
                "system_name": "RABBIT VR Secure Package Delivery",
                "version": "2.2.8-FULL-RELEASE",
                "boot_timestamp": datetime.now().isoformat(),
                "security_level": "high",
                "autonomous_testing": True,
                "cloud_integration": True,
                "repository_support": True,
                "network_protocols": [
                    "HTTP", "HTTPS", "TCP", "UDP", "IP", "SSH", "FTP", "DNS",
                    "SMTP", "IMAP", "WLAN", "LAN", "WAN", "VPN", "CAN", "MAN"
                ],
                "repository_types": [
                    "git", "svn", "mercurial"
                ],
                "test_interval": 3600  # 1 hour
            }
            
            # Initialize default repositories
            self._setup_default_repositories()
            
            self.system_status["initialized"] = True
            logger.info("System boot initializer completed")
            
        except Exception as e:
            logger.error(f"System initialization failed: {e}")
            self.system_status["health"] = "critical"
    
    def _setup_default_repositories(self):
        """Setup default repositories for RABBIT software"""
        try:
            # RABBIT core repository
            core_repo = self.repo_manager.create_repository(
                repo_name="RABBIT-SOFTWARE-CORE",
                repo_type="git",
                remote_url="https://github.com/chaseringquist/rabbit-core.git",
                local_path="./rabbit_system/repos/rabbit-core",
                branch="main"
            )
            
            # RABBIT tools repository
            tools_repo = self.repo_manager.create_repository(
                repo_name="RABBIT-SOFTWARE-TOOLS",
                repo_type="git",
                remote_url="https://github.com/chaseringquist/rabbit-tools.git",
                local_path="./rabbit_system/repos/rabbit-tools",
                branch="develop"
            )
            
            # RABBIT plugins repository
            plugins_repo = self.repo_manager.create_repository(
                repo_name="RABBIT-SOFTWARE-PLUGINS",
                repo_type="git",
                remote_url="https://github.com/chaseringquist/rabbit-plugins.git",
                local_path="./rabbit_system/repos/rabbit-plugins",
                branch="master"
            )
            
            logger.info("Default repositories created successfully")
            
        except Exception as e:
            logger.error(f"Failed to setup default repositories: {e}")
    
    def boot_system(self) -> Dict:
        """Boot the system with repository system"""
        try:
            timestamp = datetime.now().isoformat()
            
            # Boot process steps
            boot_steps = [
                "Initialize core components",
                "Setup system directories",
                "Configure repository management",
                "Load repository configurations",
                "Initialize network interfaces",
                "Configure security protocols",
                "Start repository sync services",
                "Initialize dashboard components"
            ]
            
            # Simulate boot process
            boot_process = {
                "boot_id": f"BOOT_{hashlib.md5(str(time.time()).encode()).hexdigest()[:10]}",
                "timestamp": timestamp,
                "steps": [],
                "status": "booting",
                "system_config": self.root_config,
                "health": "booting"
            }
            
            # Execute steps with real-time status updates
            for i, step in enumerate(boot_steps):
                try:
                    # Simulate step execution
                    time.sleep(0.1)  # Simulate processing time
                    step_result = {
                        "step": i + 1,
                        "name": step,
                        "status": "completed",
                        "timestamp": datetime.now().isoformat(),
                        "duration": 0.1
                    }
                    boot_process["steps"].append(step_result)
                    
                except Exception as step_error:
                    step_result = {
                        "step": i + 1,
                        "name": step,
                        "status": "failed",
                        "timestamp": datetime.now().isoformat(),
                        "error": str(step_error)
                    }
                    boot_process["steps"].append(step_result)
                    logger.warning(f"Boot step {step} failed: {step_error}")
            
            boot_process["status"] = "completed"
            boot_process["health"] = "healthy" if all(
                s["status"] == "completed" for s in boot_process["steps"]
            ) else "degraded"
            
            # Save boot process
            with self.boot_lock:
                self.boot_processes.append(boot_process)
                self.system_status["booted"] = True
                self.system_status["health"] = boot_process["health"]
            
            logger.info(f"System boot completed with ID: {boot_process['boot_id']}")
            return boot_process
            
        except Exception as e:
            error_msg = f"System boot failed: {e}"
            logger.error(error_msg)
            self.system_status["health"] = "critical"
            
            boot_process = {
                "boot_id": f"BOOT_ERROR_{hashlib.md5(str(time.time()).encode()).hexdigest()[:10]}",
                "timestamp": datetime.now().isoformat(),
                "steps": [],
                "status": "failed",
                "error": error_msg,
                "health": "critical"
            }
            return boot_process
    
    def add_system_component(self, component_name: str, component_info: Dict):
        """Add a system component to the bootstrap"""
        try:
            with self.boot_lock:
                self.system_components[component_name] = {
                    "name": component_name,
                    "info": component_info,
                    "registered_timestamp": datetime.now().isoformat(),
                    "status": "active"
                }
            logger.info(f"Component {component_name} registered")
            return True
        except Exception as e:
            logger.error(f"Failed to register component {component_name}: {e}")
            return False

