pragma solidity ^0.8.20;

import "@openzeppelin/contracts/access/AccessControl.sol";
import "@openzeppelin/contracts/token/ERC20/IERC20.sol";

contract ChaseNeuralVault is AccessControl {
    // Your DNA risk tiers as roles
    bytes32 public constant RESEARCHER_ROLE = keccak256("RESEARCHER_ROLE");
    bytes32 public constant GOVERNMENT_ROLE = keccak256("GOVERNMENT_ROLE");
    bytes32 public constant CONTRACTOR_ROLE = keccak256("CONTRACTOR_ROLE");
    bytes32 public constant OWNER_ROLE = keccak256("OWNER_ROLE");
    
    IERC20 public immutable xrpToken;  // XRPL bridge token
    uint256 public constant RESEARCH_PRICE = 0.001 ether;
    
    mapping(bytes32 => bool) public releasedBuckets;
    
    event DataAccessRequest(
        address indexed requester,
        bytes32 indexed bucketHash,
        uint256 timestamp
    );
    
    constructor(address _xrpToken) {
        xrpToken = IERC20(_xrpToken);
        
        // Chase = supreme owner
        _grantRole(DEFAULT_ADMIN_ROLE, msg.sender);
        _grantRole(OWNER_ROLE, msg.sender);
    }
    
    // Research access (LOW tier buckets only)
    function requestResearchBucket(bytes32 bucketHash) 
        external 
        onlyRole(RESEARCHER_ROLE)
    {
        require(!releasedBuckets[bucketHash], "Already released");
        require(xrpToken.transferFrom(msg.sender, address(this), RESEARCH_PRICE), "Payment failed");
        
        releasedBuckets[bucketHash] = true;
        emit DataAccessRequest(msg.sender, bucketHash, block.timestamp);
    }
    
    // Government access (MEDIUM tier + court order proof)
    function requestGovernmentBucket(bytes32 bucketHash, bytes32 courtOrderHash) 
        external 
        onlyRole(GOVERNMENT_ROLE)
        payable 
    {
        require(keccak256(abi.encodePacked("DOJ_ORDER_2026")) == courtOrderHash, "Invalid court order");
        // Same payment + LOW tier logic
        _safeBucketRelease(msg.sender, bucketHash);
    }
    
    // Contractor code review (no data access)
    function validateContractorCode(bytes32 codeHash, bytes32 thresholdSig) 
        external 
        onlyRole(CONTRACTOR_ROLE)
    {
        // Verify 3-of-5 node threshold signature (off-chain oracle)
        require(verifyThresholdSignature(thresholdSig), "Invalid node consensus");
        emit CodeValidated(msg.sender, codeHash);
    }
    
    // Owner functions (full control)
    function grantResearcher(address researcher) external onlyRole(OWNER_ROLE) {
        _grantRole(RESEARCHER_ROLE, researcher);
    }
    
    function revokeAccess(address user) external onlyRole(OWNER_ROLE) {
        _revokeRole(RESEARCHER_ROLE, user);
        _revokeRole(GOVERNMENT_ROLE, user);
        _revokeRole(CONTRACTOR_ROLE, user);
    }
    
    // Emergency shutdown (CHEST_01 equivalent)
    function emergencyVaultLock() external onlyRole(DEFAULT_ADMIN_ROLE) {
        // Pause all new requests
        // Critical data remains physically vaulted
    }
    
    function _safeBucketRelease(address requester, bytes32 bucketHash) internal {
        require(!releasedBuckets[bucketHash], "Already released");
        releasedBuckets[bucketHash] = true;
        emit DataAccessRequest(requester, bucketHash, block.timestamp);
    }
}